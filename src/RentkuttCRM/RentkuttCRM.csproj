    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>ee03b278-06d1-466c-88de-c840f5fc8010</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Migrations\*.sql" />
