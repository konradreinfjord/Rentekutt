@inherits LayoutComponentBase
@implements IDisposable
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.SupabaseUserService Users
@inject RentkuttCRM.Services.LinkMobilityService LinkMobility
@inject RentkuttCRM.Services.WebhookService Webhooks
@inject NavigationManager Nav

@if (!Session.IsLoggedIn)
{
    @* Login og andre åpne sider vises uten skall *@
    @Body
}
else
{
    <div class="app-shell">
        <NavSidebar />
        <div class="app-main">
            <header class="app-topbar">
                <div class="topbar-left">
                    <div class="topbar-clock">
                        <span class="live-dot" title="Live"></span>
                        <span class="clock-time">@_now.ToString("HH:mm:ss")</span>
                        <span class="clock-date">@_now.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="health @(_issues.Count == 0 ? "health-ok" : "health-feil")"
                         title="@(_issues.Count == 0 ? "Alle systemer OK" : $"{_issues.Count} tekniske feil")"
                         @onclick="() => _healthOpen = !_healthOpen">
                        @if (_issues.Count == 0)
                        {
                            <span class="health-icon">✓</span>
                            <span class="health-label">Alle systemer OK</span>
                        }
                        else
                        {
                            <span class="health-icon">⚠</span>
                            <span class="health-count">@_issues.Count</span>
                        }
                        @if (_healthOpen)
                        {
                            <div class="health-panel" @onclick:stopPropagation="true">
                                @if (_issues.Count == 0)
                                {
                                    <div class="health-panel-title ok">✓ Alle tekniske overføringer OK</div>
                                }
                                else
                                {
                                    <div class="health-panel-title feil">@_issues.Count tekniske feil</div>
                                    @foreach (var i in _issues)
                                    {
                                        <div class="health-item">
                                            <span class="lampe off"></span>
                                            <div><strong>@i.Navn</strong><div class="health-item-msg">@i.Melding</div></div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="topbar-user">
                    <span class="user-name">@Session.UserName</span>
                    <span class="user-role">@Session.Role</span>
                    <button class="btn-logout" @onclick="LogOut">Logg ut</button>
                </div>
            </header>
            <main class="app-content">
                <ErrorBoundary @ref="_errorBoundary">
                    <ChildContent>@Body</ChildContent>
                    <ErrorContent>
                        <div class="form-card" style="max-width:520px;margin:40px auto;text-align:center">
                            <h2>Noe gikk galt</h2>
                            <p class="page-sub">Siden støtte på en uventet feil. Prøv igjen, eller gå tilbake til dashbordet.</p>
                            <button class="btn-primary" @onclick="NullstillFeil">Prøv igjen</button>
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </main>
        </div>
    </div>
}

@code {
    private DateTime _now = DateTime.Now;
    private System.Threading.Timer? _timer;
    private ErrorBoundary? _errorBoundary;

    private List<(string Navn, string Melding)> _issues = new();
    private bool _healthOpen;
    private int _tick;

    // Sjekk om noen tekniske overføringer feiler (vises som varsellampe i headeren).
    private async Task SjekkHelseAsync()
    {
        var issues = new List<(string, string)>();
        if (!Users.IsConfigured) issues.Add(("Database (Supabase)", "Ikke konfigurert / ikke tilkoblet"));
        if (!LinkMobility.ErKonfigurert) issues.Add(("LinkMobility", "SMS/2FA ikke konfigurert"));
        try
        {
            var hooks = new[] { await Webhooks.GetInboundAsync(), await Webhooks.GetByNameAsync(RentkuttCRM.Services.WebhookService.PrismatchName) };
            foreach (var w in hooks)
            {
                // Feil = kanal som var aktiv og har mottatt data før, men ikke siste 3 døgn.
                if (w is { Active: true, LastReceivedAt: { } t } && t <= DateTime.UtcNow.AddDays(-3))
                    issues.Add(($"Kanal: {w.Name}", $"Ingen data siste 3 døgn (sist {t.ToLocalTime():dd.MM HH:mm})"));
            }
        }
        catch { /* nettverksfeil ved helsesjekk skal ikke velte UI */ }
        _issues = issues;
    }

    private void NullstillFeil() => _errorBoundary?.Recover();

    // Nullstill feilgrensen ved navigasjon, så en feil på én side ikke henger igjen.
    protected override void OnParametersSet() => _errorBoundary?.Recover();

    protected override void OnInitialized()
    {
        _timer = new System.Threading.Timer(async _ =>
        {
            // Oppdater kun klokka når man er innlogget (skjermen vises) — unngå
            // å re-rendre login-siden hvert sekund (kan forstyrre innloggingen).
            if (!Session.IsLoggedIn) return;
            _now = DateTime.Now;
            if (_tick++ % 30 == 0) await SjekkHelseAsync();   // helsesjekk hvert 30. sek (og ved oppstart)
            await InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private void LogOut()
    {
        Session.SignOut();
        Nav.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose() => _timer?.Dispose();
}
