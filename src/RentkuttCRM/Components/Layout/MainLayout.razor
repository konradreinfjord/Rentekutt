@inherits LayoutComponentBase
@implements IDisposable
@inject RentkuttCRM.Services.SessionState Session
@inject NavigationManager Nav

@if (!Session.IsLoggedIn)
{
    @* Login og andre åpne sider vises uten skall *@
    @Body
}
else
{
    <div class="app-shell">
        <NavSidebar />
        <div class="app-main">
            <header class="app-topbar">
                <div class="topbar-clock">
                    <span class="live-dot" title="Live"></span>
                    <span class="clock-time">@_now.ToString("HH:mm:ss")</span>
                    <span class="clock-date">@_now.ToString("dd.MM.yyyy")</span>
                </div>
                <div class="topbar-user">
                    <span class="user-name">@Session.UserName</span>
                    <span class="user-role">@Session.Role</span>
                    <button class="btn-logout" @onclick="LogOut">Logg ut</button>
                </div>
            </header>
            <main class="app-content">
                <ErrorBoundary @ref="_errorBoundary">
                    <ChildContent>@Body</ChildContent>
                    <ErrorContent>
                        <div class="form-card" style="max-width:520px;margin:40px auto;text-align:center">
                            <h2>Noe gikk galt</h2>
                            <p class="page-sub">Siden støtte på en uventet feil. Prøv igjen, eller gå tilbake til dashbordet.</p>
                            <button class="btn-primary" @onclick="NullstillFeil">Prøv igjen</button>
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </main>
        </div>
    </div>
}

@code {
    private DateTime _now = DateTime.Now;
    private System.Threading.Timer? _timer;
    private ErrorBoundary? _errorBoundary;

    private void NullstillFeil() => _errorBoundary?.Recover();

    // Nullstill feilgrensen ved navigasjon, så en feil på én side ikke henger igjen.
    protected override void OnParametersSet() => _errorBoundary?.Recover();

    protected override void OnInitialized()
    {
        _timer = new System.Threading.Timer(_ =>
        {
            // Oppdater kun klokka når man er innlogget (skjermen vises) — unngå
            // å re-rendre login-siden hvert sekund (kan forstyrre innloggingen).
            if (!Session.IsLoggedIn) return;
            _now = DateTime.Now;
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private void LogOut()
    {
        Session.SignOut();
        Nav.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose() => _timer?.Dispose();
}
