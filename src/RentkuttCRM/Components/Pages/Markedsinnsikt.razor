@page "/crm/markedsinnsikt"
@using System.Globalization
@using System.Text
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.KundekortService Svc
@inject RentkuttCRM.Services.StyringsrenteService StyringSvc
@inject NavigationManager Nav

<PageTitle>Markedsinnsikt — Rentekutt</PageTitle>

<div class="wide-page"></div>

<h1 class="page-title">Markedsinnsikt</h1>
<p class="page-sub">Rentenivå kundene har oppgitt fra søknad (rentkutt.no), sammenlignet med Norges Banks styringsrente over tid.</p>

@if (_loading)
{
    <p class="page-sub">Laster…</p>
}
else
{
    <div class="db-stats">
        <div class="db-box"><span class="db-box-num">@_punkter.Count</span><span class="db-box-lbl">Registrerte renter</span></div>
        <div class="db-box"><span class="db-box-num">@_banker.Count</span><span class="db-box-lbl">Banker</span></div>
        <div class="db-box accent-blue"><span class="db-box-num">@(_punkter.Count > 0 ? _snittRente.ToString("N2", Nb) + " %" : "—")</span><span class="db-box-lbl">Snitt kunderente</span></div>
        <div class="db-box accent-amber"><span class="db-box-num">@(_punkter.Count > 0 ? _snittMargin.ToString("N2", Nb) + " pp" : "—")</span><span class="db-box-lbl">Snitt over styringsrente</span></div>
    </div>

    <div class="section">
        <h2>Siste 12 måneder</h2>
        <p class="page-sub">Styringsrenten som referanse, med kundenes registrerte rente rundt. Boblestørrelse følger lånebeløpet.</p>
        @if (_punkter12.Count == 0)
        {
            <p class="page-sub">Ingen registrerte renter siste 12 måneder. De kommer inn fra søknadene og fra «Lagre bank &amp; rente» på kundekortet.</p>
        }
        else
        {
            <div class="mi-legend">
                <span class="mi-leg"><span class="mi-swatch" style="background:#c2740a"></span>Styringsrente — @_styringKilde</span>
                <span class="mi-leg"><span class="mi-swatch" style="background:#266f32"></span>Snitt kunderente (mnd)</span>
                <span class="mi-leg"><span class="mi-dot" style="background:#1f5fc4"></span>Fra søknad (@_antSoknad)</span>
                <span class="mi-leg"><span class="mi-dot" style="background:#6b3fc4"></span>Manuelt registrert (@_antManuell)</span>
            </div>
            <div class="mi-chart">
                <svg viewBox="0 0 900 340" preserveAspectRatio="none" role="img" aria-label="Rentenivå siste 12 måneder">
                    @((MarkupString)_svgTrend)
                </svg>
            </div>
        }
    </div>

    <div class="section">
        <h2>Rente vs lånebeløp</h2>
        <p class="page-sub">Hvert punkt er en kunde: lånebeløp (MNOK) mot oppgitt rente. Viser rentespredning på tvers av lånestørrelse.</p>
        @if (_belopPunkter == 0)
        {
            <p class="page-sub">Ingen kunder med både lånebeløp og rente registrert ennå.</p>
        }
        else
        {
            <div class="mi-legend">
                <span class="mi-leg"><span class="mi-dot" style="background:#1f5fc4"></span>Fra søknad</span>
                <span class="mi-leg"><span class="mi-dot" style="background:#6b3fc4"></span>Manuelt registrert</span>
                <span class="mi-leg"><span class="mi-swatch" style="background:#c2740a"></span>Styringsrente nå (@_naaStyring.ToString("N2", Nb) %)</span>
            </div>
            <div class="mi-chart">
                <svg viewBox="0 0 900 340" preserveAspectRatio="none" role="img" aria-label="Rente mot lånebeløp">
                    @((MarkupString)_svgBelop)
                </svg>
            </div>
        }
    </div>

    <div class="section">
        <h2>Registrerte renter per bank</h2>
        <div class="table-scroll">
        <table class="data-table">
            <thead>
                <tr><th>Bank</th><th class="num">Antall</th><th class="num">Snitt</th><th class="num">Laveste</th><th class="num">Høyeste</th><th class="num">Over styringsrente</th><th>Sist registrert</th></tr>
            </thead>
            <tbody>
                @if (_banker.Count == 0)
                {
                    <tr><td colspan="7" class="empty-row">Ingen data ennå.</td></tr>
                }
                @foreach (var b in _banker)
                {
                    <tr>
                        <td>@b.Bank</td>
                        <td class="num">@b.Antall</td>
                        <td class="num">@b.Snitt.ToString("N2", Nb) %</td>
                        <td class="num">@b.Min.ToString("N2", Nb) %</td>
                        <td class="num">@b.Max.ToString("N2", Nb) %</td>
                        <td class="num">@((b.Snitt - (decimal)_naaStyring).ToString("N2", Nb)) pp</td>
                        <td>@b.Siste.ToLocalTime().ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
}

@code {
    private static readonly CultureInfo Nb = CultureInfo.GetCultureInfo("nb-NO");
    private static readonly CultureInfo Inv = CultureInfo.InvariantCulture;

    private bool _loading = true;
    private List<Punkt> _punkter = new();      // alle med bank + rente
    private List<Punkt> _punkter12 = new();     // siste 12 måneder
    private List<BankRad> _banker = new();
    private decimal _snittRente, _snittMargin;
    private double _naaStyring;
    private int _antSoknad, _antManuell, _belopPunkter;
    private double _maxBelop;

    private record Punkt(DateTime Dato, string Bank, decimal Rente, decimal? Belop, bool Soknad);
    private record BankRad(string Bank, int Antall, decimal Snitt, decimal Min, decimal Max, DateTime Siste);

    // Norges Banks styringsrente (endringsdatoer) — hentes live via StyringsrenteService.
    private IReadOnlyList<(DateTime Dato, decimal Rente)> _styring = Array.Empty<(DateTime, decimal)>();
    private string _styringKilde = "";

    // Chart-geometri (delt av begge bildene)
    private const double W = 900, H = 340, PadL = 40, PadR = 16, PadT = 14, PadB = 26;
    private const double PlotW = W - PadL - PadR;
    private const double PlotH = H - PadT - PadB;

    private string _svgTrend = "", _svgBelop = "";

    private static string Num(double v) => v.ToString("0.##", Inv);
    private const string BlaSoknad = "#1f5fc4", LillaManuell = "#6b3fc4";
    private static string Farge(bool soknad) => soknad ? BlaSoknad : LillaManuell;

    private decimal RentePaa(DateTime dato)
    {
        if (_styring.Count == 0) return 0m;
        decimal r = _styring[0].Rente;
        foreach (var s in _styring) { if (s.Dato <= dato) r = s.Rente; else break; }
        return r;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

        _styring = await StyringSvc.HentAsync();
        _styringKilde = StyringSvc.Kilde;

        var rows = await Svc.ListAsync();
        _punkter = rows
            .Where(k => !string.IsNullOrWhiteSpace(k.NavarendeBank) && k.NaavaerendeRente is > 0)
            .Select(k => new Punkt(k.CreatedAt, k.NavarendeBank!.Trim(), k.NaavaerendeRente!.Value,
                k.OnsketLaanebelop,
                !string.IsNullOrWhiteSpace(k.Kilde) && !k.Kilde.Equals("Manuell", StringComparison.OrdinalIgnoreCase)))
            .OrderBy(p => p.Dato)
            .ToList();

        _naaStyring = (double)RentePaa(DateTime.UtcNow);

        if (_punkter.Count > 0)
        {
            _snittRente = _punkter.Average(p => p.Rente);
            _snittMargin = _punkter.Average(p => p.Rente - RentePaa(p.Dato));

            _banker = _punkter
                .GroupBy(p => p.Bank, StringComparer.OrdinalIgnoreCase)
                .Select(g => new BankRad(g.Key, g.Count(), g.Average(x => x.Rente),
                    g.Min(x => x.Rente), g.Max(x => x.Rente), g.Max(x => x.Dato)))
                .OrderByDescending(b => b.Antall).ThenBy(b => b.Bank)
                .ToList();

            _maxBelop = _punkter.Where(p => p.Belop is > 0).Select(p => (double)p.Belop!.Value).DefaultIfEmpty(0).Max();

            ByggTrend();
            ByggBelop();
        }

        _loading = false;
    }

    // Bobleradius etter lånebeløp (2.5–9 px).
    private double Radius(decimal? belop) =>
        _maxBelop <= 0 || belop is not > 0 ? 3 : 2.5 + Math.Sqrt((double)belop.Value / _maxBelop) * 6.5;

    // ---- Bilde 1: siste 12 måneder (tid → rente) ----
    private void ByggTrend()
    {
        var xMax = DateTime.Today;
        var xMin = new DateTime(xMax.Year, xMax.Month, 1).AddMonths(-11);
        _punkter12 = _punkter.Where(p => p.Dato.ToLocalTime().Date >= xMin).ToList();
        _antSoknad = _punkter12.Count(p => p.Soknad);
        _antManuell = _punkter12.Count - _antSoknad;
        if (_punkter12.Count == 0) return;

        var relevant = _styring.Where(s => s.Dato <= xMax).Select(s => (double)s.Rente)
            .Concat(_punkter12.Select(p => (double)p.Rente));
        var yMax = Math.Max(8, (int)Math.Ceiling(relevant.Max() + 1));
        if (yMax % 2 != 0) yMax++;

        double X(DateTime d) => PadL + (d - xMin).TotalDays / Math.Max(1, (xMax - xMin).TotalDays) * PlotW;
        double Y(double r) => PadT + PlotH - r / yMax * PlotH;
        var svg = new StringBuilder();

        for (var g = 0; g <= yMax; g += 2)
        {
            svg.Append($"<line x1=\"{Num(PadL)}\" y1=\"{Num(Y(g))}\" x2=\"{Num(W - PadR)}\" y2=\"{Num(Y(g))}\" stroke=\"var(--border)\" stroke-width=\"1\" />");
            svg.Append($"<text x=\"{Num(PadL - 6)}\" y=\"{Num(Y(g) + 3)}\" text-anchor=\"end\" font-size=\"10\" fill=\"var(--text-2)\">{g} %</text>");
        }
        // Måned-ticks
        for (var m = 0; m <= 12; m += 2)
        {
            var t = xMin.AddMonths(m);
            var x = X(t);
            svg.Append($"<line x1=\"{Num(x)}\" y1=\"{Num(PadT)}\" x2=\"{Num(x)}\" y2=\"{Num(H - PadB)}\" stroke=\"var(--border)\" stroke-width=\"1\" stroke-dasharray=\"2 3\" />");
            svg.Append($"<text x=\"{Num(x)}\" y=\"{Num(H - PadB + 14)}\" text-anchor=\"middle\" font-size=\"10\" fill=\"var(--text-2)\">{t.ToString("MMM yy", Nb)}</text>");
        }
        // Styringsrente (stegvis, fremhevet referanse)
        var sb = new StringBuilder();
        var startR = (double)RentePaa(xMin);
        sb.Append("M ").Append(Num(X(xMin))).Append(' ').Append(Num(Y(startR)));
        var prev = startR;
        foreach (var s in _styring.Where(s => s.Dato > xMin && s.Dato <= xMax))
        {
            var x = Num(X(s.Dato));
            sb.Append(" L ").Append(x).Append(' ').Append(Num(Y(prev)));
            sb.Append(" L ").Append(x).Append(' ').Append(Num(Y((double)s.Rente)));
            prev = (double)s.Rente;
        }
        sb.Append(" L ").Append(Num(X(xMax))).Append(' ').Append(Num(Y(prev)));
        svg.Append($"<path d=\"{sb}\" fill=\"none\" stroke=\"#c2740a\" stroke-width=\"2.5\" stroke-linejoin=\"round\" />");

        // Kundepunkter — farge = kilde, størrelse = lånebeløp
        foreach (var p in _punkter12)
            svg.Append($"<circle cx=\"{Num(X(p.Dato))}\" cy=\"{Num(Y((double)p.Rente))}\" r=\"{Num(Radius(p.Belop))}\" fill=\"{Farge(p.Soknad)}\" fill-opacity=\"0.45\" />");

        // Snitt kunderente per måned
        var mnd = _punkter12
            .GroupBy(p => new DateTime(p.Dato.Year, p.Dato.Month, 15))
            .Select(g => (Dato: g.Key, Snitt: (double)g.Average(x => x.Rente)))
            .OrderBy(x => x.Dato).ToList();
        if (mnd.Count >= 2)
        {
            var tb = new StringBuilder();
            for (var i = 0; i < mnd.Count; i++)
                tb.Append(i == 0 ? "M " : " L ").Append(Num(X(mnd[i].Dato))).Append(' ').Append(Num(Y(mnd[i].Snitt)));
            svg.Append($"<path d=\"{tb}\" fill=\"none\" stroke=\"#266f32\" stroke-width=\"2\" stroke-linejoin=\"round\" />");
        }

        _svgTrend = svg.ToString();
    }

    // ---- Bilde 2: rente vs lånebeløp ----
    private void ByggBelop()
    {
        var pts = _punkter.Where(p => p.Belop is > 0).ToList();
        _belopPunkter = pts.Count;
        if (pts.Count == 0) return;

        var bMaxM = Math.Max(1, Math.Ceiling((double)pts.Max(p => p.Belop!.Value) / 1_000_000.0)); // MNOK, rundet opp
        var yMax = Math.Max(8, (int)Math.Ceiling(Math.Max((double)pts.Max(p => p.Rente), _naaStyring) + 1));
        if (yMax % 2 != 0) yMax++;

        double X(double mnok) => PadL + mnok / bMaxM * PlotW;
        double Y(double r) => PadT + PlotH - r / yMax * PlotH;
        var svg = new StringBuilder();

        for (var g = 0; g <= yMax; g += 2)
        {
            svg.Append($"<line x1=\"{Num(PadL)}\" y1=\"{Num(Y(g))}\" x2=\"{Num(W - PadR)}\" y2=\"{Num(Y(g))}\" stroke=\"var(--border)\" stroke-width=\"1\" />");
            svg.Append($"<text x=\"{Num(PadL - 6)}\" y=\"{Num(Y(g) + 3)}\" text-anchor=\"end\" font-size=\"10\" fill=\"var(--text-2)\">{g} %</text>");
        }
        // X-ticks i MNOK
        for (var i = 0; i <= 5; i++)
        {
            var mnok = bMaxM * i / 5;
            var x = X(mnok);
            svg.Append($"<line x1=\"{Num(x)}\" y1=\"{Num(PadT)}\" x2=\"{Num(x)}\" y2=\"{Num(H - PadB)}\" stroke=\"var(--border)\" stroke-width=\"1\" stroke-dasharray=\"2 3\" />");
            svg.Append($"<text x=\"{Num(x)}\" y=\"{Num(H - PadB + 14)}\" text-anchor=\"middle\" font-size=\"10\" fill=\"var(--text-2)\">{mnok.ToString("0.#", Nb)} M</text>");
        }
        // Styringsrente nå — horisontal referanse
        svg.Append($"<line x1=\"{Num(PadL)}\" y1=\"{Num(Y(_naaStyring))}\" x2=\"{Num(W - PadR)}\" y2=\"{Num(Y(_naaStyring))}\" stroke=\"#c2740a\" stroke-width=\"1.5\" stroke-dasharray=\"5 4\" />");

        // Punkter: x = lånebeløp, y = rente, farge = kilde
        foreach (var p in pts)
            svg.Append($"<circle cx=\"{Num(X((double)p.Belop!.Value / 1_000_000.0))}\" cy=\"{Num(Y((double)p.Rente))}\" r=\"4\" fill=\"{Farge(p.Soknad)}\" fill-opacity=\"0.5\" />");

        _svgBelop = svg.ToString();
    }
}
