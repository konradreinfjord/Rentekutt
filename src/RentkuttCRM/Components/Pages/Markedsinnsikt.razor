@page "/crm/markedsinnsikt"
@using System.Globalization
@using System.Text
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.KundekortService Svc
@inject RentkuttCRM.Services.StyringsrenteService StyringSvc
@inject NavigationManager Nav

<PageTitle>Markedsinnsikt — Rentekutt</PageTitle>

<div class="wide-page"></div>

<h1 class="page-title">Markedsinnsikt</h1>
<p class="page-sub">Rentenivå kundene har oppgitt fra søknad (rentkutt.no), sammenlignet med Norges Banks styringsrente over tid.</p>

@if (_loading)
{
    <p class="page-sub">Laster…</p>
}
else
{
    <div class="db-stats">
        <div class="db-box"><span class="db-box-num">@_punkter.Count</span><span class="db-box-lbl">Registrerte renter</span></div>
        <div class="db-box"><span class="db-box-num">@_banker.Count</span><span class="db-box-lbl">Banker</span></div>
        <div class="db-box accent-blue"><span class="db-box-num">@(_punkter.Count > 0 ? _snittRente.ToString("N2", Nb) + " %" : "—")</span><span class="db-box-lbl">Snitt kunderente</span></div>
        <div class="db-box accent-amber"><span class="db-box-num">@(_punkter.Count > 0 ? _snittMargin.ToString("N2", Nb) + " pp" : "—")</span><span class="db-box-lbl">Snitt over styringsrente</span></div>
    </div>

    <div class="section">
        <h2>Rentenivå over tid</h2>
        @if (_punkter.Count == 0)
        {
            <p class="page-sub">Ingen registrerte renter ennå. De kommer inn fra søknadene og fra «Lagre bank &amp; rente» på kundekortet.</p>
        }
        else
        {
            <div class="mi-legend">
                <span class="mi-leg"><span class="mi-swatch" style="background:#c2740a"></span>Styringsrente — @_styringKilde</span>
                <span class="mi-leg"><span class="mi-swatch" style="background:#266f32"></span>Snitt kunderente (mnd)</span>
                <span class="mi-leg"><span class="mi-dot" style="background:#1f5fc4"></span>Registrert kunderente</span>
            </div>
            <div class="mi-chart">
                <svg viewBox="0 0 900 340" preserveAspectRatio="none" role="img" aria-label="Rentenivå over tid">
                    @((MarkupString)_svgInner)
                </svg>
            </div>
        }
    </div>

    <div class="section">
        <h2>Registrerte renter per bank</h2>
        <div class="table-scroll">
        <table class="data-table">
            <thead>
                <tr><th>Bank</th><th class="num">Antall</th><th class="num">Snitt</th><th class="num">Laveste</th><th class="num">Høyeste</th><th class="num">Over styringsrente</th><th>Sist registrert</th></tr>
            </thead>
            <tbody>
                @if (_banker.Count == 0)
                {
                    <tr><td colspan="7" class="empty-row">Ingen data ennå.</td></tr>
                }
                @foreach (var b in _banker)
                {
                    <tr>
                        <td>@b.Bank</td>
                        <td class="num">@b.Antall</td>
                        <td class="num">@b.Snitt.ToString("N2", Nb) %</td>
                        <td class="num">@b.Min.ToString("N2", Nb) %</td>
                        <td class="num">@b.Max.ToString("N2", Nb) %</td>
                        <td class="num">@((b.Snitt - (decimal)_naaStyring).ToString("N2", Nb)) pp</td>
                        <td>@b.Siste.ToLocalTime().ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
}

@code {
    private static readonly CultureInfo Nb = CultureInfo.GetCultureInfo("nb-NO");
    private static readonly CultureInfo Inv = CultureInfo.InvariantCulture;

    private bool _loading = true;
    private List<Punkt> _punkter = new();
    private List<BankRad> _banker = new();
    private decimal _snittRente, _snittMargin;
    private double _naaStyring;

    private record Punkt(DateTime Dato, string Bank, decimal Rente);
    private record BankRad(string Bank, int Antall, decimal Snitt, decimal Min, decimal Max, DateTime Siste);

    // Norges Banks styringsrente (endringsdatoer) — hentes live via StyringsrenteService.
    private IReadOnlyList<(DateTime Dato, decimal Rente)> _styring = Array.Empty<(DateTime, decimal)>();
    private string _styringKilde = "";

    // Chart-geometri
    private const double W = 900, H = 340, PadL = 40, PadR = 16, PadT = 14, PadB = 26;
    private double PlotW => W - PadL - PadR;
    private double PlotH => H - PadT - PadB;
    private DateTime _xMin, _xMax;
    private int _yMax = 8;
    private string _svgInner = "";

    private double X(DateTime d) => PadL + (d - _xMin).TotalDays / Math.Max(1, (_xMax - _xMin).TotalDays) * PlotW;
    private double Y(double rente) => PadT + PlotH - rente / _yMax * PlotH;

    private decimal RentePaa(DateTime dato)
    {
        if (_styring.Count == 0) return 0m;
        decimal r = _styring[0].Rente;
        foreach (var s in _styring) { if (s.Dato <= dato) r = s.Rente; else break; }
        return r;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

        _styring = await StyringSvc.HentAsync();
        _styringKilde = StyringSvc.Kilde;

        var rows = await Svc.ListAsync();
        _punkter = rows
            .Where(k => !string.IsNullOrWhiteSpace(k.NavarendeBank) && k.NaavaerendeRente is > 0)
            .Select(k => new Punkt(k.CreatedAt, k.NavarendeBank!.Trim(), k.NaavaerendeRente!.Value))
            .OrderBy(p => p.Dato)
            .ToList();

        _naaStyring = (double)RentePaa(DateTime.UtcNow);

        if (_punkter.Count > 0)
        {
            _snittRente = _punkter.Average(p => p.Rente);
            _snittMargin = _punkter.Average(p => p.Rente - RentePaa(p.Dato));

            _banker = _punkter
                .GroupBy(p => p.Bank, StringComparer.OrdinalIgnoreCase)
                .Select(g => new BankRad(g.Key, g.Count(), g.Average(x => x.Rente),
                    g.Min(x => x.Rente), g.Max(x => x.Rente), g.Max(x => x.Dato)))
                .OrderByDescending(b => b.Antall).ThenBy(b => b.Bank)
                .ToList();

            ByggGraf();
        }

        _loading = false;
    }

    private void ByggGraf()
    {
        // X-vindu: fra tidligste datapunkt (start av måned) til i dag.
        _xMin = new DateTime(_punkter[0].Dato.Year, _punkter[0].Dato.Month, 1);
        _xMax = DateTime.Today;
        if (_xMax <= _xMin) _xMax = _xMin.AddMonths(1);

        var maxRente = (double)_punkter.Max(p => p.Rente);
        _yMax = Math.Max(8, (int)Math.Ceiling(maxRente + 1));
        if (_yMax % 2 != 0) _yMax++;

        string N(double v) => v.ToString("0.##", Inv);
        var svg = new StringBuilder();

        // Y-gridlinjer + labels
        for (var g = 0; g <= _yMax; g += 2)
        {
            svg.Append($"<line x1=\"{N(PadL)}\" y1=\"{N(Y(g))}\" x2=\"{N(W - PadR)}\" y2=\"{N(Y(g))}\" stroke=\"var(--border)\" stroke-width=\"1\" />");
            svg.Append($"<text x=\"{N(PadL - 6)}\" y=\"{N(Y(g) + 3)}\" text-anchor=\"end\" font-size=\"10\" fill=\"var(--text-2)\">{g} %</text>");
        }

        // X-ticks (~6 jevnt fordelt)
        var totalDays = (_xMax - _xMin).TotalDays;
        for (var i = 0; i <= 5; i++)
        {
            var t = _xMin.AddDays(totalDays * i / 5);
            var x = X(t);
            svg.Append($"<line x1=\"{N(x)}\" y1=\"{N(PadT)}\" x2=\"{N(x)}\" y2=\"{N(H - PadB)}\" stroke=\"var(--border)\" stroke-width=\"1\" stroke-dasharray=\"2 3\" />");
            svg.Append($"<text x=\"{N(x)}\" y=\"{N(H - PadB + 14)}\" text-anchor=\"middle\" font-size=\"10\" fill=\"var(--text-2)\">{t.ToString("MMM yy", Nb)}</text>");
        }

        // Styringsrente-sti (stegvis), klippet til vinduet.
        var sb = new StringBuilder();
        var startR = (double)RentePaa(_xMin);
        sb.Append("M ").Append(N(X(_xMin))).Append(' ').Append(N(Y(startR)));
        var prev = startR;
        foreach (var s in _styring.Where(s => s.Dato > _xMin && s.Dato <= _xMax))
        {
            var x = N(X(s.Dato));
            sb.Append(" L ").Append(x).Append(' ').Append(N(Y(prev)));            // horisontalt
            sb.Append(" L ").Append(x).Append(' ').Append(N(Y((double)s.Rente))); // steg
            prev = (double)s.Rente;
        }
        sb.Append(" L ").Append(N(X(_xMax))).Append(' ').Append(N(Y(prev)));
        svg.Append($"<path d=\"{sb}\" fill=\"none\" stroke=\"#c2740a\" stroke-width=\"2\" stroke-linejoin=\"round\" />");

        // Kundepunkter
        foreach (var p in _punkter)
            svg.Append($"<circle cx=\"{N(X(p.Dato))}\" cy=\"{N(Y((double)p.Rente))}\" r=\"2.5\" fill=\"#1f5fc4\" fill-opacity=\"0.5\" />");

        // Trend: snitt kunderente per måned.
        var mnd = _punkter
            .GroupBy(p => new DateTime(p.Dato.Year, p.Dato.Month, 15))
            .Select(g => (Dato: g.Key, Snitt: (double)g.Average(x => x.Rente)))
            .OrderBy(x => x.Dato)
            .ToList();
        if (mnd.Count >= 2)
        {
            var tb = new StringBuilder();
            for (var i = 0; i < mnd.Count; i++)
                tb.Append(i == 0 ? "M " : " L ").Append(N(X(mnd[i].Dato))).Append(' ').Append(N(Y(mnd[i].Snitt)));
            svg.Append($"<path d=\"{tb}\" fill=\"none\" stroke=\"#266f32\" stroke-width=\"2\" stroke-linejoin=\"round\" />");
        }

        _svgInner = svg.ToString();
    }
}
