    private async Task SetPassword(UserRow u)
    {
        if (!Session.IsAdmin) return;   // server-side vern (defence-in-depth)
        var (ok, error) = await Users.SetPasswordAsync(u.Id, _pwInputs.GetValueOrDefault(u.Id, ""));
