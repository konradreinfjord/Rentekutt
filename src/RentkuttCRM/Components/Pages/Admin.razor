    // Bankpartnere lastes fra databasen (persistente).
    private List<Partner> _banks = new();

    // Ny partner
    private string _nbName = "", _nbRate = "", _nbEngangssum = "";
    private string? _nbMsg;

    private readonly HashSet<Guid> _compUnlocked = new();

    private async Task AddBank()
    {
        var (ok, error) = await Partners.AddAsync(
            _nbName,
            string.IsNullOrWhiteSpace(_nbRate) ? "0,00" : _nbRate.Trim(),
            string.IsNullOrWhiteSpace(_nbEngangssum) ? "0" : _nbEngangssum.Trim());
        if (ok)
        {
            _nbName = _nbRate = _nbEngangssum = "";
            _nbMsg = null;
            _banks = await Partners.ListAsync();
        }
        else { _nbMsg = error; }
    }

    private async Task SaveProvisjon(Partner b, ChangeEventArgs e)
    {
        b.Provisjon = e.Value?.ToString();
        await Partners.UpdateCompAsync(b.Id, b.Provisjon, b.Engangssum);
    }

    private async Task SaveEngangssum(Partner b, ChangeEventArgs e)
    {
        b.Engangssum = e.Value?.ToString();
        await Partners.UpdateCompAsync(b.Id, b.Provisjon, b.Engangssum);
    }

