        <h3 style="margin:18px 0 6px">Progressiv inntektsskatt (2024)</h3>
        <ul class="page-sub" style="margin:0; padding-left:18px; line-height:1.7">
            <li>Trygdeavgift 7,8 % av brutto</li>
            <li>Minstefradrag 46 % (maks 109 950) + personfradrag 88 250</li>
            <li>Alminnelig inntektsskatt 22 % av grunnlag</li>
            <li>Trinnskatt: 1,7 % (208 050) · 4,0 % (292 850) · 13,6 % (670 000) · 16,6 % (937 900) · 17,6 % (1 350 000+)</li>
        </ul>
    </div>
}
else if (_active == "GDPR")
{
    <div class="form-card">
        <h2>Personvern & oppbevaring</h2>
        <p class="page-sub" style="margin:0 0 16px">
            For å etterleve GDPR (dataminimering og lagringsbegrensning) behandles søknadsdata i to trinn,
