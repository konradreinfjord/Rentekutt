@page "/crm/admin"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.CustomerFieldCatalog Catalog
@inject RentkuttCRM.Services.SupabaseUserService Users
@inject RentkuttCRM.Services.WebhookService Webhooks
@inject RentkuttCRM.Services.LinkMobilityService LinkMobility
@inject RentkuttCRM.Services.SettingsService Settings
@inject RentkuttCRM.Services.EventService Events
@inject RentkuttCRM.Services.PartnerService Partners
@inject RentkuttCRM.Services.SmsMalService SmsMaler
@inject RentkuttCRM.Services.InstabankService Instabank
@inject RentkuttCRM.Services.BeregningService Beregning
@inject NavigationManager Nav

<PageTitle>Admin — Rentekutt</PageTitle>

<h1 class="page-title">Admin</h1>
<p class="page-sub">Brukere, tilgang, integrasjoner og personvern.</p>

<div class="tabs">
    @foreach (var t in _tabs)
    {
        <button class="tab @(t == _active ? "active" : "")" @onclick="() => _active = t">@t</button>
    }
</div>

@if (_active == "Generelt")
{
    <div class="section">
        <h2>SLA-frister</h2>
        <table class="data-table">
            <thead><tr><th>Hendelse</th><th>Frist</th></tr></thead>
            <tbody>
                @foreach (var s in _slas)
                {
                    <tr><td>@s.Label</td><td><input class="inline-input" value="@s.Hours" /> t</td></tr>
                }
            </tbody>
        </table>
    </div>
}
else if (_active == "Partnere")
{
    <div class="section">
        <h2>Bankpartnere & provisjonssatser <span class="pill pill-warn">@_banks.Count</span></h2>
        <table class="data-table">
            <thead><tr><th>Bank</th><th>Provisjon %</th><th>Engangssum per godkjent søknad (kr)</th><th>Postnummer-dekning</th></tr></thead>
            <tbody>
                @if (_banks.Count == 0)
                {
                    <tr><td colspan="4" class="empty-row">Ingen bankpartnere ennå — legg til under.</td></tr>
                }
                @foreach (var b in _banks)
                {
                    <tr>
                        <td>@b.Navn</td>
                        <td @ondblclick="() => _compUnlocked.Add(b.Id)">
                            @if (_compUnlocked.Contains(b.Id))
                            {
                                <input class="inline-input" value="@b.Provisjon" @onchange="e => SaveProvisjon(b, e)" /> <span>%</span>
                            }
                            else
                            {
                                <span class="locked-comp" title="Dobbeltklikk for å endre">🔒 @(string.IsNullOrWhiteSpace(b.Provisjon) ? "0" : b.Provisjon) %</span>
                            }
                        </td>
                        <td @ondblclick="() => _compUnlocked.Add(b.Id)">
                            @if (_compUnlocked.Contains(b.Id))
                            {
                                <input class="inline-input" style="width:90px" value="@b.Engangssum" @onchange="e => SaveEngangssum(b, e)" /> <span>kr</span>
                                <button class="btn-sm" @onclick="() => _compUnlocked.Remove(b.Id)">Lås</button>
                            }
                            else
                            {
                                <span class="locked-comp" title="Dobbeltklikk for å endre">🔒 @(string.IsNullOrWhiteSpace(b.Engangssum) ? "0" : b.Engangssum) kr</span>
                            }
                        </td>
                        <td>
                            <input class="inline-input" style="width:220px" value="@b.PostnummerDekning"
                                   placeholder="0001-1299, 5000, 7000-7099"
                                   title="Kommaseparerte postnummer og/eller intervaller"
                                   @onchange="e => SavePostnummerDekning(b, e)" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Ny partner</h2>
        <div class="rule-builder">
            <div class="rb-field"><label>Banknavn</label><input class="rb-input" @bind="_nbName" placeholder="f.eks. DNB" /></div>
            <div class="rb-field rb-op" style="max-width:130px"><label>Provisjon %</label><input class="rb-input" @bind="_nbRate" placeholder="1,20" /></div>
            <div class="rb-field rb-op" style="max-width:170px"><label>Engangssum (kr)</label><input class="rb-input" @bind="_nbEngangssum" placeholder="0" /></div>
            <div class="rb-field" style="max-width:260px"><label>Postnummer-dekning</label><input class="rb-input" @bind="_nbDekning" placeholder="0001-1299, 5000, 7000-7099" /></div>
            <button class="btn-primary rb-add" @onclick="AddBank">Legg til partner</button>
        </div>
        @if (!string.IsNullOrEmpty(_nbMsg))
        {
            <p class="page-sub" style="margin-top:10px">@_nbMsg</p>
        }
    </div>
}
else if (_active == "Brukere")
{
    <div class="section">
        <h2>Brukere <span class="pill pill-warn">@_userRows.Count</span></h2>
        @if (_loadingUsers)
        {
            <p class="page-sub">Laster brukere…</p>
        }
        else
        {
            <table class="data-table">
                <thead><tr><th>Navn</th><th>E-post</th><th>Mobil (2FA)</th><th>Rolle</th><th>2FA</th><th>Nytt passord</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var u in _userRows)
                    {
                        <tr>
                            <td>@(string.IsNullOrWhiteSpace(u.FullName) ? "—" : u.FullName)</td>
                            <td class="mono-cell">@u.Email</td>
                            <td>
                                <span class="token-row">
                                    <input class="inline-input" style="width:110px" placeholder="+47…"
                                           value="@MobilInput(u)" @onchange="e => SetMobilInput(u.Id, e)" />
                                    <button class="btn-sm" @onclick="() => SaveMobil(u)">Lagre</button>
                                </span>
                            </td>
                            <td>
                                <select class="inline-select" @onchange="e => ChangeRole(u, e)">
                                    @foreach (var r in SupabaseUserService.Roles)
                                    {
                                        <option value="@r" selected="@(r == u.Role)">@r</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <button class="btn-sm @(u.TwoFactorEnabled ? "" : "btn-danger")" @onclick="() => ToggleTwoFactor(u)">
                                    @(u.TwoFactorEnabled ? "På" : "Av")
                                </button>
                            </td>
                            <td>
                                <span class="token-row">
                                    <input class="inline-input" type="password" style="width:96px" placeholder="nytt"
                                           value="@PwInput(u.Id)" @onchange="e => SetPwInput(u.Id, e)" />
                                    <button class="btn-sm" @onclick="() => SetPassword(u)">Sett</button>
                                </span>
                            </td>
                            <td><span class="status @(u.Active ? "on" : "off")">@(u.Active ? "Aktiv" : "Deaktivert")</span></td>
                            <td><button class="btn-sm btn-danger" @onclick="() => ToggleActive(u)">@(u.Active ? "Deaktiver" : "Aktiver")</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (!string.IsNullOrEmpty(_pwMsg))
    {
        <p class="page-sub" style="margin:-8px 0 18px">@_pwMsg</p>
    }

    <div class="section">
        <h2>Ny bruker</h2>
        <div class="rule-builder">
            <div class="rb-field"><label>Navn</label><input class="rb-input" @bind="_nuName" placeholder="Fullt navn" /></div>
            <div class="rb-field"><label>E-post</label><input class="rb-input" @bind="_nuEmail" placeholder="navn@rentekutt.no" /></div>
            <div class="rb-field"><label>Mobilnummer (2FA)</label><input class="rb-input" @bind="_nuMobil" placeholder="+47 …" /></div>
            <div class="rb-field rb-op" style="max-width:160px">
                <label>Rolle</label>
                <select class="rb-input" @bind="_nuRole">
                    @foreach (var r in SupabaseUserService.Roles) { <option value="@r">@r</option> }
                </select>
            </div>
            <div class="rb-field"><label>Midlertidig passord</label><input class="rb-input" type="password" @bind="_nuPassword" placeholder="••••••" /></div>
            <button class="btn-primary rb-add" @onclick="CreateUser" disabled="@_creating">@(_creating ? "Oppretter…" : "Opprett bruker")</button>
        </div>
        @if (!string.IsNullOrEmpty(_userMsg))
        {
            <p class="page-sub" style="margin-top:10px">@_userMsg</p>
        }
        @if (!Users.IsConfigured)
        {
            <p class="page-sub" style="margin-top:6px; font-size:12px">⚠️ Supabase ikke koblet til — endringer er midlertidige (staging).</p>
        }
    </div>

    <div class="section">
        <h2>Roller og tilgang</h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Rettighet</th>
                    @foreach (var r in _roles) { <th>@r</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var perm in _permissions)
                {
                    <tr>
                        <td>@perm.Name</td>
                        @foreach (var allowed in perm.Access)
                        {
                            <td>@if (allowed) { <span class="check">✓</span> } else { <span class="muted">—</span> }</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Tilgang — IP-whitelist</h2>
        <p class="page-sub" style="margin:-4px 0 10px">Begrens hvilke IP-adresser brukere kan logge inn fra (komma-/linjeseparert). Tom = ingen begrensning.</p>
        <div class="rule-builder">
            <div class="rb-field" style="flex:1; min-width:260px"><label>Tillatte IP-er</label><input class="rb-input" @bind="_loginIpList" placeholder="f.eks. 84.208.0.10, 51.120.0.5" /></div>
            <button class="btn-primary rb-add" @onclick="SaveLoginIp">Lagre</button>
        </div>
        @if (!string.IsNullOrEmpty(_loginIpMsg))
        {
            <p class="page-sub" style="margin-top:10px">@_loginIpMsg</p>
        }
    </div>
}
else if (_active == "API og Data")
{
    <div class="subtabs">
        @foreach (var st in _apiTabs)
        {
            <button class="subtab @(st == _apiTab ? "active" : "")" @onclick="() => _apiTab = st">@st</button>
        }
    </div>

    @if (_apiTab == "Oversikt")
    {
        <div class="section">
            <h2>Alle tilkoblinger</h2>
            <p class="page-sub" style="margin:-4px 0 16px">Lampe = grønn hvis data siste 3 døgn, rød hvis ikke.</p>

            <h3 class="stat-subhead">Utility</h3>
            <table class="data-table" style="margin-bottom:20px">
                <thead><tr><th>Helse</th><th>Tilkobling</th><th>Type</th><th>Siste status</th></tr></thead>
                <tbody>
                    <tr>
                        <td><span class="lampe @(Users.IsConfigured ? "on" : "off")"></span></td>
                        <td>Database (Supabase)</td><td>Kjerne</td>
                        <td>@(Users.IsConfigured ? "Tilkoblet" : "Ikke tilkoblet")</td>
                    </tr>
                    <tr>
                        <td><span class="lampe @(LinkMobility.ErKonfigurert ? "on" : "off")"></span></td>
                        <td>LinkMobility</td><td>SMS / 2FA</td>
                        <td>@(LinkMobility.ErKonfigurert ? "Konfigurert" : "Ikke konfigurert")</td>
                    </tr>
                    @foreach (var w in _inboundWebhooks)
                    {
                        <tr>
                            <td><span class="lampe @(DataSiste3Dogn(w.LastReceivedAt) ? "on" : "off")"></span></td>
                            <td>@w.Name</td><td>Kanal</td>
                            <td>@(w.LastReceivedAt is { } t ? $"Sist mottatt {t.TilOslo():dd.MM HH:mm}" : "Ingen data mottatt")</td>
                        </tr>
                    }
                    @foreach (var d in _dataTjenester)
                    {
                        <tr>
                            <td><span class="lampe off"></span></td>
                            <td>@d</td><td>Datatjeneste</td>
                            <td>Ikke tilkoblet</td>
                        </tr>
                    }
                </tbody>
            </table>

            <h3 class="stat-subhead">Banker</h3>
            <table class="data-table">
                <thead><tr><th>Helse</th><th>Bank</th><th>Type</th><th>Siste status</th></tr></thead>
                <tbody>
                    @if (_banks.Count == 0)
                    {
                        <tr><td colspan="4" class="empty-row">Ingen bankpartnere ennå.</td></tr>
                    }
                    @foreach (var b in _banks)
                    {
                        <tr>
                            <td><span class="lampe off"></span></td>
                            <td>@b.Navn</td><td>Bank API</td>
                            <td>Ikke tilkoblet</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (_apiTab == "Supabase")
    {
        <div class="section">
            <div style="display:flex; justify-content:space-between; align-items:center; gap:12px">
                <h2 style="margin:0">Supabase</h2>
                <span class="status @(Users.IsConfigured ? "on" : "off")">@(Users.IsConfigured ? "Tilkoblet" : "Ikke tilkoblet")</span>
            </div>
            <p class="page-sub" style="margin:8px 0 16px">Postgres-database, autentisering og lagring for hele plattformen.</p>
            <h3 class="ww-h">Datalagring</h3>
            <ul class="bullet-list">
                <li>Region: <strong>EU (Sweden Central)</strong></li>
                <li>Database: Supabase (Postgres) med Row Level Security</li>
                <li>Backup: daglig, 30 dagers oppbevaring</li>
            </ul>
            <h3 class="ww-h">Konfigurasjon (Azure App Settings)</h3>
            <pre class="code-block">Supabase__Url             = &lt;prosjekt-URL&gt;
Supabase__Key             = &lt;service_role-nøkkel&gt;
ConnectionStrings__Postgres = &lt;session pooler-streng&gt;</pre>
            <p class="page-sub" style="margin:12px 0 0; font-size:12px">
                🔒 Nøkler leses kun fra server-config (Azure), aldri fra klienten. Migrasjoner kjøres automatisk ved oppstart.
            </p>
        </div>

        <div class="section">
            <h2>Feltoversikt & mapping — tabellen <code>kundekort</code></h2>
            <p class="page-sub" style="margin:-4px 0 6px">
                Alle felt i databasen, hva de betyr, og hva hver kanal mapper fra.
                <strong>Rentekutt.no</strong> = full lånesøknad · <strong>Prismatch</strong> = forenklede leads
                (kun kontakt + grunnleggende lånedata). «Manuell» = kan legges inn i Ny kunde-skjemaet.
                Begge kanaler treffer samme fleksible mapper; Prismatch sender bare et delsett.
            </p>
            @foreach (var g in _feltmapping)
            {
                <h3 class="stat-subhead" style="margin-top:16px">@g.Kategori</h3>
                <table class="data-table" style="margin-bottom:14px">
                    <thead><tr><th>DB-felt</th><th>Betydning</th><th>Rentekutt.no</th><th>Prismatch</th><th class="num">Manuell</th></tr></thead>
                    <tbody>
                        @foreach (var r in g.Rader)
                        {
                            <tr>
                                <td class="mono-cell">@r.DbFelt</td>
                                <td>@r.Betydning</td>
                                <td class="brk-kilde">@r.Rentekutt</td>
                                <td class="brk-kilde @(r.Prismatch == "—" ? "" : "kilde-pm")">@r.Prismatch</td>
                                <td class="num">@(r.Manuell ? "✓" : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
    else if (_apiTab == "Kanaler")
    {
        <div class="section" style="margin-bottom:14px">
            <h2>Kanaler</h2>
            <p class="page-sub" style="margin:-4px 0 0">Innkommende leadkanaler — endepunkter som mottar søknader (Rentekutt og Prismatch).</p>
        </div>
        <WebhookWidget Hook="_webhook" Url="@WebhookUrl" Name="@WebhookService.InboundName" />
        <WebhookWidget Hook="_webhookPrismatch" Url="@WebhookUrl" Name="@WebhookService.PrismatchName" />
    }
    else if (_apiTab == "Tredjeparter")
    {
        <div class="section">
            <div style="display:flex; justify-content:space-between; align-items:center; gap:12px">
                <h2 style="margin:0">Tredjeparter <span class="ww-tag">GET · status</span></h2>
                <span class="status @(_tpEnabled ? "on" : "off")">@(_tpEnabled ? "Aktiv" : "Av")</span>
            </div>
            <p class="page-sub" style="margin:8px 0 16px">
                Utgående GET-API der en tredjepart slår opp en sak på <strong>mobilnummer</strong> og får
                forenklet status tilbake — om saken er <strong>åpen</strong> eller <strong>ferdig (utbetalt/avslått)</strong>.
                Ingen sensitive detaljer eksponeres. Sikret med token (HTTPS + Bearer).
            </p>

            <label class="ff-check" style="margin-bottom:14px"><input type="checkbox" @bind="_tpEnabled" /> Aktiver tredjepart-API-et</label>

            <h3 class="ww-h">Endepunkt</h3>
            <pre class="code-block">GET @TredjepartUrl?mobil=+4791234567
Authorization: Bearer &lt;token&gt;</pre>
            <p class="page-sub" style="margin:8px 0 14px; font-size:12px">Token kan alternativt sendes som <code>?token=…</code> i URL-en.</p>

            <h3 class="ww-h">API-token</h3>
            <div class="rule-builder" style="margin-bottom:8px">
                <div class="rb-field" style="flex:1; min-width:280px">
                    <label>Token</label>
                    <input class="rb-input" style="font-family:var(--mono)" @bind="_tpToken" placeholder="Ingen token generert ennå" />
                </div>
                <button class="btn-sm rb-add" @onclick="() => _tpToken = TredjepartController.NewToken()">Generer nytt</button>
                <button class="btn-primary rb-add" @onclick="LagreTredjepart">Lagre</button>
            </div>
            @if (!string.IsNullOrEmpty(_tpMsg)) { <p class="page-sub" style="margin:0 0 12px; font-size:12px">@_tpMsg</p> }

            <h3 class="ww-h">Svar (JSON)</h3>
            <pre class="code-block">{
  "funnet": true,
  "mobil": "+4791234567",
  "status": "apen",            // apen | utbetalt | avslatt
  "status_tekst": "Åpen",
  "ferdig": false,             // true = ferdigbehandlet
  "opprettet": "2026-06-01T10:22:00Z",
  "sist_oppdatert": "2026-06-14T08:05:00Z"
}</pre>
            <h3 class="ww-h" style="margin-top:16px">Statuskart</h3>
            <table class="data-table">
                <thead><tr><th>Sakstatus i CRM</th><th>API-status</th><th>Ferdig</th></tr></thead>
                <tbody>
                    <tr><td>Fullført og utbetalt</td><td class="mono-cell">utbetalt</td><td>✓</td></tr>
                    <tr><td>Avslått</td><td class="mono-cell">avslatt</td><td>✓</td></tr>
                    <tr><td>Åpen / Pågår / Manuell / Sendt bank / Tilbud utsendt</td><td class="mono-cell">apen</td><td class="muted">—</td></tr>
                </tbody>
            </table>
        </div>
    }
    else if (_apiTab == "Bank API")
    {
        <div class="section">
            <h2>Bank API <span class="pill pill-warn">@_banks.Count</span></h2>
            <p class="page-sub" style="margin:-4px 0 14px">Bankpartnere som mottar delegerte søknader (f.eks. Instabank, Søknedal). Velg metode for datautveksling.</p>
            <table class="data-table">
                <thead><tr><th>Bank</th><th>Metode</th><th>Status</th></tr></thead>
                <tbody>
                    @if (_banks.Count == 0)
                    {
                        <tr><td colspan="3" class="empty-row">Ingen bankpartnere ennå — opprett under Partnere.</td></tr>
                    }
                    @foreach (var b in _banks)
                    {
                        <tr>
                            <td>@b.Navn</td>
                            <td><select class="inline-select" @bind="b.Method">@foreach (var m in _methods) { <option value="@m">@m</option> }</select></td>
                            <td>
                                @if (ErInstabank(b.Navn))
                                {
                                    <span class="status @(_ibKonfigurert && _ibEnabled ? "on" : "off")">@(_ibKonfigurert && _ibEnabled ? "Instabank API aktiv" : "Se Instabank-widget under")</span>
                                }
                                else
                                {
                                    <span class="status off">Ikke tilkoblet</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ---- Instabank Agent API-widget ---- *@
        <div class="section">
            <div style="display:flex; justify-content:space-between; align-items:center; gap:12px">
                <h2 style="margin:0">Instabank <span class="ww-tag">Agent API</span></h2>
                <span class="status @(_ibKonfigurert && _ibEnabled ? "on" : "off")">@(_ibKonfigurert && _ibEnabled ? "Aktiv" : "Av")</span>
            </div>
            <p class="page-sub" style="margin:8px 0 16px">
                Send delegerte lånesøknader til Instabank for kunder som skal dit. Agent API (Basic Auth) —
                kunden får en <strong>SigningUrl</strong> tilbake for å fullføre. Min. statusintervall: 5 min.
            </p>

            <div class="kv-list" style="margin-bottom:16px">
                <span class="k">Legitimasjon</span>
                <span class="v">@(_ibKonfigurert ? "Brukernavn + passord satt ✓" : "Mangler brukernavn/passord for valgt miljø")</span>
                <span class="k">Miljø</span>
                <span class="v">@(_ibMiljo == "prod" ? "Produksjon" : "Test")</span>
                <span class="k">Base-URL</span>
                <span class="v mono">@InstabankService.BaseUrl(_ibMiljo)</span>
                <span class="k">Produkter</span>
                <span class="v">Forbrukslån (151) · Kredittlinje (251) · Kredittkort (600) · Bedriftslån (2001) · Bedriftskreditt (2000)</span>
            </div>

            <h3 class="ww-h">Styring</h3>
            <div class="rule-builder" style="margin-bottom:8px; align-items:flex-end">
                <label class="ff-check" style="white-space:nowrap; margin-bottom:6px">
                    <input type="checkbox" checked="@_ibEnabled" @onchange="ToggleInstabank" /> Integrasjon aktivert
                </label>
                <div class="rb-field rb-op" style="max-width:150px">
                    <label>Miljø</label>
                    <select class="rb-input" @bind="_ibMiljo" @bind:after="LagreInstabankMiljo">
                        <option value="test">Test</option>
                        <option value="prod">Produksjon</option>
                    </select>
                </div>
                <button class="btn-primary rb-add" @onclick="TestInstabank" disabled="@_ibTester">
                    @(_ibTester ? "Tester…" : "Test tilkobling")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_ibMsg))
            {
                <p class="page-sub" style="margin:0 0 16px; font-size:12px; color:@(_ibOk ? "var(--green-dark)" : "var(--danger, #b42318)")">@_ibMsg</p>
            }

            <h3 class="ww-h">Konfigurasjon (Azure App Settings)</h3>
            <pre class="code-block">Instabank__Username      = &lt;agent-brukernavn&gt;
Instabank__PasswordTest  = &lt;passord for test (netbankpp)&gt;
Instabank__PasswordProd  = &lt;passord for prod (netbank)&gt;
Instabank__AgentEmail    = &lt;agent-e-post&gt;   (påkrevd for bedriftslån)</pre>
            <p class="page-sub" style="margin:12px 0 0; font-size:12px">
