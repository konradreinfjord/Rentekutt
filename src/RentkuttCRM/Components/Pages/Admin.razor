                <tr><td>Bilkostnad</td><td>antall_biler</td><td>antall × SIFO bildrift per husstand</td></tr>
                <tr><td>Faste bokostnader</td><td>boligkostnad_mnd, barnebidrag_betalt_mnd</td><td>trekkes direkte</td></tr>
                <tr><td>Gjeld</td><td>boliggjeld, studielaan, billaan, forbruksgjeld, refinansieres_belop, onsket_laanebelop</td><td>eksisterende − refi + ønsket</td></tr>
