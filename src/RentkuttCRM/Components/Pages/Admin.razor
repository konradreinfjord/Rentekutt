        await Settings.SetAsync("gdpr_delete_months", _gdprDeleteMonths.ToString());
        _gdprMsg = "Lagret.";
    }

    // ---- Logikk-matrise (universalfilter → ruting til bank) ----
    // Feltene leses fra CustomerFieldCatalog (én kilde til sannhet). Når ekte
    // datafelt opprettes, oppdateres katalogen og denne siden følger automatisk.
    private string[] BankNames => _banks.Select(b => b.Navn).ToArray();

    private class Rule
    {
        public int Priority { get; set; }
        public string FieldKey { get; set; } = "";
        public string Operator { get; set; } = "=";
        public string Value { get; set; } = "";
        public List<string> Banks { get; set; } = new();
        public bool Active { get; set; } = true;
    }

    private readonly List<Rule> _rules = new();

    // Builder-felt for ny regel
    private string _newFieldKey = "laanetype";
    private string _newOp = "=";
    private string _newValue = "Forbrukslån";
    private readonly HashSet<string> _newBanks = new() { "DNB" };

    private FieldDef? NewField => Catalog.Get(_newFieldKey);
    private string[] NewOperators => CustomerFieldCatalog.OperatorsFor(NewField?.Type ?? FieldType.Text);

    private string LabelFor(string key) => Catalog.Get(key)?.Label ?? key;
    private string DisplayValue(Rule r)
    {
        var unit = Catalog.Get(r.FieldKey)?.Unit;
        return string.IsNullOrEmpty(unit) ? r.Value : $"{r.Value} {unit}";
    }

    private void OnFieldChanged(ChangeEventArgs e)
    {
        _newFieldKey = e.Value?.ToString() ?? "";
        var f = NewField;
        _newOp = NewOperators.First();
        _newValue = f?.Type == FieldType.Enum && f.Options is { Length: > 0 } ? f.Options[0] : "";
    }

    private void ToggleNewBank(string bank)
    {
        if (!_newBanks.Remove(bank)) _newBanks.Add(bank);
    }

    private void AddRule()
    {
        if (string.IsNullOrWhiteSpace(_newValue) || _newBanks.Count == 0) return;
        _rules.Add(new Rule
        {
            Priority = _rules.Count == 0 ? 1 : _rules.Max(r => r.Priority) + 1,
            FieldKey = _newFieldKey,
            Operator = _newOp,
            Value = _newValue,
            Banks = _newBanks.OrderBy(b => b).ToList(),
            Active = true,
        });
    }

    private void RemoveRule(Rule r) => _rules.Remove(r);

