@code {
    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        // Kun administratorer har tilgang til admin-panelet (brukeradmin, tokens, integrasjoner).
        if (!Session.IsAdmin) { Nav.NavigateTo("/crm"); return; }
        // Hent uavhengige kilder i parallell.
        var usersTask = Users.ListUsersAsync();
        var banksTask = Partners.ListAsync();
        var webhookTask = Webhooks.GetInboundAsync();
        var webhookPrismatchTask = Webhooks.GetByNameAsync(WebhookService.PrismatchName);
        var eventsTask = Events.ListAsync(100);
        await Task.WhenAll(usersTask, banksTask, webhookTask, webhookPrismatchTask, eventsTask);
        _userRows = usersTask.Result;
        _banks = banksTask.Result;
        _webhook = webhookTask.Result;
        _webhookPrismatch = webhookPrismatchTask.Result;
        _inboundWebhooks = new[] { _webhook, _webhookPrismatch }.Where(w => w is not null).Select(w => w!).ToList();
        _events = eventsTask.Result;
        // Innstillingene deler én cachet bulk-henting (første kall laster alt).
        _smsMaxHour = await Settings.GetIntAsync(TwoFactorService.KeyMaxPerHour, TwoFactorService.DefaultMaxPerHour);
        _smsMax24h = await Settings.GetIntAsync(TwoFactorService.KeyMaxPer24h, TwoFactorService.DefaultMaxPer24h);
        _gdprAnonMonths = await Settings.GetIntAsync("gdpr_anonymize_months", 12);
        _gdprDeleteMonths = await Settings.GetIntAsync("gdpr_delete_months", 24);
        _loginIpList = await Settings.GetAsync("login_ip_allowlist") ?? "";
        _loginMaxFailHour = await Settings.GetIntAsync(SupabaseUserService.KeyMaxFailHour, SupabaseUserService.DefaultMaxFailHour);
        _loginMaxFail24h = await Settings.GetIntAsync(SupabaseUserService.KeyMaxFail24h, SupabaseUserService.DefaultMaxFail24h);
        _smsMaler = await SmsMaler.ListAsync();
        _autoEnabled = (await Settings.GetAsync(SmsMalService.KeyAutoEnabled)) == "true";
        _autoMal = await Settings.GetAsync(SmsMalService.KeyAutoMal) ?? "";
        _tpToken = await Settings.GetAsync(TredjepartController.KeyToken) ?? "";
        _tpEnabled = (await Settings.GetAsync(TredjepartController.KeyEnabled)) == "true";
        _ibEnabled = await Instabank.AktivertAsync();
        _ibMiljo = await Instabank.MiljoAsync();
        _ibKonfigurert = await Instabank.ErKonfigurertAsync();
        var bp = await Beregning.HentParametreAsync();
        _berRente = bp.Rente; _berLopetid = bp.LopetidAar;
        _berStress = bp.Stresstest; _berSifoVoksen = bp.SifoVoksen; _berSifoBarn = bp.SifoBarn;
    }

