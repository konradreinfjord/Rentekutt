                </tr>
            </thead>
            <tbody>
                <tr><td>Kvinne</td>@foreach (var v in BeregningService.SifoIndivKvinne) { <td class="num">@($"{v:N0}")</td> }</tr>
                <tr><td>Mann</td>@foreach (var v in BeregningService.SifoIndivMann) { <td class="num">@($"{v:N0}")</td> }</tr>
            </tbody>
