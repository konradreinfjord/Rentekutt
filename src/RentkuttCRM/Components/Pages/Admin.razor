    private async Task AddBank()
    {
        var (ok, error) = await Partners.AddAsync(
            _nbName,
            string.IsNullOrWhiteSpace(_nbRate) ? "0,00" : _nbRate.Trim(),
            string.IsNullOrWhiteSpace(_nbEngangssum) ? "0" : _nbEngangssum.Trim(),
            _nbDekning);
        if (ok)
        {
            _nbName = _nbRate = _nbEngangssum = _nbDekning = "";
            _nbMsg = null;
            _banks = await Partners.ListAsync();
        }
        else { _nbMsg = error; }
    }

