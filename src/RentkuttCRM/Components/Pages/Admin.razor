    private class BankRate { public string Name { get; set; } = ""; public string Rate { get; set; } = ""; public string Method { get; set; } = "Webhook"; }
    private readonly List<BankRate> _banks = new();

    // Ny partner (kan legges til, ikke fjernes)
    private string _nbName = "", _nbRate = "";

    private void AddBank()
    {
        var name = _nbName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        if (_banks.Any(b => b.Name.Equals(name, StringComparison.OrdinalIgnoreCase))) return;
        // Oppretter også en API-rad (under "API og Data") for denne partneren.
        _banks.Add(new BankRate { Name = name, Rate = string.IsNullOrWhiteSpace(_nbRate) ? "0,00" : _nbRate.Trim() });
        _nbName = "";
        _nbRate = "";
    }

    private class Source { public string Name { get; set; } = ""; public bool Active { get; set; } = true; public string Method { get; set; } = "Webhook"; }
    private readonly List<Source> _sources = new();

    // Ny leadkilde (oppretter også en API-rad)
    private string _nsName = "";

    private void AddSource()
    {
        var name = _nsName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        if (_sources.Any(s => s.Name.Equals(name, StringComparison.OrdinalIgnoreCase))) return;
        _sources.Add(new Source { Name = name, Active = true });
        _nsName = "";
    }

