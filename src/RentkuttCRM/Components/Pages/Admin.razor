    private async Task SaveLoginLimits()
    {
        if (_loginMaxFailHour < 1) _loginMaxFailHour = 1;
        if (_loginMaxFail24h < 1) _loginMaxFail24h = 1;
        await Settings.SetAsync(SupabaseUserService.KeyMaxFailHour, _loginMaxFailHour.ToString());
