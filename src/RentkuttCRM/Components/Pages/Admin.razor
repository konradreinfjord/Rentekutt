    private async Task LoadUsersAsync()
    {
        _loadingUsers = true;
        _userRows = await Users.ListUsersAsync();
        _loadingUsers = false;
    }

    private async Task ChangeRole(UserRow u, ChangeEventArgs e)
    {
        if (!Session.IsAdmin) return;   // server-side vern (defence-in-depth)
        var role = e.Value?.ToString() ?? u.Role;
        await Users.SetRoleAsync(u.Id, role);
        await LoadUsersAsync();
    }

    private async Task ToggleActive(UserRow u)
    {
        await Users.SetActiveAsync(u.Id, !u.Active);
        await LoadUsersAsync();
    }

    private async Task ToggleTwoFactor(UserRow u)
    {
        await Users.SetTwoFactorAsync(u.Id, !u.TwoFactorEnabled);
        await LoadUsersAsync();
    }

    private readonly Dictionary<Guid, string> _mobilInputs = new();
    private string MobilInput(UserRow u) => _mobilInputs.TryGetValue(u.Id, out var v) ? v : (u.Mobilnummer ?? "");
    private void SetMobilInput(Guid id, ChangeEventArgs e) => _mobilInputs[id] = e.Value?.ToString() ?? "";
    private async Task SaveMobil(UserRow u)
    {
        await Users.SetMobilAsync(u.Id, _mobilInputs.GetValueOrDefault(u.Id, u.Mobilnummer ?? ""));
        _mobilInputs.Remove(u.Id);
        _pwMsg = $"Mobilnummer oppdatert for {u.Email}.";
        await LoadUsersAsync();
    }

    private async Task CreateUser()
    {
        if (!Session.IsAdmin) return;   // server-side vern (defence-in-depth)
        _creating = true;
        _userMsg = null;
        var (ok, error) = await Users.CreateUserAsync(_nuEmail, _nuName, _nuRole, _nuPassword, _nuMobil);
        if (ok)
        {
            await Events.LogAsync("Bruker", $"Ny bruker opprettet (rolle: {_nuRole})", "Admin");
            _userMsg = $"Bruker {_nuEmail} opprettet.";
            _nuName = _nuEmail = _nuPassword = _nuMobil = "";
            _nuRole = "Saksbehandler";
            await LoadUsersAsync();
            _events = await Events.ListAsync(100);
        }
        else
        {
            _userMsg = error ?? "Kunne ikke opprette bruker.";
        }
        _creating = false;
    }

