@page "/crm/admin"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.CustomerFieldCatalog Catalog
@inject RentkuttCRM.Services.SupabaseUserService Users
@inject RentkuttCRM.Services.WebhookService Webhooks
@inject RentkuttCRM.Services.LinkMobilityService LinkMobility
@inject RentkuttCRM.Services.SettingsService Settings
@inject RentkuttCRM.Services.EventService Events
@inject RentkuttCRM.Services.PartnerService Partners
@inject RentkuttCRM.Services.BeregningService Beregning
@inject NavigationManager Nav

<PageTitle>Admin — Rentekutt</PageTitle>

<h1 class="page-title">Admin</h1>
<p class="page-sub">Brukere, tilgang, integrasjoner og personvern.</p>

<div class="tabs">
    @foreach (var t in _tabs)
    {
        <button class="tab @(t == _active ? "active" : "")" @onclick="() => _active = t">@t</button>
    }
</div>

@if (_active == "Status")
{
    <div class="section">
        <h2>Tilkoblinger</h2>
        <p class="page-sub" style="margin:-4px 0 16px">Live oversikt over systemer og sist mottatte data. Grønn = OK / nylig data, rød = ikke tilkoblet / ingen data.</p>
        <div class="summary-grid">
            <div class="summary-card">
                <div class="sc-head"><span class="sc-dot @(Users.IsConfigured ? "ok" : "bad")"></span> Database (Supabase)</div>
                <div class="sc-status">@(Users.IsConfigured ? "Tilkoblet" : "Ikke tilkoblet")</div>
                <div class="summary-sub">Postgres · EU (Sweden)</div>
            </div>
            <div class="summary-card">
                <div class="sc-head"><span class="sc-dot @(LinkMobility.ErKonfigurert ? "ok" : "bad")"></span> SMS (LinkMobility)</div>
                <div class="sc-status">@(LinkMobility.ErKonfigurert ? "Konfigurert" : "Ikke konfigurert")</div>
                <div class="summary-sub">2FA-koder</div>
            </div>
            @foreach (var w in _inboundWebhooks)
            {
                <div class="summary-card">
                    <div class="sc-head"><span class="sc-dot @(WebhookFresh(w) ? "ok" : "bad")"></span> @w.Name</div>
                    <div class="sc-status">@(w.LastReceivedAt is { } t ? $"Sist mottatt {t.ToLocalTime():dd.MM HH:mm}" : "Ingen data mottatt")</div>
                    <div class="summary-sub">@(w.LastReceivedInfo ?? "Inbound endepunkt")</div>
                </div>
            }
        </div>
    </div>
}
else if (_active == "Generelt")
{
    <div class="section">
        <h2>SLA-frister</h2>
        <table class="data-table">
            <thead><tr><th>Hendelse</th><th>Frist</th></tr></thead>
            <tbody>
                @foreach (var s in _slas)
                {
                    <tr><td>@s.Label</td><td><input class="inline-input" value="@s.Hours" /> t</td></tr>
                }
            </tbody>
        </table>
    </div>
}
else if (_active == "Partnere")
{
    <div class="section">
        <h2>Bankpartnere & provisjonssatser <span class="pill pill-warn">@_banks.Count</span></h2>
        <table class="data-table">
            <thead><tr><th>Bank</th><th>Provisjon %</th><th>Engangssum per godkjent søknad (kr)</th></tr></thead>
            <tbody>
                @if (_banks.Count == 0)
                {
                    <tr><td colspan="3" class="empty-row">Ingen bankpartnere ennå — legg til under.</td></tr>
                }
                @foreach (var b in _banks)
                {
                    <tr>
                        <td>@b.Navn</td>
                        <td @ondblclick="() => _compUnlocked.Add(b.Id)">
                            @if (_compUnlocked.Contains(b.Id))
                            {
                                <input class="inline-input" value="@b.Provisjon" @onchange="e => SaveProvisjon(b, e)" /> <span>%</span>
                            }
                            else
                            {
                                <span class="locked-comp" title="Dobbeltklikk for å endre">🔒 @(string.IsNullOrWhiteSpace(b.Provisjon) ? "0" : b.Provisjon) %</span>
                            }
                        </td>
                        <td @ondblclick="() => _compUnlocked.Add(b.Id)">
                            @if (_compUnlocked.Contains(b.Id))
                            {
                                <input class="inline-input" style="width:90px" value="@b.Engangssum" @onchange="e => SaveEngangssum(b, e)" /> <span>kr</span>
                                <button class="btn-sm" @onclick="() => _compUnlocked.Remove(b.Id)">Lås</button>
                            }
                            else
                            {
                                <span class="locked-comp" title="Dobbeltklikk for å endre">🔒 @(string.IsNullOrWhiteSpace(b.Engangssum) ? "0" : b.Engangssum) kr</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Ny partner</h2>
        <div class="rule-builder">
            <div class="rb-field"><label>Banknavn</label><input class="rb-input" @bind="_nbName" placeholder="f.eks. DNB" /></div>
            <div class="rb-field rb-op" style="max-width:130px"><label>Provisjon %</label><input class="rb-input" @bind="_nbRate" placeholder="1,20" /></div>
            <div class="rb-field rb-op" style="max-width:170px"><label>Engangssum (kr)</label><input class="rb-input" @bind="_nbEngangssum" placeholder="0" /></div>
            <button class="btn-primary rb-add" @onclick="AddBank">Legg til partner</button>
        </div>
        @if (!string.IsNullOrEmpty(_nbMsg))
        {
            <p class="page-sub" style="margin-top:10px">@_nbMsg</p>
        }
    </div>
}
else if (_active == "Brukere")
{
    <div class="section">
        <h2>Brukere <span class="pill pill-warn">@_userRows.Count</span></h2>
        @if (_loadingUsers)
        {
            <p class="page-sub">Laster brukere…</p>
        }
        else
        {
            <table class="data-table">
                <thead><tr><th>Navn</th><th>E-post</th><th>Mobil (2FA)</th><th>Rolle</th><th>2FA</th><th>Nytt passord</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var u in _userRows)
                    {
                        <tr>
                            <td>@(string.IsNullOrWhiteSpace(u.FullName) ? "—" : u.FullName)</td>
                            <td class="mono-cell">@u.Email</td>
                            <td>
                                <span class="token-row">
                                    <input class="inline-input" style="width:110px" placeholder="+47…"
                                           value="@MobilInput(u)" @onchange="e => SetMobilInput(u.Id, e)" />
                                    <button class="btn-sm" @onclick="() => SaveMobil(u)">Lagre</button>
                                </span>
                            </td>
                            <td>
                                <select class="inline-select" @onchange="e => ChangeRole(u, e)">
                                    @foreach (var r in SupabaseUserService.Roles)
                                    {
                                        <option value="@r" selected="@(r == u.Role)">@r</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <button class="btn-sm @(u.TwoFactorEnabled ? "" : "btn-danger")" @onclick="() => ToggleTwoFactor(u)">
                                    @(u.TwoFactorEnabled ? "På" : "Av")
                                </button>
                            </td>
                            <td>
                                <span class="token-row">
                                    <input class="inline-input" type="password" style="width:96px" placeholder="nytt"
                                           value="@PwInput(u.Id)" @onchange="e => SetPwInput(u.Id, e)" />
                                    <button class="btn-sm" @onclick="() => SetPassword(u)">Sett</button>
                                </span>
                            </td>
                            <td><span class="status @(u.Active ? "on" : "off")">@(u.Active ? "Aktiv" : "Deaktivert")</span></td>
                            <td><button class="btn-sm btn-danger" @onclick="() => ToggleActive(u)">@(u.Active ? "Deaktiver" : "Aktiver")</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (!string.IsNullOrEmpty(_pwMsg))
    {
        <p class="page-sub" style="margin:-8px 0 18px">@_pwMsg</p>
    }

    <div class="section">
        <h2>Ny bruker</h2>
        <div class="rule-builder">
            <div class="rb-field"><label>Navn</label><input class="rb-input" @bind="_nuName" placeholder="Fullt navn" /></div>
            <div class="rb-field"><label>E-post</label><input class="rb-input" @bind="_nuEmail" placeholder="navn@rentekutt.no" /></div>
            <div class="rb-field"><label>Mobilnummer (2FA)</label><input class="rb-input" @bind="_nuMobil" placeholder="+47 …" /></div>
            <div class="rb-field rb-op" style="max-width:160px">
                <label>Rolle</label>
                <select class="rb-input" @bind="_nuRole">
                    @foreach (var r in SupabaseUserService.Roles) { <option value="@r">@r</option> }
                </select>
            </div>
            <div class="rb-field"><label>Midlertidig passord</label><input class="rb-input" type="password" @bind="_nuPassword" placeholder="••••••" /></div>
            <button class="btn-primary rb-add" @onclick="CreateUser" disabled="@_creating">@(_creating ? "Oppretter…" : "Opprett bruker")</button>
        </div>
        @if (!string.IsNullOrEmpty(_userMsg))
        {
            <p class="page-sub" style="margin-top:10px">@_userMsg</p>
        }
        @if (!Users.IsConfigured)
        {
            <p class="page-sub" style="margin-top:6px; font-size:12px">⚠️ Supabase ikke koblet til — endringer er midlertidige (staging).</p>
        }
    </div>

    <div class="section">
        <h2>Roller og tilgang</h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Rettighet</th>
                    @foreach (var r in _roles) { <th>@r</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var perm in _permissions)
                {
                    <tr>
                        <td>@perm.Name</td>
                        @foreach (var allowed in perm.Access)
                        {
                            <td>@if (allowed) { <span class="check">✓</span> } else { <span class="muted">—</span> }</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Tilgang — IP-whitelist</h2>
        <p class="page-sub" style="margin:-4px 0 10px">Begrens hvilke IP-adresser brukere kan logge inn fra (komma-/linjeseparert). Tom = ingen begrensning.</p>
        <div class="rule-builder">
            <div class="rb-field" style="flex:1; min-width:260px"><label>Tillatte IP-er</label><input class="rb-input" @bind="_loginIpList" placeholder="f.eks. 84.208.0.10, 51.120.0.5" /></div>
            <button class="btn-primary rb-add" @onclick="SaveLoginIp">Lagre</button>
        </div>
        @if (!string.IsNullOrEmpty(_loginIpMsg))
        {
            <p class="page-sub" style="margin-top:10px">@_loginIpMsg</p>
        }
    </div>
}
else if (_active == "API og Data")
{
    <div class="subtabs">
        @foreach (var st in _apiTabs)
        {
            <button class="subtab @(st == _apiTab ? "active" : "")" @onclick="() => _apiTab = st">@st</button>
        }
    </div>

    @if (_apiTab == "Oversikt")
    {
        <div class="section">
            <h2>Alle tilkoblinger</h2>
            <p class="page-sub" style="margin:-4px 0 14px">Helse og siste status per integrasjon — én linje hver.</p>
            <table class="data-table">
                <thead><tr><th>Helse</th><th>Tilkobling</th><th>Type</th><th>Siste status</th></tr></thead>
                <tbody>
                    <tr>
                        <td><span class="sc-dot @(Users.IsConfigured ? "ok" : "bad")"></span></td>
                        <td>Database (Supabase)</td><td>Kjerne</td>
                        <td>@(Users.IsConfigured ? "Tilkoblet" : "Ikke tilkoblet")</td>
                    </tr>
                    <tr>
                        <td><span class="sc-dot @(LinkMobility.ErKonfigurert ? "ok" : "bad")"></span></td>
                        <td>LinkMobility</td><td>SMS / 2FA</td>
                        <td>@(LinkMobility.ErKonfigurert ? "Konfigurert" : "Ikke konfigurert")</td>
                    </tr>
                    @foreach (var w in _inboundWebhooks)
                    {
                        <tr>
                            <td><span class="sc-dot @(WebhookFresh(w) ? "ok" : "bad")"></span></td>
                            <td>@w.Name</td><td>Kanal</td>
                            <td>@(w.LastReceivedAt is { } t ? $"Sist mottatt {t.ToLocalTime():dd.MM HH:mm}" : "Ingen data mottatt")</td>
                        </tr>
                    }
                    @foreach (var b in _banks)
                    {
                        <tr>
                            <td><span class="sc-dot bad"></span></td>
                            <td>@b.Navn</td><td>Bank API</td>
                            <td>Ikke tilkoblet</td>
                        </tr>
                    }
                    @foreach (var d in _dataTjenester)
                    {
                        <tr>
                            <td><span class="sc-dot bad"></span></td>
                            <td>@d</td><td>Datatjeneste</td>
                            <td>Ikke tilkoblet</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="section">
            <h2>Datalagring</h2>
            <ul class="bullet-list">
                <li>Region: <strong>EU (Sweden Central)</strong></li>
                <li>Database: Supabase (Postgres)</li>
                <li>Backup: daglig, 30 dagers oppbevaring</li>
            </ul>
        </div>
    }
    else if (_apiTab == "Kanaler")
    {
        <div class="section" style="margin-bottom:14px">
            <h2>Kanaler</h2>
            <p class="page-sub" style="margin:-4px 0 0">Innkommende leadkanaler — endepunkter som mottar søknader (Rentekutt og Prismatch).</p>
        </div>
        <WebhookWidget Hook="_webhook" Url="@WebhookUrl" Name="@WebhookService.InboundName" />
        <WebhookWidget Hook="_webhookPrismatch" Url="@WebhookUrl" Name="@WebhookService.PrismatchName" />
    }
    else if (_apiTab == "Bank API")
    {
        <div class="section">
            <h2>Bank API <span class="pill pill-warn">@_banks.Count</span></h2>
            <p class="page-sub" style="margin:-4px 0 14px">Bankpartnere som mottar delegerte søknader (f.eks. Instabank, Søknedal). Velg metode for datautveksling.</p>
            <table class="data-table">
                <thead><tr><th>Bank</th><th>Metode</th><th>Status</th></tr></thead>
                <tbody>
                    @if (_banks.Count == 0)
                    {
                        <tr><td colspan="3" class="empty-row">Ingen bankpartnere ennå — opprett under Partnere.</td></tr>
                    }
                    @foreach (var b in _banks)
                    {
                        <tr>
                            <td>@b.Navn</td>
                            <td><select class="inline-select" @bind="b.Method">@foreach (var m in _methods) { <option value="@m">@m</option> }</select></td>
                            <td><span class="status off">Ikke tilkoblet</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (_apiTab == "LinkMobility")
    {
        <div class="section">
            <div style="display:flex; justify-content:space-between; align-items:center; gap:12px">
                <h2 style="margin:0">LinkMobility <span class="ww-tag">SMS · 2FA</span></h2>
                <span class="status @(LinkMobility.ErKonfigurert ? "on" : "off")">@(LinkMobility.ErKonfigurert ? "Aktiv" : "Av")</span>
            </div>
            <p class="page-sub" style="margin:8px 0 16px">
                MyLink SMS API (OAuth2 client credentials) — sender engangskoder for 2FA ved innlogging.
            </p>
            <div class="kv-list" style="margin-bottom:16px">
                <span class="k">Status</span>
                <span class="v">@(LinkMobility.ErKonfigurert ? "Client ID + secret satt ✓" : "Mangler Client ID/secret")</span>
                <span class="k">Avsender</span><span class="v">@LinkMobility.Sender</span>
                <span class="k">Token-URL</span><span class="v">@LinkMobility.TokenUrl</span>
                <span class="k">Send-URL</span><span class="v">@LinkMobility.SendUrl</span>
            </div>
            <h3 class="ww-h">SMS-rategrense (per bruker)</h3>
            <p class="page-sub" style="margin:0 0 8px; font-size:12px">Sikring mot misbruk og kostnad: maks antall innloggingskoder per bruker.</p>
            <div class="rule-builder" style="margin-bottom:8px">
                <div class="rb-field rb-op" style="max-width:130px"><label>Maks per time</label><input class="rb-input" type="number" min="1" @bind="_smsMaxHour" /></div>
                <div class="rb-field rb-op" style="max-width:130px"><label>Maks per 24t</label><input class="rb-input" type="number" min="1" @bind="_smsMax24h" /></div>
                <button class="btn-primary rb-add" @onclick="SaveSmsLimits">Lagre</button>
            </div>
            @if (!string.IsNullOrEmpty(_smsMsg))
            {
                <p class="page-sub" style="margin:0 0 16px; font-size:12px">@_smsMsg</p>
            }
            <h3 class="ww-h">Konfigurasjon (Azure App Settings)</h3>
            <pre class="code-block">LinkMobility__ClientId      = &lt;klient-ID&gt;
LinkMobility__ClientSecret  = &lt;klient-hemmelighet&gt;
LinkMobility__Sender        = Rentekutt        (valgfri)
LinkMobility__TokenUrl      = &lt;overstyrbar&gt;     (valgfri)
LinkMobility__SendUrl       = &lt;overstyrbar&gt;     (valgfri)</pre>
            <p class="page-sub" style="margin:12px 0 0; font-size:12px">
                🔒 Client ID/secret leses kun fra server-config (Azure), aldri fra databasen. 2FA aktiveres per bruker under Brukere.
            </p>
        </div>
    }
    else if (_apiTab == "Bank ID")
    {
        @IntegrasjonsKort(
            "BankID",
            "Elektronisk legitimering og signering av søkere via BankID (gjennom broker som Signicat eller Vipps MobilePay).",
            new[] { "Verifiser søkers identitet ved oppstart av sak", "Digital signering av lånedokumenter", "Sikker innlogging for kunder" },
            "BankID__ClientId      = <klient-ID>\nBankID__ClientSecret  = <hemmelighet>\nBankID__Environment   = prod | test")
    }
    else if (_apiTab == "Gjeldsregisteret")
    {
        @IntegrasjonsKort(
            "Gjeldsregisteret",
            "Sanntidsoppslag mot Gjeldsregisteret for søkers usikrede gjeld (forbrukslån, kredittkort) — brukes i finansieringsevne-beregningen.",
            new[] { "Hent samlet usikret gjeld per person", "Automatisk utfylling av gjeld i kundekort", "Oppdatert gjeldsgrad i beregningsmodellen" },
            "Gjeldsregisteret__ClientId      = <klient-ID>\nGjeldsregisteret__ClientSecret  = <hemmelighet>\nGjeldsregisteret__ApiUrl        = <endepunkt>")
    }
    else if (_apiTab == "Eiendomsverdi")
    {
        @IntegrasjonsKort(
            "Eiendomsverdi",
            "Automatisk verdivurdering av bolig (AVM) via Eiendomsverdi AS — gir boligverdi til belåningsgrad-beregningen.",
            new[] { "Estimert markedsverdi per adresse/matrikkel", "Automatisk boligverdi i kundekort", "Oppdatert belåningsgrad (LTV)" },
            "Eiendomsverdi__ClientId      = <klient-ID>\nEiendomsverdi__ClientSecret  = <hemmelighet>\nEiendomsverdi__ApiUrl        = <endepunkt>")
    }
    else if (_apiTab == "Kredittsjekk")
    {
        @IntegrasjonsKort(
            "Kredittsjekk",
            "Kredittvurdering av søker via kredittopplysningsbyrå (f.eks. Bisnode/Dun & Bradstreet eller Experian) — score, betalingsanmerkninger og inntektsdata.",
            new[] { "Kredittscore og risikoklasse", "Betalingsanmerkninger og inkasso", "Bekreftet inntekt (skattedata)" },
            "Kredittsjekk__ClientId      = <klient-ID>\nKredittsjekk__ClientSecret  = <hemmelighet>\nKredittsjekk__ApiUrl        = <endepunkt>")
    }
}
else if (_active == "Hendelseslogg")
{
    <div class="section">
        <h2>Hendelseslogg <span class="pill pill-warn">@_events.Count</span></h2>
        <p class="page-sub" style="margin:-4px 0 14px">Systemhendelser (siste 100). Ingen personopplysninger logges.</p>
        <table class="data-table">
            <thead><tr><th>Tidspunkt</th><th>Type</th><th>Beskrivelse</th><th>Kilde</th></tr></thead>
            <tbody>
                @if (_events.Count == 0)
                {
                    <tr><td colspan="4" class="empty-row">Ingen hendelser ennå.</td></tr>
                }
                @foreach (var e in _events)
                {
                    <tr>
                        <td class="mono-cell">@e.Tidspunkt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td><span class="type-tag">@e.Type</span></td>
                        <td>@e.Beskrivelse</td>
                        <td class="muted">@e.Kilde</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (_active == "Logikk-matrise")
{
    <div class="section">
        <h2>Rutingsregler <span class="pill pill-warn">@_rules.Count(r => r.Active) aktive</span></h2>
        <p class="page-sub" style="margin:-4px 0 14px">
            Universalfilter: segmentér søknader til bank basert på alle kundedata vi har
            (@Catalog.Fields.Count felter — geografi, lån, økonomi, personalia, PSD2).
            Reglene vurderes ovenfra og ned — første treff bestemmer hvilke banker søknaden sendes til.
        </p>
        <table class="data-table">
            <thead>
                <tr><th>#</th><th>Parameter</th><th>Operator</th><th>Verdi</th><th>Send til</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @if (_rules.Count == 0)
                {
                    <tr><td colspan="7" class="empty-row">Ingen rutingsregler ennå — legg til under.</td></tr>
                }
                @foreach (var r in _rules.OrderBy(r => r.Priority))
                {
                    <tr>
                        <td class="mono-cell">@r.Priority</td>
                        <td>@LabelFor(r.FieldKey)</td>
                        <td class="mono-cell">@r.Operator</td>
                        <td>@DisplayValue(r)</td>
                        <td>
                            <div class="route-banks">
                                @foreach (var bank in r.Banks)
                                {
                                    <span class="route-bank">@bank</span>
                                }
                            </div>
                        </td>
                        <td>
                            <label class="toggle">
                                <input type="checkbox" checked="@r.Active" @onchange="e => r.Active = (bool)e.Value!" />
                                <span class="status @(r.Active ? "on" : "off")">@(r.Active ? "Aktiv" : "Av")</span>
                            </label>
                        </td>
                        <td><button class="btn-sm btn-danger" @onclick="() => RemoveRule(r)">Slett</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Ny regel</h2>
        <div class="rule-builder">
            <div class="rb-field">
                <label>Felt (kundedata)</label>
                <select class="rb-input" value="@_newFieldKey" @onchange="OnFieldChanged">
                    @foreach (var cat in Catalog.Categories)
                    {
                        <optgroup label="@cat">
                            @foreach (var f in Catalog.InCategory(cat))
                            {
                                <option value="@f.Key">@f.Label</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>
            <div class="rb-field rb-op">
                <label>Operator</label>
