    // ---- Brukeradministrasjon ----
    private List<UserRow> _userRows = new();
    private bool _loadingUsers = true;
    private string _nuName = "", _nuEmail = "", _nuRole = "Saksbehandler", _nuPassword = "", _nuMobil = "";
    private bool _creating;
    private string? _userMsg;

    // Endre passord (per bruker-rad)
    private readonly Dictionary<Guid, string> _pwInputs = new();
    private string? _pwMsg;
    private string PwInput(Guid id) => _pwInputs.GetValueOrDefault(id, "");
    private void SetPwInput(Guid id, ChangeEventArgs e) => _pwInputs[id] = e.Value?.ToString() ?? "";

    private async Task SetPassword(UserRow u)
    {
        var (ok, error) = await Users.SetPasswordAsync(u.Id, _pwInputs.GetValueOrDefault(u.Id, ""));
        _pwMsg = ok ? $"Passord oppdatert for {u.Email}." : (error ?? "Kunne ikke endre passord.");
        if (ok) _pwInputs[u.Id] = "";
    }

    private async Task LoadUsersAsync()
    {
        _loadingUsers = true;
        _userRows = await Users.ListUsersAsync();
        _loadingUsers = false;
    }

    private async Task ChangeRole(UserRow u, ChangeEventArgs e)
    {
        var role = e.Value?.ToString() ?? u.Role;
        await Users.SetRoleAsync(u.Id, role);
        await LoadUsersAsync();
    }

    private async Task ToggleActive(UserRow u)
    {
        await Users.SetActiveAsync(u.Id, !u.Active);
        await LoadUsersAsync();
    }

    private async Task ToggleTwoFactor(UserRow u)
    {
        await Users.SetTwoFactorAsync(u.Id, !u.TwoFactorEnabled);
        await LoadUsersAsync();
    }

    private async Task CreateUser()
    {
        _creating = true;
        _userMsg = null;
        var (ok, error) = await Users.CreateUserAsync(_nuEmail, _nuName, _nuRole, _nuPassword, _nuMobil);
        if (ok)
        {
            _userMsg = $"Bruker {_nuEmail} opprettet.";
            _nuName = _nuEmail = _nuPassword = _nuMobil = "";
            _nuRole = "Saksbehandler";
            await LoadUsersAsync();
        }
        else
        {
            _userMsg = error ?? "Kunne ikke opprette bruker.";
        }
        _creating = false;
    }

    private readonly string[] _tabs = { "Generelt", "Partnere", "Leadkilder", "Brukere", "Logikk-matrise", "API og Data", "GDPR" };
    private string _active = "Generelt";

    // ---- GDPR: anonymisering + sletting ----
    private int _gdprAnonMonths = 12;
    private int _gdprDeleteMonths = 24;
    private string? _gdprMsg;
    private async Task SaveGdpr()
    {
        if (_gdprAnonMonths < 1) _gdprAnonMonths = 1;
        if (_gdprDeleteMonths < 1) _gdprDeleteMonths = 1;
        await Settings.SetAsync("gdpr_anonymize_months", _gdprAnonMonths.ToString());
        await Settings.SetAsync("gdpr_delete_months", _gdprDeleteMonths.ToString());
        _gdprMsg = "Lagret.";
    }

    // ---- Logikk-matrise (universalfilter → ruting til bank) ----
    // Feltene leses fra CustomerFieldCatalog (én kilde til sannhet). Når ekte
    // datafelt opprettes, oppdateres katalogen og denne siden følger automatisk.
    private string[] BankNames => _banks.Select(b => b.Name).ToArray();

    private class Rule
    {
        public int Priority { get; set; }
        public string FieldKey { get; set; } = "";
        public string Operator { get; set; } = "=";
        public string Value { get; set; } = "";
        public List<string> Banks { get; set; } = new();
        public bool Active { get; set; } = true;
    }

    private readonly List<Rule> _rules = new();

    // Builder-felt for ny regel
    private string _newFieldKey = "laanetype";
    private string _newOp = "=";
    private string _newValue = "Forbrukslån";
    private readonly HashSet<string> _newBanks = new() { "DNB" };

    private FieldDef? NewField => Catalog.Get(_newFieldKey);
    private string[] NewOperators => CustomerFieldCatalog.OperatorsFor(NewField?.Type ?? FieldType.Text);

    private string LabelFor(string key) => Catalog.Get(key)?.Label ?? key;
    private string DisplayValue(Rule r)
    {
        var unit = Catalog.Get(r.FieldKey)?.Unit;
        return string.IsNullOrEmpty(unit) ? r.Value : $"{r.Value} {unit}";
    }

    private void OnFieldChanged(ChangeEventArgs e)
    {
        _newFieldKey = e.Value?.ToString() ?? "";
        var f = NewField;
        _newOp = NewOperators.First();
        _newValue = f?.Type == FieldType.Enum && f.Options is { Length: > 0 } ? f.Options[0] : "";
    }

    private void ToggleNewBank(string bank)
    {
        if (!_newBanks.Remove(bank)) _newBanks.Add(bank);
    }

    private void AddRule()
    {
        if (string.IsNullOrWhiteSpace(_newValue) || _newBanks.Count == 0) return;
        _rules.Add(new Rule
        {
            Priority = _rules.Count == 0 ? 1 : _rules.Max(r => r.Priority) + 1,
            FieldKey = _newFieldKey,
            Operator = _newOp,
            Value = _newValue,
            Banks = _newBanks.OrderBy(b => b).ToList(),
            Active = true,
        });
    }

    private void RemoveRule(Rule r) => _rules.Remove(r);

    private readonly string[] _roles = { "Saksbeh.", "Compliance", "Leder", "Admin" };

    private record Perm(string Name, bool[] Access);
    private readonly Perm[] _permissions =
    {
        new("Lese saker",        new[]{ true,  true,  true,  true }),
        new("Redigere saker",    new[]{ true,  false, true,  true }),
        new("Kvalifisere",       new[]{ true,  false, true,  true }),
        new("Sende lead",        new[]{ true,  false, true,  true }),
        new("Kundedata",         new[]{ true,  true,  true,  true }),
        new("GDPR-sletting",     new[]{ false, true,  false, true }),
        new("Se provisjon",      new[]{ false, false, true,  true }),
        new("Revisjonslogg",     new[]{ false, true,  true,  true }),
        new("Brukeradmin",       new[]{ false, false, false, true }),
    };

    private class BankRate { public string Name { get; set; } = ""; public string Rate { get; set; } = ""; public string Method { get; set; } = "Webhook"; }
    private readonly List<BankRate> _banks = new();

    // Ny partner (kan legges til, ikke fjernes)
    private string _nbName = "", _nbRate = "";

    private void AddBank()
    {
        var name = _nbName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        if (_banks.Any(b => b.Name.Equals(name, StringComparison.OrdinalIgnoreCase))) return;
        // Oppretter også en API-rad (under "API og Data") for denne partneren.
        _banks.Add(new BankRate { Name = name, Rate = string.IsNullOrWhiteSpace(_nbRate) ? "0,00" : _nbRate.Trim() });
        _nbName = "";
        _nbRate = "";
    }

    private class Source { public string Name { get; set; } = ""; public bool Active { get; set; } = true; public string Method { get; set; } = "Webhook"; }
    private readonly List<Source> _sources = new();

    // Ny leadkilde (oppretter også en API-rad)
    private string _nsName = "";

    private void AddSource()
    {
        var name = _nsName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        if (_sources.Any(s => s.Name.Equals(name, StringComparison.OrdinalIgnoreCase))) return;
        _sources.Add(new Source { Name = name, Active = true });
        _nsName = "";
    }

    private record Sla(string Label, string Hours);
    private readonly Sla[] _slas =
    {
        new("Ring kunde etter lead", "2"),
        new("Følg opp samtykke", "24"),
        new("Vurdering ferdig", "48"),
        new("Følg opp bank", "72"),
        new("Følg opp tilbud", "24"),
    };

    // Manuelle integrasjoner (i tillegg til de som auto-opprettes fra banker/leadkilder)
    private class Integration { public string Name { get; set; } = ""; public string Method { get; set; } = "Webhook"; }
    private readonly List<Integration> _integrations = new();

    private static readonly string[] _methods = { "Webhook", "API (REST)", "Manuell", "FTP/SFTP", "E-post" };

    private string _niName = "", _niMethod = "Webhook";

    private void AddIntegration()
    {
        var name = _niName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        _integrations.Add(new Integration { Name = name, Method = _niMethod });
        _niName = "";
        _niMethod = "Webhook";
