            <p class="page-sub" style="margin-top:10px">@_loginLimitMsg</p>
        }
    </div>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        // Hent uavhengige kilder i parallell.
        var usersTask = Users.ListUsersAsync();
        var banksTask = Partners.ListAsync();
        var webhookTask = Webhooks.GetInboundAsync();
        var webhookPrismatchTask = Webhooks.GetByNameAsync(WebhookService.PrismatchName);
        var eventsTask = Events.ListAsync(100);
        await Task.WhenAll(usersTask, banksTask, webhookTask, webhookPrismatchTask, eventsTask);
        _userRows = usersTask.Result;
        _banks = banksTask.Result;
        _webhook = webhookTask.Result;
        _webhookPrismatch = webhookPrismatchTask.Result;
        _inboundWebhooks = new[] { _webhook, _webhookPrismatch }.Where(w => w is not null).Select(w => w!).ToList();
        _events = eventsTask.Result;
        // Innstillingene deler én cachet bulk-henting (første kall laster alt).
        _smsMaxHour = await Settings.GetIntAsync(TwoFactorService.KeyMaxPerHour, TwoFactorService.DefaultMaxPerHour);
        _smsMax24h = await Settings.GetIntAsync(TwoFactorService.KeyMaxPer24h, TwoFactorService.DefaultMaxPer24h);
        _gdprAnonMonths = await Settings.GetIntAsync("gdpr_anonymize_months", 12);
        _gdprDeleteMonths = await Settings.GetIntAsync("gdpr_delete_months", 24);
        _loginIpList = await Settings.GetAsync("login_ip_allowlist") ?? "";
        _loginMaxFailHour = await Settings.GetIntAsync(SupabaseUserService.KeyMaxFailHour, SupabaseUserService.DefaultMaxFailHour);
        _loginMaxFail24h = await Settings.GetIntAsync(SupabaseUserService.KeyMaxFail24h, SupabaseUserService.DefaultMaxFail24h);
        var bp = await Beregning.HentParametreAsync();
        _berRente = bp.Rente; _berLopetid = bp.LopetidAar;
        _berStress = bp.Stresstest; _berSifoVoksen = bp.SifoVoksen; _berSifoBarn = bp.SifoBarn;
    }

    // ---- Beregningsmodell ----
    private decimal _berRente, _berStress, _berSifoVoksen, _berSifoBarn;
    private int _berLopetid;
    private string? _berMsg;
    private async Task SaveBeregning()
    {
        await Beregning.LagreParametreAsync(new BeregningParametre(_berRente, _berLopetid, _berStress, _berSifoVoksen, _berSifoBarn));
        _berMsg = "Lagret.";
    }

    private string _loginIpList = "";
    private string? _loginIpMsg;
    private async Task SaveLoginIp()
    {
        await Settings.SetAsync("login_ip_allowlist", _loginIpList);
        _loginIpMsg = "IP-whitelist lagret.";
    }

    private int _smsMaxHour = TwoFactorService.DefaultMaxPerHour;
    private int _smsMax24h = TwoFactorService.DefaultMaxPer24h;
    private string? _smsMsg;
    private async Task SaveSmsLimits()
    {
        if (_smsMaxHour < 1) _smsMaxHour = 1;
        if (_smsMax24h < 1) _smsMax24h = 1;
        await Settings.SetAsync(TwoFactorService.KeyMaxPerHour, _smsMaxHour.ToString());
        await Settings.SetAsync(TwoFactorService.KeyMaxPer24h, _smsMax24h.ToString());
        _smsMsg = "Rategrense lagret.";
    }

    // ---- Inbound webhooks + status + hendelser ----
    private Webhook? _webhook;
    private Webhook? _webhookPrismatch;
    private List<Webhook> _inboundWebhooks = new();
    private List<Hendelse> _events = new();
    private string WebhookUrl => $"{Nav.BaseUri}api/webhook/soknad";
    private static bool WebhookFresh(Webhook w) => w.Active && w.LastReceivedAt is { } t && t > DateTime.UtcNow.AddDays(-7);

    // ---- Brukeradministrasjon ----
    private List<UserRow> _userRows = new();
    private bool _loadingUsers = true;
    private string _nuName = "", _nuEmail = "", _nuRole = "Saksbehandler", _nuPassword = "", _nuMobil = "";
    private bool _creating;
    private string? _userMsg;

    // Endre passord (per bruker-rad)
    private readonly Dictionary<Guid, string> _pwInputs = new();
    private string? _pwMsg;
    private string PwInput(Guid id) => _pwInputs.GetValueOrDefault(id, "");
    private void SetPwInput(Guid id, ChangeEventArgs e) => _pwInputs[id] = e.Value?.ToString() ?? "";

    private async Task SetPassword(UserRow u)
    {
        var (ok, error) = await Users.SetPasswordAsync(u.Id, _pwInputs.GetValueOrDefault(u.Id, ""));
        _pwMsg = ok ? $"Passord oppdatert for {u.Email}." : (error ?? "Kunne ikke endre passord.");
        if (ok) _pwInputs[u.Id] = "";
    }

    private async Task LoadUsersAsync()
    {
        _loadingUsers = true;
        _userRows = await Users.ListUsersAsync();
        _loadingUsers = false;
    }

    private async Task ChangeRole(UserRow u, ChangeEventArgs e)
    {
        var role = e.Value?.ToString() ?? u.Role;
        await Users.SetRoleAsync(u.Id, role);
        await LoadUsersAsync();
    }

    private async Task ToggleActive(UserRow u)
    {
        await Users.SetActiveAsync(u.Id, !u.Active);
        await LoadUsersAsync();
    }

    private async Task ToggleTwoFactor(UserRow u)
    {
        await Users.SetTwoFactorAsync(u.Id, !u.TwoFactorEnabled);
        await LoadUsersAsync();
    }

    private readonly Dictionary<Guid, string> _mobilInputs = new();
    private string MobilInput(UserRow u) => _mobilInputs.TryGetValue(u.Id, out var v) ? v : (u.Mobilnummer ?? "");
    private void SetMobilInput(Guid id, ChangeEventArgs e) => _mobilInputs[id] = e.Value?.ToString() ?? "";
    private async Task SaveMobil(UserRow u)
    {
        await Users.SetMobilAsync(u.Id, _mobilInputs.GetValueOrDefault(u.Id, u.Mobilnummer ?? ""));
        _mobilInputs.Remove(u.Id);
        _pwMsg = $"Mobilnummer oppdatert for {u.Email}.";
        await LoadUsersAsync();
    }

    private async Task CreateUser()
    {
        _creating = true;
        _userMsg = null;
        var (ok, error) = await Users.CreateUserAsync(_nuEmail, _nuName, _nuRole, _nuPassword, _nuMobil);
        if (ok)
        {
            await Events.LogAsync("Bruker", $"Ny bruker opprettet (rolle: {_nuRole})", "Admin");
            _userMsg = $"Bruker {_nuEmail} opprettet.";
            _nuName = _nuEmail = _nuPassword = _nuMobil = "";
            _nuRole = "Saksbehandler";
            await LoadUsersAsync();
            _events = await Events.ListAsync(100);
        }
        else
        {
            _userMsg = error ?? "Kunne ikke opprette bruker.";
        }
        _creating = false;
    }

    private readonly string[] _tabs = { "Status", "Generelt", "Partnere", "Brukere", "Logikk-matrise", "Beregningsmodell", "API og Data", "GDPR", "Hendelseslogg" };
    private string _active = "Status";

