    private string _apiTab = "Oversikt";
    private readonly string[] _dataTjenester = { "BankID", "Gjeldsregisteret", "Eiendomsverdi", "Kredittsjekk" };

    // Gjenbrukbart integrasjons-placeholder-kort for de eksterne datatjenestene.
    private RenderFragment IntegrasjonsKort(string navn, string beskrivelse, string[] bruk, string configKeys) =>@<div class="section">
