@page "/crm/admin"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.CustomerFieldCatalog Catalog
@inject RentkuttCRM.Services.SupabaseUserService Users
@inject RentkuttCRM.Services.WebhookService Webhooks
@inject RentkuttCRM.Services.LinkMobilityService LinkMobility
@inject RentkuttCRM.Services.SettingsService Settings
@inject NavigationManager Nav

<PageTitle>Admin — Rentekutt</PageTitle>

<h1 class="page-title">Admin</h1>
<p class="page-sub">Brukere, tilgang, integrasjoner og personvern.</p>

<div class="tabs">
    @foreach (var t in _tabs)
    {
        <button class="tab @(t == _active ? "active" : "")" @onclick="() => _active = t">@t</button>
    }
</div>

@if (_active == "Generelt")
{
    <div class="section">
        <h2>SLA-frister</h2>
        <table class="data-table">
            <thead><tr><th>Hendelse</th><th>Frist</th></tr></thead>
            <tbody>
                @foreach (var s in _slas)
                {
                    <tr><td>@s.Label</td><td><input class="inline-input" value="@s.Hours" /> t</td></tr>
                }
            </tbody>
        </table>
    </div>
}
else if (_active == "Partnere")
{
    <div class="section">
        <h2>Bankpartnere & provisjonssatser <span class="pill pill-warn">@_banks.Count</span></h2>
        <table class="data-table">
            <thead><tr><th>Bank</th><th>Provisjon %</th></tr></thead>
            <tbody>
                @if (_banks.Count == 0)
                {
                    <tr><td colspan="2" class="empty-row">Ingen bankpartnere ennå — legg til under.</td></tr>
                }
                @foreach (var b in _banks)
                {
                    <tr>
                        <td>@b.Name</td>
                        <td><input class="inline-input" value="@b.Rate" /> %</td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_banks.Count > 0)
        {
            <button class="btn-primary" style="margin-top:12px">Lagre satser</button>
        }
    </div>

    <div class="section">
        <h2>Ny partner</h2>
        <div class="rule-builder">
            <div class="rb-field"><label>Banknavn</label><input class="rb-input" @bind="_nbName" placeholder="f.eks. DNB" /></div>
            <div class="rb-field rb-op" style="max-width:140px"><label>Provisjon %</label><input class="rb-input" @bind="_nbRate" placeholder="1,20" /></div>
            <button class="btn-primary rb-add" @onclick="AddBank">Legg til partner</button>
        </div>
    </div>
}
else if (_active == "Leadkilder")
{
    <div class="section">
        <h2>Leadkilder <span class="pill pill-warn">@_sources.Count</span></h2>
        <table class="data-table">
            <thead><tr><th>Kilde</th><th>Aktiv</th></tr></thead>
            <tbody>
                @if (_sources.Count == 0)
                {
                    <tr><td colspan="2" class="empty-row">Ingen leadkilder ennå — legg til under.</td></tr>
                }
                @foreach (var s in _sources)
                {
                    <tr><td>@s.Name</td><td><span class="status @(s.Active ? "on" : "off")">@(s.Active ? "På" : "Av")</span></td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Ny leadkilde</h2>
        <div class="rule-builder">
            <div class="rb-field"><label>Navn</label><input class="rb-input" @bind="_nsName" placeholder="f.eks. Prismatch" /></div>
            <button class="btn-primary rb-add" @onclick="AddSource">Legg til leadkilde</button>
        </div>
    </div>
}
else if (_active == "Brukere")
{
    <div class="section">
        <h2>Roller og tilgang</h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Rettighet</th>
                    @foreach (var r in _roles) { <th>@r</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var perm in _permissions)
                {
                    <tr>
                        <td>@perm.Name</td>
                        @foreach (var allowed in perm.Access)
                        {
                            <td>@if (allowed) { <span class="check">✓</span> } else { <span class="muted">—</span> }</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Brukere <span class="pill pill-warn">@_userRows.Count</span></h2>
        @if (_loadingUsers)
        {
            <p class="page-sub">Laster brukere…</p>
        }
        else
        {
            <table class="data-table">
                <thead><tr><th>Navn</th><th>E-post</th><th>Rolle</th><th>2FA</th><th>Nytt passord</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var u in _userRows)
                    {
                        <tr>
                            <td>@(string.IsNullOrWhiteSpace(u.FullName) ? "—" : u.FullName)</td>
                            <td class="mono-cell">@u.Email</td>
                            <td>
                                <select class="inline-select" @onchange="e => ChangeRole(u, e)">
                                    @foreach (var r in SupabaseUserService.Roles)
                                    {
                                        <option value="@r" selected="@(r == u.Role)">@r</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <button class="btn-sm @(u.TwoFactorEnabled ? "" : "btn-danger")" @onclick="() => ToggleTwoFactor(u)">
                                    @(u.TwoFactorEnabled ? "På" : "Av")
                                </button>
                            </td>
                            <td>
                                <span class="token-row">
                                    <input class="inline-input" type="password" style="width:96px" placeholder="nytt"
                                           value="@PwInput(u.Id)" @onchange="e => SetPwInput(u.Id, e)" />
                                    <button class="btn-sm" @onclick="() => SetPassword(u)">Sett</button>
                                </span>
                            </td>
                            <td><span class="status @(u.Active ? "on" : "off")">@(u.Active ? "Aktiv" : "Deaktivert")</span></td>
                            <td><button class="btn-sm btn-danger" @onclick="() => ToggleActive(u)">@(u.Active ? "Deaktiver" : "Aktiver")</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (!string.IsNullOrEmpty(_pwMsg))
    {
        <p class="page-sub" style="margin:-8px 0 18px">@_pwMsg</p>
    }

    <div class="section">
        <h2>Ny bruker</h2>
        <div class="rule-builder">
            <div class="rb-field"><label>Navn</label><input class="rb-input" @bind="_nuName" placeholder="Fullt navn" /></div>
            <div class="rb-field"><label>E-post</label><input class="rb-input" @bind="_nuEmail" placeholder="navn@rentekutt.no" /></div>
            <div class="rb-field"><label>Mobilnummer (2FA)</label><input class="rb-input" @bind="_nuMobil" placeholder="+47 …" /></div>
            <div class="rb-field rb-op" style="max-width:160px">
                <label>Rolle</label>
                <select class="rb-input" @bind="_nuRole">
                    @foreach (var r in SupabaseUserService.Roles) { <option value="@r">@r</option> }
                </select>
            </div>
            <div class="rb-field"><label>Midlertidig passord</label><input class="rb-input" type="password" @bind="_nuPassword" placeholder="••••••" /></div>
            <button class="btn-primary rb-add" @onclick="CreateUser" disabled="@_creating">@(_creating ? "Oppretter…" : "Opprett bruker")</button>
        </div>
        @if (!string.IsNullOrEmpty(_userMsg))
        {
            <p class="page-sub" style="margin-top:10px">@_userMsg</p>
        }
        @if (!Users.IsConfigured)
        {
            <p class="page-sub" style="margin-top:6px; font-size:12px">⚠️ Supabase ikke koblet til — endringer er midlertidige (staging).</p>
        }
    </div>

}
else if (_active == "API og Data")
{
    <div class="webhook-widget">
        <div class="ww-header" @onclick="() => _webhookOpen = !_webhookOpen">
            <div class="ww-title">
                <span class="ww-chevron @(_webhookOpen ? "open" : "")">▸</span>
                <strong>@WebhookService.InboundName</strong>
                <span class="ww-tag">inbound endepunkt</span>
            </div>
            <div class="ww-meta">
                @if (_webhook?.LastReceivedAt is { } t)
                {
                    <span class="ww-last">Sist mottatt @t.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · @_webhook.LastReceivedInfo</span>
                }
                else
                {
                    <span class="ww-last muted">Ingen data mottatt ennå</span>
                }
                <span class="status on">Aktiv</span>
            </div>
        </div>

        @if (_webhookOpen)
        {
            <div class="ww-body">
                <p class="page-sub" style="margin:0 0 16px">
                    Mottar lånesøknader (finansielle data + fødselsnummer) fra ekstern leverandør og mapper dem til kundekort.
                </p>

                <div class="kv-list" style="margin-bottom:16px">
                    <span class="k">Endepunkt</span>
                    <span class="v">POST @WebhookUrl</span>
                    <span class="k">Autentisering</span>
                    <span class="v">Authorization: Bearer &lt;token&gt;</span>
                    <span class="k">Format</span>
                    <span class="v">application/json</span>
                    <span class="k">Token</span>
                    <span>
                        @if (_webhook is null)
                        {
                            <span class="muted">Genereres ved oppstart…</span>
                        }
                        else
                        {
                            <span class="token-row">
                                <span class="token-val">@(_showToken ? _webhook.Token : "whk_••••••••••••••••••••••••")</span>
                                <button class="btn-sm" @onclick="() => _showToken = !_showToken">@(_showToken ? "Skjul" : "Vis")</button>
                            </span>
                        }
                    </span>
                </div>

                <div style="margin-bottom:18px">
                    <span class="sec-badge">🔒 HTTPS påkrevd (TLS)</span>
                    <span class="sec-badge">🔑 Token (konstant-tid)</span>
                    <span class="sec-badge">🇪🇺 EU-lagring</span>
                    <span class="sec-badge">🛡️ RLS — kun server</span>
                    <span class="sec-badge">🙈 Ingen PII i logg</span>
                </div>

                <h3 class="ww-h">IP-whitelist</h3>
                <p class="page-sub" style="margin:0 0 8px; font-size:12px">Kun disse IP-ene får sende data (komma-/linjeseparert). Tom = alle tillatt.</p>
                <div class="rule-builder" style="margin-bottom:18px">
                    <div class="rb-field" style="flex:1; min-width:240px"><label>Tillatte IP-er</label><input class="rb-input" @bind="_ipList" placeholder="f.eks. 13.74.0.10, 51.120.0.5" /></div>
                    <button class="btn-primary rb-add" @onclick="SaveIpAllowlist">Lagre</button>
                </div>
                @if (!string.IsNullOrEmpty(_ipMsg))
                {
                    <p class="page-sub" style="margin:-8px 0 14px">@_ipMsg</p>
                }

                <h3 class="ww-h">Dataflyt</h3>
                <ol class="flow-steps" style="margin-bottom:18px">
                    <li>Leverandør (f.eks. lead-portal) sender <strong>POST</strong> med JSON til endepunktet over <strong>HTTPS</strong>.</li>
                    <li>Forespørselen autentiseres med <strong>Bearer-token</strong> — sammenlignet i konstant tid. Ugyldig token → <code>401</code>.</li>
                    <li>Payloaden <strong>mappes til et kundekort</strong> (fødselsnummer blir kunde-ID for B2C, orgnr for B2B).</li>
                    <li>Kundekortet lagres i <strong>Supabase</strong> (EU, Postgres) med RLS — kun serveren har tilgang.</li>
                    <li>Søknaden dukker opp i <strong>Database</strong>-fanen og kan rutes videre via Logikk-matrise.</li>
                </ol>

                <h3 class="ww-h">Payload — send til utvikler</h3>
                <pre class="code-block">curl -X POST @WebhookUrl \
  -H "Authorization: Bearer @(_webhook?.Token ?? "<token>")" \
  -H "Content-Type: application/json" \
  -d '@PayloadExample'</pre>
            </div>
        }
    </div>

    <div class="webhook-widget">
        <div class="ww-header" @onclick="() => _lmOpen = !_lmOpen">
            <div class="ww-title">
                <span class="ww-chevron @(_lmOpen ? "open" : "")">▸</span>
                <strong>LinkMobility</strong>
                <span class="ww-tag">SMS · 2FA</span>
            </div>
            <div class="ww-meta">
                <span class="ww-last">@(LinkMobility.ErKonfigurert ? "Konfigurert" : "Ikke konfigurert")</span>
                <span class="status @(LinkMobility.ErKonfigurert ? "on" : "off")">@(LinkMobility.ErKonfigurert ? "Aktiv" : "Av")</span>
            </div>
        </div>
        @if (_lmOpen)
        {
            <div class="ww-body">
                <p class="page-sub" style="margin:0 0 16px">
                    MyLink SMS API (OAuth2 client credentials) — sender engangskoder for 2FA ved innlogging.
                </p>
                <div class="kv-list" style="margin-bottom:16px">
                    <span class="k">Status</span>
                    <span class="v">@(LinkMobility.ErKonfigurert ? "Client ID + secret satt ✓" : "Mangler Client ID/secret")</span>
                    <span class="k">Avsender</span><span class="v">@LinkMobility.Sender</span>
                    <span class="k">Token-URL</span><span class="v">@LinkMobility.TokenUrl</span>
                    <span class="k">Send-URL</span><span class="v">@LinkMobility.SendUrl</span>
                </div>
                <h3 class="ww-h">SMS-rategrense (per bruker)</h3>
                <p class="page-sub" style="margin:0 0 8px; font-size:12px">Sikring mot misbruk og kostnad: maks antall innloggingskoder per bruker.</p>
                <div class="rule-builder" style="margin-bottom:8px">
                    <div class="rb-field rb-op" style="max-width:130px"><label>Maks per time</label><input class="rb-input" type="number" min="1" @bind="_smsMaxHour" /></div>
                    <div class="rb-field rb-op" style="max-width:130px"><label>Maks per 24t</label><input class="rb-input" type="number" min="1" @bind="_smsMax24h" /></div>
                    <button class="btn-primary rb-add" @onclick="SaveSmsLimits">Lagre</button>
                </div>
                @if (!string.IsNullOrEmpty(_smsMsg))
                {
                    <p class="page-sub" style="margin:0 0 16px; font-size:12px">@_smsMsg</p>
                }

                <h3 class="ww-h">Konfigurasjon (Azure App Settings)</h3>
                <pre class="code-block">LinkMobility__ClientId      = &lt;klient-ID&gt;
LinkMobility__ClientSecret  = &lt;klient-hemmelighet&gt;
LinkMobility__Sender        = Rentekutt        (valgfri)
LinkMobility__TokenUrl      = &lt;overstyrbar&gt;     (valgfri)
LinkMobility__SendUrl       = &lt;overstyrbar&gt;     (valgfri)</pre>
                <p class="page-sub" style="margin:12px 0 0; font-size:12px">
                    🔒 Client ID/secret leses kun fra server-config (Azure), aldri fra databasen. 2FA aktiveres per bruker under Brukere.
                </p>
            </div>
        }
    </div>

    <div class="section">
        <h2>API <span class="pill pill-warn">@ApiRowCount</span></h2>
        <p class="page-sub" style="margin:-4px 0 14px">
            Hver bankpartner og leadkilde får automatisk en rad her. Velg metode for å motta/sende data.
        </p>
        <table class="data-table">
            <thead><tr><th>Navn</th><th>Type</th><th>Metode</th><th>Status</th></tr></thead>
            <tbody>
                @if (ApiRowCount == 0)
                {
                    <tr><td colspan="4" class="empty-row">Ingen integrasjoner ennå — opprett en partner/leadkilde, eller legg til under.</td></tr>
                }
                @foreach (var b in _banks)
                {
                    <tr>
                        <td>@b.Name</td>
                        <td><span class="type-tag bank">Bank</span></td>
                        <td>
                            <select class="inline-select" @bind="b.Method">
                                @foreach (var m in _methods) { <option value="@m">@m</option> }
                            </select>
                        </td>
                        <td><span class="status off">Ikke tilkoblet</span></td>
                    </tr>
                }
                @foreach (var s in _sources)
                {
                    <tr>
                        <td>@s.Name</td>
                        <td><span class="type-tag lead">Leadkilde</span></td>
                        <td>
                            <select class="inline-select" @bind="s.Method">
                                @foreach (var m in _methods) { <option value="@m">@m</option> }
                            </select>
                        </td>
                        <td><span class="status off">Ikke tilkoblet</span></td>
                    </tr>
                }
                @foreach (var i in _integrations)
                {
                    <tr>
                        <td>@i.Name</td>
                        <td><span class="type-tag">Annet</span></td>
                        <td>
                            <select class="inline-select" @bind="i.Method">
                                @foreach (var m in _methods) { <option value="@m">@m</option> }
                            </select>
                        </td>
                        <td><span class="status off">Ikke tilkoblet</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Ny integrasjon</h2>
        <div class="rule-builder">
            <div class="rb-field"><label>Navn</label><input class="rb-input" @bind="_niName" placeholder="f.eks. Kreditz" /></div>
            <div class="rb-field rb-op" style="max-width:180px">
                <label>Metode</label>
                <select class="rb-input" @bind="_niMethod">
                    @foreach (var m in _methods) { <option value="@m">@m</option> }
                </select>
            </div>
            <button class="btn-primary rb-add" @onclick="AddIntegration">Legg til integrasjon</button>
        </div>
    </div>

    <div class="section">
        <h2>Datalagring</h2>
        <ul class="bullet-list">
            <li>Region: <strong>EU (Sweden Central)</strong></li>
            <li>Database: Supabase (Postgres)</li>
            <li>Backup: daglig, 30 dagers oppbevaring</li>
        </ul>
    </div>
}
else if (_active == "Logikk-matrise")
{
    <div class="section">
        <h2>Rutingsregler <span class="pill pill-warn">@_rules.Count(r => r.Active) aktive</span></h2>
        <p class="page-sub" style="margin:-4px 0 14px">
            Universalfilter: segmentér søknader til bank basert på alle kundedata vi har
            (@Catalog.Fields.Count felter — geografi, lån, økonomi, personalia, PSD2).
            Reglene vurderes ovenfra og ned — første treff bestemmer hvilke banker søknaden sendes til.
        </p>
        <table class="data-table">
            <thead>
                <tr><th>#</th><th>Parameter</th><th>Operator</th><th>Verdi</th><th>Send til</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @if (_rules.Count == 0)
                {
                    <tr><td colspan="7" class="empty-row">Ingen rutingsregler ennå — legg til under.</td></tr>
                }
                @foreach (var r in _rules.OrderBy(r => r.Priority))
                {
                    <tr>
                        <td class="mono-cell">@r.Priority</td>
                        <td>@LabelFor(r.FieldKey)</td>
                        <td class="mono-cell">@r.Operator</td>
                        <td>@DisplayValue(r)</td>
                        <td>
                            <div class="route-banks">
                                @foreach (var bank in r.Banks)
                                {
                                    <span class="route-bank">@bank</span>
                                }
                            </div>
                        </td>
                        <td>
                            <label class="toggle">
                                <input type="checkbox" checked="@r.Active" @onchange="e => r.Active = (bool)e.Value!" />
                                <span class="status @(r.Active ? "on" : "off")">@(r.Active ? "Aktiv" : "Av")</span>
                            </label>
                        </td>
                        <td><button class="btn-sm btn-danger" @onclick="() => RemoveRule(r)">Slett</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Ny regel</h2>
        <div class="rule-builder">
            <div class="rb-field">
                <label>Felt (kundedata)</label>
                <select class="rb-input" value="@_newFieldKey" @onchange="OnFieldChanged">
                    @foreach (var cat in Catalog.Categories)
                    {
                        <optgroup label="@cat">
                            @foreach (var f in Catalog.InCategory(cat))
                            {
                                <option value="@f.Key">@f.Label</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>
            <div class="rb-field rb-op">
                <label>Operator</label>
                <select class="rb-input" @bind="_newOp">
                    @foreach (var o in NewOperators) { <option value="@o">@o</option> }
                </select>
            </div>
            <div class="rb-field">
                <label>Verdi</label>
                @{ var nf = NewField; }
                @if (nf?.Type == FieldType.Enum && nf.Options is not null)
                {
                    <select class="rb-input" @bind="_newValue">
                        @foreach (var v in nf.Options) { <option value="@v">@v</option> }
                    </select>
                }
                else
                {
                    <div class="input-unit">
                        <input class="rb-input" @bind="_newValue" placeholder="@(nf?.Placeholder ?? "Verdi")" />
                        @if (!string.IsNullOrEmpty(nf?.Unit)) { <span class="unit-suffix">@nf.Unit</span> }
                    </div>
                }
            </div>
            <div class="rb-arrow">→</div>
            <div class="rb-field rb-banks">
                <label>Send til bank(er) — velg én eller flere</label>
                <div class="bank-chips">
                    @foreach (var b in BankNames)
                    {
                        <button type="button" class="bank-chip @(_newBanks.Contains(b) ? "sel" : "")" @onclick="() => ToggleNewBank(b)">@b</button>
                    }
                </div>
            </div>
        </div>
        <button class="btn-primary rb-add-row" @onclick="AddRule">Legg til regel</button>
        <p class="page-sub" style="margin:14px 0 0; font-size:12px">
            💡 Feltlisten er foreløpig eksempeldata. Den styres fra ett sted (feltkatalogen),
            og oppdateres automatisk her når ekte kundedatafelt opprettes / kobles til API-et (PSD2/scoring).
        </p>
    </div>
}
else if (_active == "GDPR")
{
    <div class="form-card">
        <h2>Personvern & oppbevaring</h2>
        <p class="page-sub" style="margin:0 0 16px">
            For å etterleve GDPR (dataminimering og lagringsbegrensning) behandles søknadsdata i to trinn,
            regnet fra da søknaden ble opprettet. Først <strong>anonymisering</strong> — de finansielle
            detaljene fjernes, men kontaktinfo og at en søknad ble sendt beholdes. Deretter <strong>sletting</strong>
            — hele kundekortet fjernes permanent.
        </p>

        <table class="data-table">
            <thead><tr><th>Trinn</th><th>Hva skjer</th><th>Beholdes</th><th>Etter</th></tr></thead>
            <tbody>
                <tr>
                    <td><span class="type-tag lead">Anonymisering</span></td>
                    <td>Fjerner alle søknadsdetaljer (lånebeløp, inntekt, gjeld, arbeidsforhold, husholdning m.m.)</td>
                    <td>Navn + kontaktinfo, og at en søknad ble sendt (dato)</td>
                    <td><input class="inline-input" type="number" min="1" max="120" @bind="_gdprAnonMonths" /> mnd</td>
                </tr>
                <tr>
                    <td><span class="type-tag">Sletting</span></td>
                    <td>Sletter hele kundekortet permanent</td>
                    <td class="muted">Ingenting</td>
                    <td><input class="inline-input" type="number" min="1" max="240" @bind="_gdprDeleteMonths" /> mnd</td>
                </tr>
            </tbody>
        </table>
        <button class="btn-primary" style="margin-top:14px" @onclick="SaveGdpr">Lagre</button>
        @if (!string.IsNullOrEmpty(_gdprMsg))
        {
            <p class="page-sub" style="margin-top:10px">@_gdprMsg</p>
        }
    </div>

    <div class="form-card">
        <h2>Slik ser en anonymisert sak ut</h2>
        <p class="page-sub" style="margin:0">
            Etter @_gdprAnonMonths måneder lagres f.eks. kun:
            «<strong>Ola Nordmann (90012345)</strong> sendte en lånesøknad <strong>12.03.2026</strong>» —
            ingen detaljer om beløp, inntekt eller gjeld.
        </p>
    </div>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        await LoadUsersAsync();
        _webhook = await Webhooks.GetInboundAsync();
        _ipList = _webhook?.IpAllowlist ?? "";
        _smsMaxHour = await Settings.GetIntAsync(TwoFactorService.KeyMaxPerHour, TwoFactorService.DefaultMaxPerHour);
        _smsMax24h = await Settings.GetIntAsync(TwoFactorService.KeyMaxPer24h, TwoFactorService.DefaultMaxPer24h);
        _gdprAnonMonths = await Settings.GetIntAsync("gdpr_anonymize_months", 12);
        _gdprDeleteMonths = await Settings.GetIntAsync("gdpr_delete_months", 24);
    }

    private int _smsMaxHour = TwoFactorService.DefaultMaxPerHour;
    private int _smsMax24h = TwoFactorService.DefaultMaxPer24h;
    private string? _smsMsg;
    private async Task SaveSmsLimits()
    {
        if (_smsMaxHour < 1) _smsMaxHour = 1;
        if (_smsMax24h < 1) _smsMax24h = 1;
        await Settings.SetAsync(TwoFactorService.KeyMaxPerHour, _smsMaxHour.ToString());
        await Settings.SetAsync(TwoFactorService.KeyMaxPer24h, _smsMax24h.ToString());
        _smsMsg = "Rategrense lagret.";
    }

    private string _ipList = "";
    private string? _ipMsg;
    private async Task SaveIpAllowlist()
    {
        if (_webhook is null) return;
        await Webhooks.SetIpAllowlistAsync(_webhook.Id, _ipList);
        _webhook.IpAllowlist = _ipList;
        _ipMsg = "IP-whitelist lagret.";
    }

    // ---- Inbound webhook ----
    private Webhook? _webhook;
    private bool _showToken;
    private bool _webhookOpen;
    private bool _lmOpen;
    private string WebhookUrl => $"{Nav.BaseUri}api/webhook/soknad";
    private const string PayloadExample = """
{
