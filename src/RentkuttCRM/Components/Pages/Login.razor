@page "/"
@page "/login"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.SupabaseUserService Users
@inject RentkuttCRM.Services.TwoFactorService TwoFactor
@inject NavigationManager Nav
@inject ILogger<Login> Logger
@inject ProtectedLocalStorage LocalStorage

<PageTitle>Logg inn — Rentekutt</PageTitle>

<div class="login-wrap">
    <div class="login-card">
        <div class="login-brand">
            <img src="rentekutt-logo.svg" alt="Rentekutt" class="login-logo" />
        </div>

        @if (_step == 1)
        {
            <EditForm Model="@model" OnValidSubmit="HandleLogin">
                <div class="form-field">
                    <label>E-post</label>
                    <InputText @bind-Value="model.Email" placeholder="navn@rentekutt.no" autocomplete="username" />
                </div>
                <div class="form-field">
                    <label>Passord</label>
                    <InputText type="password" @bind-Value="model.Password" placeholder="••••••••" autocomplete="current-password" />
                </div>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="login-error">@_error</div>
                }
                <button type="submit" class="btn-primary full" disabled="@_busy">
                    @(_busy ? "Logger inn…" : "Logg inn")
                </button>
            </EditForm>
        }
        else
        {
            <div>
                <p class="page-sub" style="margin:0 0 14px">Vi sendte en engangskode på SMS. Skriv den inn for å fullføre innloggingen.</p>
                <div class="form-field">
                    <label>SMS-kode</label>
                    <input @bind="_code" placeholder="6-sifret kode" autocomplete="one-time-code" inputmode="numeric" />
                </div>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="login-error">@_error</div>
                }
                <button class="btn-primary full" @onclick="HandleVerify" disabled="@_busy">
                    @(_busy ? "Verifiserer…" : "Bekreft kode")
                </button>
                <p class="login-note">Feil nummer? <a href="/login" @onclick:preventDefault @onclick="Reset">Start på nytt</a></p>
            </div>
        }

        @if (_step == 1 && !Users.IsConfigured)
        {
            <p class="login-note">Staging — skriv hva som helst for å logge inn.</p>
        }
    </div>
</div>

@code {
    private readonly LoginModel model = new();
    private string _code = "";
    private int _step = 1;
    private UserRow? _pending;
    private string? _error;
    private bool _busy;

    protected override void OnInitialized()
    {
        if (Session.IsLoggedIn) Nav.NavigateTo("/crm");
    }

    private async Task HandleLogin()
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await Users.SignInAsync(model.Email, model.Password);
            if (result is not { Ok: true, User: not null })
            {
                _error = result.Error ?? "Innlogging feilet.";
                _busy = false;
                return;
            }

            var user = result.User;
            // 2FA er fail-closed: er den PÅ men vi ikke kan levere kode (mangler mobil / SMS
            // ikke konfigurert), nekter vi innlogging i stedet for å slippe forbi uten andrefaktor.
            if (user.TwoFactorEnabled)
            {
                if (!TwoFactor.KanSende(user))
                {
                    _error = "Tofaktor er påkrevd for kontoen din, men ingen leveringskanal (mobilnummer/SMS) er satt opp. Kontakt administrator.";
                    _busy = false;
                    return;
                }
                var (sent, error) = await TwoFactor.SendKodeAsync(user);
                if (!sent) { _error = error; _busy = false; return; }
                _pending = user;
                _step = 2;
                _busy = false;
                return;
            }

            await FullforInnlogging(user);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Innlogging feilet uventet");
            _error = "Teknisk feil ved innlogging. Prøv igjen senere.";
            _busy = false;
        }
    }

    private async Task HandleVerify()
    {
        _busy = true;
        _error = null;
        try
        {
            if (_pending is not null && TwoFactor.Verifiser(_pending.Email, _code))
            {
                await FullforInnlogging(_pending);
                return;
            }
            _error = "Feil eller utløpt kode.";
            _busy = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "2FA-verifisering feilet uventet");
            _error = "Teknisk feil. Prøv igjen senere.";
            _busy = false;
        }
    }

    // Sett in-memory-sesjon + persister kryptert i nettleseren (overlever refresh), og gå til CRM.
    private async Task FullforInnlogging(UserRow user)
    {
        Session.SignIn(user);
        try { await LocalStorage.SetAsync("rk_session", new PersistertSesjon(user.Id, user.Email, user.FullName, user.Role)); }
        catch (Exception ex) { Logger.LogWarning(ex, "Kunne ikke persistere sesjon (fortsetter uten)"); }
        Nav.NavigateTo("/crm");
    }

    private void Reset()
    {
        _step = 1;
        _pending = null;
        _code = "";
        _error = null;
    }

    private class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
