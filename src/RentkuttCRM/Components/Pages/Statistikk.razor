@page "/crm/statistikk"
@inject RentkuttCRM.Services.SessionState Session
@inject NavigationManager Nav

<PageTitle>Statistikk — Rentekutt</PageTitle>

<h1 class="page-title">Statistikk</h1>
<p class="page-sub">Konvertering, bankytelse og volum.</p>

<div class="kpi-grid">
    <div class="kpi-card"><div class="kpi-value">0</div><div class="kpi-label">Søknader</div></div>
    <div class="kpi-card"><div class="kpi-value">0 %</div><div class="kpi-label">Kvalifiseringsrate</div></div>
    <div class="kpi-card"><div class="kpi-value">0 %</div><div class="kpi-label">Close rate</div></div>
    <div class="kpi-card"><div class="kpi-value">0 kr</div><div class="kpi-label">Formidlet volum</div></div>
    <div class="kpi-card"><div class="kpi-value">0 kr</div><div class="kpi-label">Opptjent provisjon</div></div>
</div>

<div class="section">
    <h2>Konverteringstrakt</h2>
    <div class="funnel">
        @foreach (var f in _funnel)
        {
            <div class="funnel-step">
                <div class="funnel-bar" style="width:0%; min-width:38px">0</div>
                <div class="funnel-label">@f <span class="muted">(0 %)</span></div>
            </div>
        }
    </div>
</div>

<div class="section">
    <h2>Bankytelse</h2>
    <table class="data-table">
        <thead>
            <tr><th>Bank</th><th>Sendt</th><th>Tilbud</th><th>Fullført</th><th>Hit rate</th><th>Close rate</th><th>Volum</th></tr>
        </thead>
        <tbody>
            <tr><td colspan="7" class="empty-row">Ingen data ennå.</td></tr>
        </tbody>
    </table>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!Session.IsLoggedIn) Nav.NavigateTo("/login");
    }

    private readonly string[] _funnel =
    {
        "Søknader",
        "Kvalifisert",
        "Sendt til bank",
        "Tilbud mottatt",
        "Fullført",
    };
}
