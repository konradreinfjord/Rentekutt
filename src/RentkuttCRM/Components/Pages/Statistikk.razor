@page "/crm/statistikk"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.KundekortService Kundekort
@inject RentkuttCRM.Services.PartnerService Partners
@inject RentkuttCRM.Services.SettingsService Settings
@inject NavigationManager Nav

<PageTitle>Statistikk — Rentekutt</PageTitle>

<h1 class="page-title">Statistikk</h1>
<p class="page-sub">Kontaktstrøm, konvertering, provisjon, lånevolum og cashflow.</p>

@if (_loading)
{
    <p class="page-sub">Laster…</p>
}
else
{
    @* ---------- Tidsfilter + parameter ---------- *@
    <div class="stat-filter">
        <div class="period-seg">
            @foreach (var pp in _perioder)
            {
                <button class="@(_periode == pp.Verdi ? "active" : "")" @onclick="() => _periode = pp.Verdi">@pp.Navn</button>
            }
        </div>
        <select class="db-select" @bind="_leadskilde">
            <option value="">Alle leadskilder</option>
            @foreach (var ls in Leadskilder) { <option value="@ls">@ls</option> }
        </select>
        <select class="db-select" @bind="_bankFilter">
            <option value="">Alle banker</option>
            @foreach (var p in _partnere) { <option value="@p.Navn">@p.Navn</option> }
        </select>
        <span class="stat-period-info">@Rows.Count søknader i utvalget</span>
    </div>

    var rows = Rows;
    var total = rows.Count;
    var fullfort = rows.Where(k => k.Status == KundekortService.StatusFullfort).ToList();
    var avslatt = rows.Where(k => k.Status == "Avslått").ToList();
    var aktive = rows.Where(k => k.Status != KundekortService.StatusFullfort && k.Status != "Avslått").ToList();

    var konv = total == 0 ? 0 : 100.0 * fullfort.Count / total;
    var laanevolum = fullfort.Sum(k => k.OnsketLaanebelop ?? 0);
    var pipelineVolum = aktive.Sum(k => k.OnsketLaanebelop ?? 0);
    var forventetVolum = aktive.Sum(k => (k.OnsketLaanebelop ?? 0) * (decimal)Sannsynlighet(k.Status));
    var opptjent = fullfort.Sum(Provisjon);
    var forventetProv = aktive.Sum(k => Provisjon(k) * (decimal)Sannsynlighet(k.Status));

    var perDag = total / (double)PeriodeDager;
    var perUke = perDag * 7;
    var perMnd = perDag * 30;
    var gjsnDager = total == 0 ? 0 : rows.Average(DagerSiden);

    var bankSyklus = BankSyklustider(rows);
    var maxSyklus = bankSyklus.Count == 0 ? 1.0 : Math.Max(1.0, bankSyklus.Max(b => b.Snitt));
    var bankRader = BankRader(rows).ToList();

    @* ---------- Nøkkeltall (metric-strip) ---------- *@
    <div class="section widget">
        <h2>Nøkkeltall</h2>
    <div class="metric-strip metric-flush">
        <div class="metric">
            <div class="metric-num">@total</div>
            <div class="metric-label">Kontaktstrøm</div>
            <div class="metric-sub">nye søknader i perioden</div>
        </div>
        <div class="metric">
            <div class="metric-num">@($"{konv:N0}")<span class="metric-unit">%</span></div>
            <div class="metric-label">Konvertering</div>
            <div class="metric-sub">@fullfort.Count fullført av @total</div>
        </div>
        <div class="metric">
            <div class="metric-num">@Mnok(laanevolum)<span class="metric-unit">@MnokEnhet(laanevolum)</span></div>
            <div class="metric-label">Lånevolum</div>
            <div class="metric-sub">formidlet (utbetalt)</div>
        </div>
        <div class="metric">
            <div class="metric-num">@Mnok(forventetVolum)<span class="metric-unit">@MnokEnhet(forventetVolum)</span></div>
            <div class="metric-label">Forventet volum</div>
            <div class="metric-sub">vektet pipeline (@Mnok(pipelineVolum) @MnokEnhet(pipelineVolum) brutto)</div>
        </div>
        <div class="metric">
            <div class="metric-num">@($"{opptjent:N0}")<span class="metric-unit">kr</span></div>
            <div class="metric-label">Opptjent provisjon</div>
            <div class="metric-sub">realisert</div>
        </div>
        <div class="metric">
            <div class="metric-num">@($"{forventetProv:N0}")<span class="metric-unit">kr</span></div>
            <div class="metric-label">Forventet provisjon</div>
            <div class="metric-sub">vektet pipeline</div>
        </div>
    </div>
    </div>

    <div class="stat-cols">
        @* ---------- Kontaktstrøm per leadskilde ---------- *@
        <div class="section widget">
            <h2>Kontaktstrøm</h2>
            <h3 class="stat-subhead">Per leadskilde</h3>
            <table class="data-table">
                <thead><tr><th>Leadskilde</th><th class="num">Søknader</th><th class="num">Andel</th></tr></thead>
                <tbody>
                    @foreach (var g in rows.GroupBy(k => string.IsNullOrWhiteSpace(k.Kilde) ? "Ukjent" : k.Kilde).OrderByDescending(g => g.Count()))
                    {
                        <tr>
                            <td><span class="kilde-badge @KundekortService.KildeBadgeKlasse(g.Key)">@g.Key</span></td>
                            <td class="num">@g.Count()</td>
                            <td class="num">@($"{(total == 0 ? 0 : 100.0 * g.Count() / total):N0}") %</td>
                        </tr>
                    }
                    @if (total == 0)
                    {
                        <tr><td colspan="3" class="empty-row">Ingen data i perioden.</td></tr>
                    }
                </tbody>
            </table>

            <h3 class="stat-subhead" style="margin-top:18px">Per lånetype</h3>
            <table class="data-table">
                <thead><tr><th>Lånetype</th><th class="num">Søknader</th><th class="num">Andel</th></tr></thead>
                <tbody>
                    @foreach (var g in rows.GroupBy(k => string.IsNullOrWhiteSpace(k.Laanetype) ? "Ukjent" : k.Laanetype).OrderByDescending(g => g.Count()))
                    {
                        <tr>
                            <td><span class="vol-dot" style="background:@LaanetypeFarge(g.Key)"></span>@g.Key</td>
                            <td class="num">@g.Count()</td>
                            <td class="num">@($"{(total == 0 ? 0 : 100.0 * g.Count() / total):N0}") %</td>
                        </tr>
                    }
                    @if (total == 0)
                    {
                        <tr><td colspan="3" class="empty-row">Ingen data i perioden.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        @* ---------- Lånevolum-fordeling ---------- *@
        <div class="section widget">
            <h2>Lånevolum</h2>
            <h3 class="stat-subhead">Etter fase</h3>
            <table class="data-table">
                <thead><tr><th>Kategori</th><th class="num">Antall</th><th class="num">Volum</th></tr></thead>
                <tbody>
                    <tr><td><span class="vol-dot" style="background:#266f32"></span>Formidlet (utbetalt)</td><td class="num">@fullfort.Count</td><td class="num">@($"{laanevolum:N0}") kr</td></tr>
                    <tr><td><span class="vol-dot" style="background:#1f5fc4"></span>Aktiv pipeline</td><td class="num">@aktive.Count</td><td class="num">@($"{pipelineVolum:N0}") kr</td></tr>
                    <tr><td><span class="vol-dot" style="background:#0f8a8a"></span>Forventet (vektet)</td><td class="num">—</td><td class="num">@($"{forventetVolum:N0}") kr</td></tr>
                    <tr><td><span class="vol-dot" style="background:#b42318"></span>Avslått</td><td class="num">@avslatt.Count</td><td class="num">@($"{avslatt.Sum(k => k.OnsketLaanebelop ?? 0):N0}") kr</td></tr>
                </tbody>
            </table>

            <h3 class="stat-subhead" style="margin-top:18px">Per lånetype</h3>
            <table class="data-table">
                <thead><tr><th>Lånetype</th><th class="num">Antall</th><th class="num">Volum</th></tr></thead>
                <tbody>
                    @foreach (var g in rows.GroupBy(k => string.IsNullOrWhiteSpace(k.Laanetype) ? "Ukjent" : k.Laanetype).OrderByDescending(g => g.Sum(k => k.OnsketLaanebelop ?? 0)))
                    {
                        <tr>
                            <td><span class="vol-dot" style="background:@LaanetypeFarge(g.Key)"></span>@g.Key</td>
                            <td class="num">@g.Count()</td>
                            <td class="num">@($"{g.Sum(k => k.OnsketLaanebelop ?? 0):N0}") kr</td>
                        </tr>
                    }
                    @if (total == 0)
                    {
                        <tr><td colspan="3" class="empty-row">Ingen data i perioden.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ---------- Konvertering per bank ---------- *@
    <div class="section widget">
        <h2>Konvertering per bank</h2>
        <table class="data-table">
            <thead>
                <tr><th>Bank</th><th class="num">Delegert</th><th class="num">Fullført</th><th>Konvertering</th><th class="num">Lånevolum</th><th class="num">Provisjon</th></tr>
            </thead>
            <tbody>
                @foreach (var b in bankRader)
                {
                    <tr>
                        <td>@b.Navn</td>
                        <td class="num">@b.Delegert</td>
                        <td class="num">@b.Fullfort</td>
                        <td>
                            <div class="minibar-cell">
                                <div class="minibar"><div class="minibar-fill" style="width:@(b.Konv.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%"></div></div>
                                <span class="minibar-pct">@($"{b.Konv:N0}") %</span>
                            </div>
                        </td>
                        <td class="num">@($"{b.Volum:N0}") kr</td>
                        <td class="num">@($"{b.Provisjon:N0}") kr</td>
                    </tr>
                }
                @if (bankRader.Count == 0)
                {
                    <tr><td colspan="6" class="empty-row">Ingen delegerte søknader i perioden.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @* ---------- Tidsbruk ---------- *@
    <div class="section widget">
        <h2>Tidsbruk</h2>
        <p class="page-sub" style="margin:-4px 0 14px">Gjennomstrømning og liggetid målt mot fastsatte krav — for å benchmarke agenter.</p>

        <div class="mal-bar">
            <label>Krav: maks <input type="number" step="0.5" min="0" @bind="_malDager" /> dager per sak</label>
            <label>Krav: minst <input type="number" min="0" @bind="_malSakerUke" /> saker per agent / uke</label>
            <button class="btn-sm" @onclick="SaveMal">Lagre krav</button>
            @if (!string.IsNullOrEmpty(_malMsg)) { <span class="muted">@_malMsg</span> }
        </div>

        <h3 class="stat-subhead" style="margin:16px 0 8px">Gjennomstrømning (etter tidsfilter)</h3>
        <div class="metric-strip metric-flush" style="margin:0 0 4px">
            <div class="metric"><div class="metric-num">@($"{perDag:N1}")</div><div class="metric-label">Saker / dag</div><div class="metric-sub">over @PeriodeDager dager</div></div>
            <div class="metric"><div class="metric-num">@($"{perUke:N1}")</div><div class="metric-label">Saker / uke</div></div>
            <div class="metric"><div class="metric-num">@($"{perMnd:N0}")</div><div class="metric-label">Saker / måned</div></div>
            <div class="metric"><div class="metric-num @(gjsnDager <= (double)_malDager ? "mal-ok" : "mal-bad")">@($"{gjsnDager:N1}")</div><div class="metric-label">Gj.snitt dager / sak</div><div class="metric-sub">krav: maks @($"{_malDager:N0}")</div></div>
        </div>

        <div class="stat-cols">
            <div>
                <h3 class="stat-subhead">Per status</h3>
                <table class="data-table">
                    <thead><tr><th>Status</th><th class="num">Antall</th><th class="num">Gj.snitt dager</th></tr></thead>
                    <tbody>
                        @foreach (var g in rows.GroupBy(k => k.Status).OrderBy(g => Array.IndexOf(KundekortService.Statuser, g.Key)))
                        {
                            <tr>
                                <td><span class="vol-dot" style="background:@StatusFarge(g.Key)"></span>@g.Key</td>
                                <td class="num">@g.Count()</td>
                                <td class="num">@($"{g.Average(DagerSiden):N1}")</td>
                            </tr>
                        }
                        @if (total == 0)
                        {
                            <tr><td colspan="3" class="empty-row">Ingen data i perioden.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            <div>
                <h3 class="stat-subhead">Hos bank</h3>
                <table class="data-table">
                    <thead><tr><th>Bank</th><th class="num">Saker</th><th class="num">Gj.snitt dager</th></tr></thead>
                    <tbody>
                        @foreach (var g in rows.Where(k => !string.IsNullOrWhiteSpace(k.DelegertBank)).GroupBy(k => k.DelegertBank!).OrderByDescending(g => g.Average(DagerSiden)))
                        {
                            <tr>
                                <td>@g.Key</td>
                                <td class="num">@g.Count()</td>
                                <td class="num">@($"{g.Average(DagerSiden):N1}")</td>
                            </tr>
                        }
                        @if (!rows.Any(k => !string.IsNullOrWhiteSpace(k.DelegertBank)))
                        {
                            <tr><td colspan="3" class="empty-row">Ingen delegerte saker i perioden.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <h3 class="stat-subhead" style="margin:20px 0 8px">Per bruker — raskest først (benchmark mot krav)</h3>
        <table class="data-table">
            <thead><tr><th>Bruker</th><th class="num">Eide saker</th><th class="num">Saker/uke</th><th class="num">Gj.snitt dager</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var g in rows.Where(k => !string.IsNullOrWhiteSpace(k.Eier)).GroupBy(k => k.Eier!).OrderBy(g => g.Average(DagerSiden)))
                {
                    var uke = g.Count() / (double)PeriodeDager * 7;
                    var avgD = g.Average(DagerSiden);
                    var raskNok = avgD <= (double)_malDager;
                    var nokSaker = uke >= _malSakerUke;
                    var eierNavn = g.FirstOrDefault()?.EierNavn;
                    <tr>
                        <td>@(string.IsNullOrWhiteSpace(eierNavn) ? g.Key : eierNavn)</td>
                        <td class="num">@g.Count()</td>
                        <td class="num @(nokSaker ? "mal-ok" : "mal-bad")">@($"{uke:N1}")</td>
                        <td class="num @(raskNok ? "mal-ok" : "mal-bad")">@($"{avgD:N1}")</td>
                        <td>@(raskNok && nokSaker ? "✓ Innfrir krav" : raskNok ? "Treg volum" : nokSaker ? "For lang tid" : "Under krav")</td>
                    </tr>
                }
                @if (!rows.Any(k => !string.IsNullOrWhiteSpace(k.Eier)))
                {
                    <tr><td colspan="5" class="empty-row">Ingen aktive eiere i perioden.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @* ---------- Syklustid per bank ---------- *@
    <div class="section widget">
        <h2>Syklustid per bank</h2>
        <p class="page-sub" style="margin:-4px 0 14px">Gjennomsnittlig tid fra åpnet til <strong>fullført og utbetalt</strong>, per bank.</p>
        <table class="data-table">
            <thead><tr><th>Bank</th><th class="num">Fullførte saker</th><th>Syklustid</th><th class="num">Gj.snitt dager</th></tr></thead>
            <tbody>
                @foreach (var b in bankSyklus)
                {
                    <tr>
                        <td>@b.Bank</td>
                        <td class="num">@b.Antall</td>
                        <td>
                            <div class="minibar-cell">
                                <div class="minibar"><div class="minibar-fill" style="width:@((b.Snitt / maxSyklus * 100).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%; background:#0f8a8a"></div></div>
                            </div>
                        </td>
                        <td class="num">@($"{b.Snitt:N1}")</td>
                    </tr>
                }
                @if (bankSyklus.Count == 0)
                {
                    <tr><td colspan="4" class="empty-row">Ingen fullførte saker hos noen bank i perioden.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @* ---------- Cashflow-analyse ---------- *@
    <div class="section widget">
        <h2>Cashflow-analyse</h2>
        <p class="page-sub" style="margin:-4px 0 14px">Forventet provisjonsinngang vektet på sannsynlighet per pipeline-steg.</p>
        <table class="data-table">
            <thead>
                <tr><th>Steg</th><th class="num">Antall</th><th class="num">Lånevolum</th><th class="num">Sannsynlighet</th><th class="num">Forventet provisjon</th></tr>
            </thead>
            <tbody>
                @foreach (var s in _cashflowSteg)
                {
                    var srows = rows.Where(k => k.Status == s).ToList();
                    var svol = srows.Sum(k => k.OnsketLaanebelop ?? 0);
                    var sprov = srows.Sum(Provisjon) * (decimal)Sannsynlighet(s);
                    <tr>
                        <td><span class="vol-dot" style="background:@StatusFarge(s)"></span>@s</td>
                        <td class="num">@srows.Count</td>
                        <td class="num">@($"{svol:N0}") kr</td>
                        <td class="num">@($"{Sannsynlighet(s) * 100:N0}") %</td>
                        <td class="num">@($"{sprov:N0}") kr</td>
                    </tr>
                }
                <tr class="cf-sum">
                    <td>Total forventet cashflow</td>
                    <td class="num">@aktive.Count <span class="muted">+ @fullfort.Count</span></td>
                    <td class="num"></td>
                    <td class="num"></td>
                    <td class="num">@($"{opptjent + forventetProv:N0}") kr</td>
                </tr>
            </tbody>
        </table>
    </div>
}

@code {
    private List<Kundekort> _all = new();
    private List<Partner> _partnere = new();
    private Dictionary<string, Partner> _partnerMap = new();
    private bool _loading = true;

    private string _periode = "30";
    private string _leadskilde = "";
    private string _bankFilter = "";

    // Krav/mål for benchmarking av agenter (lagres i innstillinger).
    private const string KeyMalDager = "mal_dager_per_sak";
    private const string KeyMalSakerUke = "mal_saker_uke";
    private decimal _malDager = 14m;
    private int _malSakerUke = 10;
    private string? _malMsg;

    private async Task SaveMal()
    {
        await Settings.SetAsync(KeyMalDager, _malDager.ToString(System.Globalization.CultureInfo.InvariantCulture));
        await Settings.SetAsync(KeyMalSakerUke, _malSakerUke.ToString());
        _malMsg = "Lagret.";
    }

    private int PeriodeDager => _periode switch
    {
        "7" => 7,
        "90" => 90,
        "ytd" => Math.Max(1, (int)(DateTime.Now.Date - new DateTime(DateTime.Now.Year, 1, 1)).TotalDays + 1),
        "all" => _all.Count == 0 ? 1 : Math.Max(1, (int)(DateTime.Now.Date - _all.Min(k => k.CreatedAt.ToLocalTime().Date)).TotalDays + 1),
        _ => 30,
    };

    private readonly (string Verdi, string Navn)[] _perioder =
    {
        ("7", "7 dager"), ("30", "30 dager"), ("90", "90 dager"), ("ytd", "I år"), ("all", "Alle")
    };

    // Pipeline-steg for cashflow (uten Avslått).
    private readonly string[] _cashflowSteg =
        { "Åpen", "Pågår", "Manuell behandling", "Sendt bank", "Tilbud utsendt", "Fullført og utbetalt" };

    private IEnumerable<string> Leadskilder =>
        _all.Select(k => string.IsNullOrWhiteSpace(k.Kilde) ? "Ukjent" : k.Kilde).Distinct().OrderBy(x => x);

    private List<Kundekort> Rows
    {
        get
        {
            IEnumerable<Kundekort> q = _all;
            if (_periode != "all")
            {
                var fra = _periode switch
                {
                    "7" => DateTime.Now.Date.AddDays(-6),
                    "90" => DateTime.Now.Date.AddDays(-89),
                    "ytd" => new DateTime(DateTime.Now.Year, 1, 1),
                    _ => DateTime.Now.Date.AddDays(-29),
                };
                q = q.Where(k => k.CreatedAt.ToLocalTime().Date >= fra);
            }
            if (!string.IsNullOrEmpty(_leadskilde))
                q = q.Where(k => (string.IsNullOrWhiteSpace(k.Kilde) ? "Ukjent" : k.Kilde) == _leadskilde);
            if (!string.IsNullOrEmpty(_bankFilter))
                q = q.Where(k => k.DelegertBank == _bankFilter);
            return q.ToList();
        }
    }

    private record BankRad(string Navn, int Delegert, int Fullfort, double Konv, decimal Volum, decimal Provisjon);

    private IEnumerable<BankRad> BankRader(List<Kundekort> rows)
    {
        foreach (var p in _partnere)
        {
            var delegert = rows.Where(k => k.DelegertBank == p.Navn).ToList();
            if (delegert.Count == 0) continue;
            var fullf = delegert.Where(k => k.Status == KundekortService.StatusFullfort).ToList();
            yield return new BankRad(
                p.Navn, delegert.Count, fullf.Count,
                delegert.Count == 0 ? 0 : 100.0 * fullf.Count / delegert.Count,
                fullf.Sum(k => k.OnsketLaanebelop ?? 0),
                fullf.Sum(Provisjon));
        }
    }

    private decimal Provisjon(Kundekort k)
    {
        if (!string.IsNullOrWhiteSpace(k.DelegertBank) && _partnerMap.TryGetValue(k.DelegertBank, out var p))
            return (k.OnsketLaanebelop ?? 0) * (ParseDec(p.Provisjon) / 100m) + ParseDec(p.Engangssum);
        return 0;
    }

    // Sannsynlighet for at en søknad ender i utbetaling, per status.
    private static double Sannsynlighet(string status) => status switch
    {
        "Åpen" => 0.10,
        "Pågår" => 0.25,
        "Manuell behandling" => 0.20,
        "Sendt bank" => 0.45,
        "Tilbud utsendt" => 0.70,
        "Fullført og utbetalt" => 1.0,
        _ => 0.0,
    };

    private static string StatusFarge(string status) => status switch
    {
        "Åpen" => "#2f8a3e",
        "Pågår" => "#1f5fc4",
        "Manuell behandling" => "#c2740a",
        "Sendt bank" => "#6b3fc4",
        "Tilbud utsendt" => "#0f8a8a",
        "Fullført og utbetalt" => "#266f32",
        "Avslått" => "#b42318",
        _ => "#9aa0a8",
    };

    // Dager siden siste statusendring (updated_at oppdateres av DB-trigger).
    private static double DagerSiden(Kundekort k) => Math.Max(0, (DateTime.UtcNow - k.UpdatedAt).TotalDays);

    // Syklustid: åpnet (created_at) → fullført (siste endring, updated_at).
    private static double SyklusDager(Kundekort k) => Math.Max(0, (k.UpdatedAt - k.CreatedAt).TotalDays);

    private record BankSyklus(string Bank, int Antall, double Snitt);
    private List<BankSyklus> BankSyklustider(List<Kundekort> rows) =>
        rows.Where(k => k.Status == KundekortService.StatusFullfort && !string.IsNullOrWhiteSpace(k.DelegertBank))
            .GroupBy(k => k.DelegertBank!)
            .Select(g => new BankSyklus(g.Key, g.Count(), g.Average(SyklusDager)))
            .OrderByDescending(x => x.Snitt)
            .ToList();

    private static string LaanetypeFarge(string type) => type switch
    {
        "Forbrukslån" => "#6b3fc4",
        "Refinansiering" => "#1f5fc4",
        "Boliglån" => "#266f32",
        _ => "#9aa0a8",
    };

    private static string Mnok(decimal v) => v >= 1_000_000 ? $"{v / 1_000_000:N0}" : $"{v / 1_000:N0}";
    private static string MnokEnhet(decimal v) => v >= 1_000_000 ? "MNOK" : "kNOK";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        var allTask = Kundekort.ListAsync();
        var partnereTask = Partners.ListAsync();
        var malDagerTask = Settings.GetDecimalAsync(KeyMalDager, 14m);
        var malUkeTask = Settings.GetIntAsync(KeyMalSakerUke, 10);
        await Task.WhenAll(allTask, partnereTask, malDagerTask, malUkeTask);
        _all = allTask.Result;
        _partnere = partnereTask.Result;
        _partnerMap = _partnere.GroupBy(p => p.Navn).ToDictionary(g => g.Key, g => g.First());
        _malDager = malDagerTask.Result;
        _malSakerUke = malUkeTask.Result;
        _loading = false;
    }

    private static decimal ParseDec(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return 0;
        s = s.Replace(" ", "").Replace(",", ".");
        return decimal.TryParse(s, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : 0;
    }
}
