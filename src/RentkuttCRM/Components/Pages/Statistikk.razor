@page "/crm/statistikk"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.KundekortService Kundekort
@inject RentkuttCRM.Services.PartnerService Partners
@inject NavigationManager Nav

<PageTitle>Statistikk — Rentekutt</PageTitle>

<h1 class="page-title">Statistikk</h1>
<p class="page-sub">Konvertering, volum og opptjening.</p>

@if (_loading)
{
    <p class="page-sub">Laster…</p>
}
else
{
    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-value">@_total</div><div class="kpi-label">Søknader</div></div>
        <div class="kpi-card"><div class="kpi-value">@($"{_kvalRate:N0}") %</div><div class="kpi-label">Kvalifiseringsrate (sendt bank)</div></div>
        <div class="kpi-card"><div class="kpi-value">@($"{_closeRate:N0}") %</div><div class="kpi-label">Close rate (fullført)</div></div>
        <div class="kpi-card"><div class="kpi-value">@($"{_formidlet:N0}") kr</div><div class="kpi-label">Formidlet volum (fullført)</div></div>
        <div class="kpi-card"><div class="kpi-value">@($"{_opptjent:N0}") kr</div><div class="kpi-label">Opptjent provisjon (fullført)</div></div>
    </div>

    <div class="section">
        <h2>Konverteringstrakt</h2>
        <div class="funnel">
            @foreach (var f in _funnel)
            {
                <div class="funnel-step">
                    <div class="funnel-bar" style="width:@(_total == 0 ? 0 : 100 * f.Antall / _total)%; min-width:40px">@f.Antall</div>
                    <div class="funnel-label">@f.Navn <span class="muted">(@(_total == 0 ? 0 : 100 * f.Antall / _total) %)</span></div>
                </div>
            }
        </div>
    </div>

    <div class="section">
        <h2>Saker per status</h2>
        <table class="data-table" style="max-width:420px">
            <thead><tr><th>Status</th><th>Antall</th></tr></thead>
            <tbody>
                @foreach (var s in _statuser)
                {
                    <tr><td>@s</td><td class="mono-cell">@_rows.Count(k => k.Status == s)</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Kundekort> _rows = new();
    private bool _loading = true;

    private int _total;
    private double _kvalRate, _closeRate;
    private decimal _formidlet, _opptjent;

    private readonly string[] _statuser = KundekortService.Statuser;
    private record FunnelStep(string Navn, int Antall);
    private List<FunnelStep> _funnel = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        _rows = await Kundekort.ListAsync();
        var partnere = await Partners.ListAsync();

        _total = _rows.Count;

        // Kumulativ funnel: en sak som er "Fullført" har også vært "Sendt bank" osv.
        int Tellfra(params string[] statuser) => _rows.Count(k => statuser.Contains(k.Status));
        var sendt = Tellfra("Sendt bank", "Tilbud utsendt", "Fullført og utbetalt");
        var fullfort = Tellfra(KundekortService.StatusFullfort);

        _kvalRate = _total == 0 ? 0 : 100.0 * sendt / _total;
        _closeRate = _total == 0 ? 0 : 100.0 * fullfort / _total;
        _formidlet = _rows.Where(k => k.Status == KundekortService.StatusFullfort).Sum(k => k.OnsketLaanebelop ?? 0);

        // Opptjent provisjon: per fullført sak, bruk satsen til banken den er delegert til.
        var partnerMap = partnere
            .GroupBy(p => p.Navn).ToDictionary(g => g.Key, g => g.First());
        foreach (var k in _rows.Where(k => k.Status == KundekortService.StatusFullfort))
        {
            if (!string.IsNullOrWhiteSpace(k.DelegertBank) && partnerMap.TryGetValue(k.DelegertBank, out var p))
                _opptjent += (k.OnsketLaanebelop ?? 0) * (ParseDec(p.Provisjon) / 100m) + ParseDec(p.Engangssum);
        }

        _funnel = new()
        {
            new("Søknader", _total),
            new("Kvalifisert", Tellfra("Pågår", "Manuell behandling", "Sendt bank", "Tilbud utsendt", "Fullført og utbetalt")),
            new("Sendt til bank", sendt),
            new("Tilbud utsendt", Tellfra("Tilbud utsendt", "Fullført og utbetalt")),
            new("Fullført", fullfort),
        };

        _loading = false;
    }

    private static decimal ParseDec(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return 0;
        s = s.Replace(" ", "").Replace(",", ".");
        return decimal.TryParse(s, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : 0;
    }
}
