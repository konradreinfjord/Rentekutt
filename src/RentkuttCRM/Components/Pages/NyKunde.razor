@if (KanEndre)
{
    <div class="form-actions">
        <button class="btn-primary" @onclick="Save" disabled="@_saving">@(_saving ? "Lagrer…" : "Lagre kundekort")</button>
        @if (_isEdit)
        {
            @if (!_confirmDelete)
            {
                <button class="btn-danger-solid" @onclick="() => _confirmDelete = true">Slett kundekort</button>
            }
            else
            {
                <span class="confirm-text">Sikker? Dette kan ikke angres.</span>
                <button class="btn-danger-solid" @onclick="Delete">Ja, slett permanent</button>
                <button class="btn-logout" @onclick="() => _confirmDelete = false">Avbryt</button>
            }
        }
        @if (!string.IsNullOrEmpty(_msg))
        {
            <span class="form-msg @(_ok ? "ok" : "err")">@_msg</span>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? Id { get; set; }

    private Kundekort _k = new();
    private bool _isEdit;
    private bool _saving;
    private bool _ok;
    private string? _msg;
    private bool _confirmDelete;
    private BeregningParametre _berParams = BeregningService.Standard;
    private bool _visBreakdown;

    private List<SmsMal> _smsMaler = new();
    private string _smsTekst = "";
    private string? _smsMsg;
    private bool _smsOk, _smsSending;

    // Notatlogg
    private List<Saksnotat> _notatLogg = new();
    private bool _visNyttNotat;
    private string _nyttNotat = "";
    private bool _notatLagrer;

    private static string Vis(string? s) => string.IsNullOrWhiteSpace(s) ? "—" : s;

    private static string StatusKlasse(string s) => s switch
    {
        "Åpen" => "st-apen", "Pågår" => "st-pagar", "Manuell behandling" => "st-manuell",
        "Sendt bank" => "st-sendt", "Tilbud utsendt" => "st-tilbud",
        "Fullført og utbetalt" => "st-fullfort", "Avslått" => "st-avslatt", _ => "",
    };

    // Hurtiglagring av bank + nåværende rente (mates til Markedsinnsikt).
    private bool _bankRenteLagrer;
    private string? _bankRenteMsg;
    private async Task LagreBankRente()
    {
        if (!KanEndre) return;
        if (_k.Id == Guid.Empty) return;
        _bankRenteLagrer = true;
        _bankRenteMsg = null;
        await Svc.SetBankRenteAsync(_k.Id, _k.NavarendeBank, _k.NaavaerendeRente);
        _bankRenteMsg = "Lagret ✓";
        _bankRenteLagrer = false;
        StateHasChanged();
        await Task.Delay(1600);
        _bankRenteMsg = null;
    }

    private async Task LagreNotat()
    {
        if (!KanEndre) return;
        if (string.IsNullOrWhiteSpace(_nyttNotat) || _k.Id == Guid.Empty) return;
        _notatLagrer = true;
        var ok = await Notater.AddAsync(_k.Id, _nyttNotat,
            Session.Email ?? Session.UserName, Session.UserName ?? Session.Email);
        if (ok)
        {
            _notatLogg = await Notater.ListAsync(_k.Id);
            _nyttNotat = "";
            _visNyttNotat = false;
        }
        _notatLagrer = false;
    }

    private void VelgMal(ChangeEventArgs e)
    {
        var navn = e.Value?.ToString();
        var mal = _smsMaler.FirstOrDefault(m => m.Navn == navn);
        if (mal is not null) _smsTekst = mal.Tekst;
    }

    private async Task SendSms()
    {
        if (!KanEndre) return;
        _smsSending = true;
        _smsMsg = null;
        var (ok, detalj) = await SmsMaler.SendTilKundeAsync(_k.Mobilnummer, _smsTekst, _k.FulltNavn);
        _smsOk = ok;
        _smsMsg = ok ? "SMS sendt ✓" : $"Kunne ikke sende: {detalj}";
        _smsSending = false;
    }

    private async Task Delete()
    {
        if (!KanEndre) return;
        var (ok, error) = await Svc.DeleteAsync(_k.Id);
        if (!ok)
        {
            _confirmDelete = false;
            _ok = false;
            _msg = error ?? "Kunne ikke slette kundekortet.";
            return;
        }
        // Tilbake til markedet kunden hører til — ikke den skjulte Database-fanen.
        Nav.NavigateTo(_k.KundeType == "B2B" ? "/crm/marked/bedrift" : "/crm/marked/person");
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

        // Kortuavhengige oppslag + selve kortet hentes i parallell (var 3–6 sekvensielle
        // rundturer før — hovedårsaken til at kundekort var tregt å åpne).
        var berTask = Beregning.HentParametreAsync();
        var smsTask = SmsMaler.ListAsync();
        var bankerTask = Partners.ListAsync();
        var kortTask = Guid.TryParse(Id, out var caseId) ? Svc.GetAsync(caseId) : Task.FromResult<Kundekort?>(null);

        await Task.WhenAll(berTask, smsTask, bankerTask, kortTask);
        _berParams = berTask.Result;
        _smsMaler = smsTask.Result;
        _banker = bankerTask.Result;

        if (kortTask.Result is { } existing)
        {
            _k = existing; _isEdit = true; _laast = true;
            // Notater + banksendinger avhenger av kort-id — hentes i parallell.
            var notatTask = Notater.ListAsync(_k.Id);
            var sendTask = BankSending.ForKundeAsync(_k.Id);
            await Task.WhenAll(notatTask, sendTask);
            _notatLogg = notatTask.Result;
            _sendinger = sendTask.Result;
        }
    }

    // ---- Send til bank ----
    private List<Partner> _banker = new();
    private List<BankSending> _sendinger = new();
    private string _valgtBank = "";
    private bool _sender;
    private string? _sendMsg;
    private bool _sendOk;

    private async Task SendTilBank()
    {
        if (!KanEndre) return;
        if (_k.Id == Guid.Empty || string.IsNullOrWhiteSpace(_valgtBank)) return;
        _sender = true;
        _sendMsg = null;
        var avsender = Session.UserName ?? Session.Email ?? "ukjent";

        // Legges i sikker sendekø — en throttlet bakgrunnsarbeider sender til bank,
        // så vi aldri bombarderer API-et. Status oppdateres når den er behandlet.
        var s = new BankSending
        {
            KundekortId = _k.Id,
            KundeNavn = _k.FulltNavn,
            Bank = _valgtBank,
            SendtAv = avsender,
            Status = SendStatus.IKo,
            Detalj = "Lagt i sendekø.",
        };
        var lagret = await BankSending.LoggAsync(s);
        _sendinger.Insert(0, lagret);

        // Speil valget i «Delegert til bank» på kundekortet.
        if (string.IsNullOrWhiteSpace(_k.DelegertBank))
        {
            _k.DelegertBank = _valgtBank;
            await Svc.SetDelegertBankAsync(_k.Id, _valgtBank);
        }

        _sendOk = true;
        _sendMsg = $"{_valgtBank}: lagt i kø — sendes automatisk ✓";
        _sender = false;
    }

    private static string SendtKlasse(string? status) => status switch
    {
        SendStatus.Feilet => "err",
        SendStatus.IKo => "pending",
        _ => "on",
    };

    // Feltene er låst på et eksisterende kundekort — dobbeltklikk for å redigere.
    private bool _laast;
    private void LaasOpp() { if (KanEndre) _laast = false; }

    // Endringsrett: admin kan alltid; ellers må saken være uten eier eller eid av deg.
    // Eies saken av en annen, er den skrivebeskyttet (kun lesing).
    private bool EierAnnen => _isEdit && !string.IsNullOrWhiteSpace(_k.Eier)
        && !string.Equals(_k.Eier, Session.Email, StringComparison.OrdinalIgnoreCase)
        && !string.Equals(_k.Eier, Session.UserName, StringComparison.OrdinalIgnoreCase);
    private bool KanEndre => Session.IsAdmin || !EierAnnen;

    // Lukk saken og gå tilbake til oversikten agenten kom fra.
    private async Task Tilbake()
    {
        try { await JS.InvokeVoidAsync("history.back"); }
        catch { Nav.NavigateTo("/crm/database"); }
    }

    private string Behovssammendrag
    {
        get
        {
            var deler = new List<string>();
            deler.Add(_k.KundeType == "B2B" ? "Bedrift" : "Privatperson");
            if (!string.IsNullOrWhiteSpace(_k.Laanetype)) deler.Add($"ønsker {_k.Laanetype.ToLower()}");
            if (_k.OnsketLaanebelop is > 0) deler.Add($"på {_k.OnsketLaanebelop:N0} kr");
            if (_k.OnsketLopetidMnd is > 0) deler.Add($"over {_k.OnsketLopetidMnd} mnd");
            var s = string.Join(" ", deler) + ".";
            if (!string.IsNullOrWhiteSpace(_k.NavarendeBank)) s += $" Nåværende bank: {_k.NavarendeBank}.";
            return s;
        }
    }

    private async Task Save()
    {
        if (!KanEndre) return;
        _saving = true;
        _msg = null;
        // B2B: orgnr er egen kolonne, men kunde_id speiler det for gruppering.
        if (_k.KundeType == "B2B" && !string.IsNullOrWhiteSpace(_k.Orgnr))
        {
            _k.Orgnr = new string(_k.Orgnr.Where(char.IsDigit).ToArray());
            if (string.IsNullOrWhiteSpace(_k.KundeId)) _k.KundeId = _k.Orgnr;
        }
        // Tillat enten fødselsnr/orgnr eller mobilnummer som identifikator.
        if (string.IsNullOrWhiteSpace(_k.KundeId) && !string.IsNullOrWhiteSpace(_k.Mobilnummer))
            _k.KundeId = new string(_k.Mobilnummer.Where(char.IsDigit).ToArray());
        if (string.IsNullOrWhiteSpace(_k.KundeId))
        {
            _ok = false;
            _msg = "Oppgi fødselsnummer/orgnr eller mobilnummer.";
            _saving = false;
            return;
        }
        if (_k.Id == Guid.Empty && string.IsNullOrWhiteSpace(_k.Kilde)) _k.Kilde = "Manuell";
        var (ok, error) = await Svc.SaveAsync(_k, strict: false);
        _ok = ok;
        if (ok)
        {
            _msg = "Kundekort lagret.";
            _isEdit = true;
        }
        else
        {
            _msg = error ?? "Kunne ikke lagre.";
        }
        _saving = false;
    }
}
