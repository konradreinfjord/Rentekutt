@page "/crm/ny-kunde"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.KundekortService Svc
@inject RentkuttCRM.Services.BeregningService Beregning
@inject RentkuttCRM.Services.SmsMalService SmsMaler
@inject RentkuttCRM.Services.NotatService Notater
@inject RentkuttCRM.Services.PartnerService Partners
@inject RentkuttCRM.Services.InstabankService Instabank
@inject RentkuttCRM.Services.BankSendingService BankSending
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Ny kunde — Rentekutt</PageTitle>

<div class="kort-topp">
    @if (_isEdit)
    {
        <button class="btn-back" @onclick="Tilbake" title="Lukk sak og gå tilbake til oversikten">← Tilbake</button>
    }
    <div>
        <h1 class="page-title">@(_isEdit ? "Kundekort" : "Ny kunde")</h1>
        <p class="page-sub">Lånesøknad med kunde- og lånedata.</p>
    </div>
</div>

@* Samlet kundeinfo øverst — se hvem kunden er med én gang *@
<div class="kunde-header">
    <div class="kunde-header-top">
        <span class="kunde-navn">@(string.IsNullOrWhiteSpace(_k.FulltNavn) ? "Ny kunde" : _k.FulltNavn)</span>
        <span class="type-tag @(_k.KundeType == "B2C" ? "lead" : "bank")">@(_k.KundeType == "B2C" ? "Privat" : "Bedrift")</span>
        @if (_isEdit) { <span class="status-pill @StatusKlasse(_k.Status)">@_k.Status</span> }
        @if (!string.IsNullOrWhiteSpace(_k.Kilde)) { <span class="kilde-badge @KundekortService.KildeBadgeKlasse(_k.Kilde)">@_k.Kilde</span> }
    </div>
    <div class="kunde-facts">
        <div class="kunde-fact"><span class="kf-lbl">Telefon</span><span class="kf-val mono">@Vis(_k.Mobilnummer)</span></div>
        <div class="kunde-fact"><span class="kf-lbl">E-post</span><span class="kf-val">@Vis(_k.Epost)</span></div>
        <div class="kunde-fact"><span class="kf-lbl">@(_k.KundeType == "B2B" ? "Orgnr" : "Personnr")</span><span class="kf-val mono">@Vis(_k.KundeType == "B2B" ? _k.Orgnr : (string.IsNullOrWhiteSpace(_k.Foedselsnummer) ? _k.KundeId : _k.Foedselsnummer))</span></div>
        <div class="kunde-fact"><span class="kf-lbl">Adresse</span><span class="kf-val">@Vis(_k.Adresse)</span></div>
        <div class="kunde-fact"><span class="kf-lbl">Poststed</span><span class="kf-val">@Vis($"{_k.Postnummer} {_k.Poststed}".Trim())</span></div>
        <div class="kunde-fact"><span class="kf-lbl">Kommune</span><span class="kf-val">@Vis(_k.Kommune)</span></div>
        <div class="kunde-fact"><span class="kf-lbl">Ønsket beløp</span><span class="kf-val">@(_k.OnsketLaanebelop.HasValue ? $"{_k.OnsketLaanebelop:N0} kr" : "—")</span></div>
        <div class="kunde-fact"><span class="kf-lbl">Nåværende bank</span><span class="kf-val">@Vis(_k.NavarendeBank)</span></div>
    </div>
</div>

@* Hurtigregistrering: kundens bank + nåværende rente (mates til Markedsinnsikt) *@
<div class="form-card rente-quick">
    <div class="rq-row">
        <div class="ff"><label>Kundens bank</label><input @bind="_k.NavarendeBank" placeholder="f.eks. DNB" /></div>
        <div class="ff"><label>Nåværende rente (%)</label><input type="number" step="0.01" @bind="_k.NaavaerendeRente" placeholder="f.eks. 6,25" /></div>
        <button class="btn-primary btn-sm" @onclick="LagreBankRente" disabled="@(_bankRenteLagrer || !_isEdit || !KanEndre)"
                title="@(_isEdit ? "" : "Lagre kundekortet først")">@(_bankRenteLagrer ? "Lagrer…" : "Lagre bank & rente")</button>
        @if (!string.IsNullOrEmpty(_bankRenteMsg)) { <span class="form-msg ok">@_bankRenteMsg</span> }
    </div>
    <p class="page-sub rq-hint">Registreres til Markedsinnsikt — gir oss rentenivå per bank over tid.</p>
</div>

@* Send søknaden til en bankpartner *@
<div class="form-card send-bank">
    <h2>Send til bank</h2>
    <p class="page-sub" style="margin:-4px 0 12px">Send denne søknaden til en bankpartner. Instabank sendes via API; andre banker registreres som manuelt videresendt.</p>
    <div class="rq-row">
        <div class="ff" style="min-width:200px">
            <label>Bank</label>
            <select @bind="_valgtBank" disabled="@(!_isEdit || !KanEndre)">
                <option value="">— velg bank —</option>
                @foreach (var b in _banker) { <option value="@b.Navn">@b.Navn@(InstabankService.ErInstabankNavn(b.Navn) ? " (API)" : "")</option> }
            </select>
        </div>
        <button class="btn-primary btn-sm" @onclick="SendTilBank"
                disabled="@(_sender || !_isEdit || !KanEndre || string.IsNullOrWhiteSpace(_valgtBank))"
                title="@(_isEdit ? "" : "Lagre kundekortet først")">@(_sender ? "Sender…" : "Send til bank")</button>
        @if (!string.IsNullOrEmpty(_sendMsg)) { <span class="form-msg @(_sendOk ? "ok" : "err")">@_sendMsg</span> }
    </div>

    @if (_sendinger.Count > 0)
    {
        <div class="sendt-logg">
            <h3 class="ww-h" style="margin:14px 0 8px">Sendt til bank</h3>
            <table class="data-table">
                <thead><tr><th>Tidspunkt</th><th>Bank</th><th>Status</th><th>Referanse</th><th></th></tr></thead>
                <tbody>
                    @foreach (var s in _sendinger)
                    {
                        <tr>
                            <td class="mono-cell">@s.SendtAt.TilOslo().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@s.Bank</td>
                            <td><span class="status @SendtKlasse(s.Status)">@s.Status</span>@(string.IsNullOrWhiteSpace(s.SendtAv) ? "" : $" · {s.SendtAv}")</td>
                            <td class="mono-cell">@(string.IsNullOrWhiteSpace(s.EksternRef) ? "—" : s.EksternRef)</td>
                            <td>@if (!string.IsNullOrWhiteSpace(s.SigningUrl)) { <a href="@s.SigningUrl" target="_blank" rel="noopener" class="btn-sm">Signeringslenke</a> }</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Tidsstemplet notatlogg *@
<div class="form-card note-card">
    <div style="display:flex; justify-content:space-between; align-items:center">
        <h2 style="margin:0">Notatlogg</h2>
        @if (!_visNyttNotat)
        {
            <button class="btn-primary btn-sm" @onclick="() => _visNyttNotat = true" disabled="@(!_isEdit || !KanEndre)"
                    title="@(!KanEndre ? "Skrivebeskyttet — du eier ikke saken" : _isEdit ? "" : "Lagre kundekortet først")">+ Nytt notat</button>
        }
    </div>
    @if (!_isEdit)
    {
        <p class="page-sub" style="margin:8px 0 0; font-size:12px">Lagre kundekortet først for å legge til notater.</p>
    }
    @if (_visNyttNotat)
    {
        <textarea class="note-area" style="margin-top:10px" @bind="_nyttNotat" placeholder="Skriv notat — hva ble avtalt, hva skjedde i samtalen…"></textarea>
        <div style="display:flex; gap:10px; align-items:center; margin-top:10px">
            <button class="btn-primary" @onclick="LagreNotat" disabled="@_notatLagrer">@(_notatLagrer ? "Lagrer…" : "Lagre notat")</button>
            <button class="btn-logout" @onclick="() => { _visNyttNotat = false; _nyttNotat = string.Empty; }">Avbryt</button>
            <span class="page-sub" style="margin:0; font-size:12px">Dato og klokkeslett registreres automatisk.</span>
        </div>
    }
    <div style="margin-top:12px">
        @if (!string.IsNullOrWhiteSpace(_k.Notater))
        {
            <div class="notat-item">
                <div class="notat-meta"><span class="notat-forfatter">Tidligere notat</span></div>
                <div class="notat-tekst">@_k.Notater</div>
            </div>
        }
        @if (_notatLogg.Count == 0 && string.IsNullOrWhiteSpace(_k.Notater))
        {
            <p class="notat-empty">Ingen notater ennå.</p>
        }
        @foreach (var n in _notatLogg)
        {
            <div class="notat-item">
                <div class="notat-meta">
                    <span class="notat-tid">@n.Opprettet.TilOslo().ToString("dd.MM.yyyy HH:mm")</span>
                    @if (!string.IsNullOrWhiteSpace(n.ForfatterNavn)) { <span class="notat-forfatter">@n.ForfatterNavn</span> }
                </div>
                <div class="notat-tekst">@n.Tekst</div>
            </div>
        }
    </div>
</div>

<div class="form-card summary-top">
    <h2>Kundens behov</h2>
    <p style="margin:0; color:var(--text-2)">@Behovssammendrag</p>
</div>

@{
    var (ber, linjer) = BeregningService.Detaljert(_k, _berParams);
    var (alderS, kjS) = BeregningService.FnrInfo(_k.Foedselsnummer);
    var (alderM, kjM) = BeregningService.FnrInfo(_k.MedsokerFoedselsnummer);
}
<div class="form-card beregn-card">
    <div style="display:flex; justify-content:space-between; align-items:center">
        <h2 style="margin:0">Beregningsmodell</h2>
        <button type="button" class="btn-link" @onclick="() => _visBreakdown = !_visBreakdown">
            @(_visBreakdown ? "Skjul breakdown ▲" : "Vis full breakdown ▼")
        </button>
    </div>
    <p class="page-sub" style="margin:8px 0 12px">
        Søker: @(alderS is int sa ? $"{sa} år ({(kjS == 'M' ? "M" : "K")})" : "alder ukjent")@*
        *@@(_k.HarMedsoker || alderM is not null ? $" · Medsøker: {(alderM is int ma ? $"{ma} år ({(kjM == 'M' ? "M" : "K")})" : "alder ukjent")}" : "")@*
        *@ · @(_k.AntallBarnUnder18 ?? 0) barn@(_k.AntallBiler is int biler && biler > 0 ? $" · {biler} bil" : "")
    </p>
    <div class="db-stats">
        <div class="db-box @(ber.Likviditet >= 0 ? "accent-green" : "")"><span class="db-box-num">@($"{ber.Likviditet:N0}")</span><span class="db-box-lbl">Likviditet/mnd</span></div>
        <div class="db-box"><span class="db-box-num">@($"{ber.Belaningsgrad:N1}") %</span><span class="db-box-lbl">Belåningsgrad</span></div>
        <div class="db-box"><span class="db-box-num">@($"{ber.Gjeldsgrad:N1}")×</span><span class="db-box-lbl">Gjeldsgrad</span></div>
        <div class="db-box"><span class="db-box-num">@($"{ber.MaksLaan:N0}")</span><span class="db-box-lbl">Maks lån</span></div>
    </div>

    @if (_visBreakdown)
    {
        <table class="breakdown-tbl">
            <thead><tr><th>Komponent</th><th>Kildefelt</th><th>Formel</th><th class="num">Beløp/mnd</th></tr></thead>
            <tbody>
                @foreach (var grp in linjer.GroupBy(l => l.Seksjon))
                {
                    <tr class="brk-seksjon"><td colspan="4">@grp.Key</td></tr>
                    @foreach (var l in grp)
                    {
                        <tr class="@(l.ErSum ? "brk-sum" : "")">
                            <td>@l.Komponent</td>
                            <td class="brk-kilde">@l.Kilde</td>
                            <td class="brk-formel">@l.Formel</td>
                            <td class="num">@($"{l.Belop:N0}") kr</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="kv-list" style="margin-top:12px; grid-template-columns:220px 1fr">
            <span class="k">Netto månedsinntekt</span><span class="v">@($"{ber.MndInntektNetto:N0}") kr</span>
            <span class="k">− Levekostnad (SIFO)</span><span class="v">@($"{ber.Levekostnad:N0}") kr</span>
            <span class="k">− Boligkostnad</span><span class="v">@($"{ber.Boligkostnad:N0}") kr</span>
            <span class="k">− Gjeldsbetjening (stresstestet)</span><span class="v">@($"{ber.Gjeldsbetjening:N0}") kr</span>
            <span class="k">= Fri likviditet</span><span class="v"><strong>@($"{ber.Likviditet:N0}") kr</strong></span>
        </div>
    }
</div>

@* Send SMS til kunde *@
<div class="form-card">
    <h2>Send SMS til kunde</h2>
    <p class="page-sub" style="margin:-4px 0 12px">Til: <strong>@(string.IsNullOrWhiteSpace(_k.Mobilnummer) ? "— mangler mobilnummer —" : _k.Mobilnummer)</strong>. Bruk <code>{navn}</code> for kundens fornavn.</p>
    <div class="form-grid">
        <div class="ff">
            <label>Velg mal (valgfritt)</label>
            <select @onchange="VelgMal">
                <option value="">— fri tekst —</option>
                @foreach (var m in _smsMaler) { <option value="@m.Navn">@m.Navn</option> }
            </select>
        </div>
    </div>
    <textarea class="note-area" style="margin-top:12px; min-height:80px" @bind="_smsTekst" placeholder="Skriv meldingen her, eller velg en mal over…"></textarea>
    <div style="display:flex; align-items:center; gap:12px; margin-top:12px">
        <button class="btn-primary" @onclick="SendSms" disabled="@(_smsSending || !KanEndre || string.IsNullOrWhiteSpace(_k.Mobilnummer))">@(_smsSending ? "Sender…" : "Send SMS")</button>
        @if (!string.IsNullOrEmpty(_smsMsg)) { <span class="form-msg @(_smsOk ? "ok" : "err")">@_smsMsg</span> }
    </div>
</div>

@if (_isEdit && !KanEndre)
{
    <div class="las-bar laast">
        <span>🔒 Skrivebeskyttet — saken eies av <strong>@(_k.EierNavn ?? _k.Eier)</strong>. Kun eier eller admin kan endre. Du kan lese, men må eie saken for å redigere.</span>
    </div>
}
else if (_isEdit)
{
    <div class="las-bar @(_laast ? "laast" : "aapen")" @ondblclick="LaasOpp">
        @if (_laast)
        {
            <span>🔒 Feltene er låst — <strong>dobbeltklikk</strong> for å redigere</span>
        }
        else
        {
            <span>🔓 Redigering aktiv</span>
            <button class="btn-sm" @onclick="() => _laast = true" @onclick:stopPropagation="true">Lås igjen</button>
        }
    </div>
}

<div class="kort-felter @(_isEdit && (_laast || !KanEndre) ? "laast" : "")" @ondblclick="LaasOpp">
@* Kundetype *@
<div class="form-card">
    <h2>Kundetype</h2>
    <div class="seg">
        <button class="@(_k.KundeType == "B2C" ? "active" : "")" @onclick='() => _k.KundeType = "B2C"'>B2C — privatperson</button>
        <button class="@(_k.KundeType == "B2B" ? "active" : "")" @onclick='() => _k.KundeType = "B2B"'>B2B — bedrift</button>
    </div>
    <div class="form-grid" style="margin-top:16px">
        <div class="ff">
            <label>@(_k.KundeType == "B2B" ? "Organisasjonsnummer" : "Fødselsnummer") <span class="muted">(valgfritt hvis mobil oppgis)</span></label>
            @if (_k.KundeType == "B2B")
            {
                <input @bind="_k.Orgnr" disabled="@_isEdit" placeholder="9 siffer" />
            }
            else
            {
                <input @bind="_k.KundeId" disabled="@_isEdit" placeholder="11 siffer" />
            }
        </div>
    </div>
</div>

@* Tjeneste & samtykke *@
<div class="form-card">
    <h2>Tjeneste & samtykke</h2>
    <div class="form-grid">
        <div class="ff"><label>Tjeneste</label><input @bind="_k.Tjeneste" /></div>
        <div class="ff" style="justify-content:flex-end"><label class="ff-check"><input type="checkbox" @bind="_k.SamtykkeGjeldsregisterKredittsjekk" /> Samtykke til Gjeldsregister & kredittsjekk</label></div>
    </div>
</div>

@* G. Lånedetaljer (ofte først) *@
<div class="form-card">
    <h2>Lånedetaljer</h2>
    <div class="form-grid">
        <div class="ff">
            <label>Lånetype / formål</label>
            <select @bind="_k.Laanetype">
                <option value="">— velg —</option>
                @foreach (var t in KundekortService.Laanetyper) { <option value="@t">@t</option> }
            </select>
        </div>
        <div class="ff"><label>Ønsket lånebeløp (kr)</label><input type="number" @bind="_k.OnsketLaanebelop" /></div>
        <div class="ff"><label>Ønsket nedbetalingstid (mnd)</label><input type="number" @bind="_k.OnsketLopetidMnd" /></div>
        <div class="ff"><label>Låneformål</label><input @bind="_k.Laaneformal" /></div>
        <div class="ff"><label>Nåværende bank</label><input @bind="_k.NavarendeBank" /></div>
        <div class="ff"><label>Nåværende rente (%)</label><input type="number" step="0.01" @bind="_k.NaavaerendeRente" /></div>
        <div class="ff"><label>Boligverdi (kr) — for belåningsgrad</label><input type="number" @bind="_k.Boligverdi" /></div>
    </div>
</div>

@* A. Søker *@
<div class="form-card">
    <h2>A · Søker</h2>
    <div class="form-grid">
        <div class="ff wide"><label>Fullt navn</label><input @bind="_k.FulltNavn" placeholder="Hentes ev. fra Vipps" /></div>
        <div class="ff"><label>Mobilnummer</label><input @bind="_k.Mobilnummer" /></div>
        <div class="ff"><label>E-postadresse</label><input @bind="_k.Epost" /></div>
        <div class="ff wide"><label>Adresse</label><input @bind="_k.Adresse" /></div>
        <div class="ff"><label>Postnummer</label><input @bind="_k.Postnummer" /></div>
        <div class="ff"><label>Poststed</label><input @bind="_k.Poststed" /></div>
        <div class="ff"><label>Kommune</label><input @bind="_k.Kommune" /></div>
    </div>
</div>

@* B. Medsøker *@
<div class="form-card">
    <h2>B · Medsøker</h2>
    <label class="ff-check"><input type="checkbox" @bind="_k.HarMedsoker" /> Søknaden har medsøker</label>
    @if (_k.HarMedsoker)
    {
        <div class="form-grid" style="margin-top:16px">
            <div class="ff wide"><label>Fullt navn</label><input @bind="_k.MedsokerNavn" /></div>
            <div class="ff"><label>Fødselsnummer</label><input @bind="_k.MedsokerFoedselsnummer" /></div>
            <div class="ff"><label>Mobilnummer</label><input @bind="_k.MedsokerMobil" /></div>
            <div class="ff"><label>E-post</label><input @bind="_k.MedsokerEpost" /></div>
            <div class="ff wide"><label>Adresse</label><input @bind="_k.MedsokerAdresse" /></div>
            <div class="ff"><label>Postnummer</label><input @bind="_k.MedsokerPostnummer" /></div>
            <div class="ff"><label>Poststed</label><input @bind="_k.MedsokerPoststed" /></div>
            <div class="ff"><label>Egen årsinntekt (kr)</label><input type="number" @bind="_k.MedsokerInntekt" /></div>
            <div class="ff"><label>Arbeidsforhold</label><input @bind="_k.MedsokerArbeidsforhold" /></div>
        </div>
    }
</div>

@* C. Husholdning *@
<div class="form-card">
    <h2>C · Husholdning</h2>
    <div class="form-grid">
        <div class="ff"><label>Statsborgerskap</label><input @bind="_k.Statsborgerskap" /></div>
        <div class="ff"><label>Opprinnelsesland</label><input @bind="_k.Opprinnelsesland" /></div>
        <div class="ff"><label>År bodd i Norge</label><input type="number" @bind="_k.AarBoddINorge" /></div>
        <div class="ff">
            <label>Sivilstatus</label>
            <select @bind="_k.Sivilstatus">
                <option value="">— velg —</option>
                @foreach (var s in KundekortService.Sivilstatuser) { <option value="@s">@s</option> }
            </select>
        </div>
        <div class="ff"><label>Antall barn under 18</label><input type="number" @bind="_k.AntallBarnUnder18" /></div>
        <div class="ff">
            <label>Boforhold</label>
            <select @bind="_k.Boforhold">
                <option value="">— velg —</option>
                @foreach (var b in KundekortService.Boforhold) { <option value="@b">@b</option> }
            </select>
        </div>
        <div class="ff"><label>Botid nåværende adresse (mnd)</label><input type="number" @bind="_k.BotidMnd" /></div>
        <div class="ff"><label>Antall biler</label><input type="number" @bind="_k.AntallBiler" /></div>
    </div>
</div>

@* D. Arbeid og inntekt *@
<div class="form-card">
    <h2>D · Arbeid og inntekt</h2>
    <div class="form-grid">
        <div class="ff">
            <label>Arbeidssituasjon</label>
            <select @bind="_k.Arbeidssituasjon">
                <option value="">— velg —</option>
                @foreach (var a in KundekortService.Arbeidssituasjoner) { <option value="@a">@a</option> }
            </select>
        </div>
        <div class="ff"><label>Arbeidsgiver</label><input @bind="_k.Arbeidsgiver" /></div>
        <div class="ff"><label>Ansiennitet (mnd)</label><input type="number" @bind="_k.AnsiennitetMnd" /></div>
        <div class="ff"><label>Utdanning (nivå)</label><input @bind="_k.Utdanning" /></div>
        <div class="ff"><label>Årsinntekt før skatt (kr)</label><input type="number" @bind="_k.AarsinntektBrutto" /></div>
        <div class="ff"><label>Andre inntekter (kr)</label><input type="number" @bind="_k.AndreInntekter" /></div>
        <div class="ff" style="justify-content:flex-end"><label class="ff-check"><input type="checkbox" @bind="_k.HarAndreInntekter" /> Har andre inntekter</label></div>
        <div class="ff"><label>Ektefelle/samboers årsinntekt (kr)</label><input type="number" @bind="_k.EktefelleInntekt" /></div>
        <div class="ff" style="justify-content:flex-end"><label class="ff-check"><input type="checkbox" @bind="_k.HarEktefelleSamboerInntekt" /> Har ektefelle/samboer-inntekt</label></div>
    </div>
</div>

@* E. Utgifter og forpliktelser *@
<div class="form-card">
    <h2>E · Utgifter og forpliktelser</h2>
    <div class="form-grid">
        <div class="ff"><label>Husleie / boligkostnad per mnd (kr)</label><input type="number" @bind="_k.BoligkostnadMnd" /></div>
        <div class="ff"><label>Barnebidrag betalt per mnd (kr)</label><input type="number" @bind="_k.BarnebidragBetaltMnd" /></div>
        <div class="ff" style="justify-content:flex-end"><label class="ff-check"><input type="checkbox" @bind="_k.BetalerBarnebidrag" /> Betaler barnebidrag</label></div>
    </div>
</div>

