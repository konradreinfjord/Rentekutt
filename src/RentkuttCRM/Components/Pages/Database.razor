@page "/crm/database"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.KundekortService Svc
@inject NavigationManager Nav

<PageTitle>Database — Rentekutt</PageTitle>

<h1 class="page-title">Database</h1>
<p class="page-sub">Alle kundekort og lånesøknader.</p>

<div class="db-toolbar">
    <button class="btn-primary" @onclick='() => Nav.NavigateTo("/crm/ny-kunde")'>+ Opprett kunde</button>
    <input class="db-search" @bind="_search" @bind:event="oninput" placeholder="Søk navn, kunde-ID eller lånetype" />
    <select class="db-select" @bind="_statusFilter">
        <option value="">Alle statuser</option>
        @foreach (var s in _statuses) { <option value="@s">@s</option> }
    </select>
    <select class="db-select" @bind="_typeFilter">
        <option value="">Alle typer</option>
        <option value="B2C">B2C</option>
        <option value="B2B">B2B</option>
    </select>
    <div class="db-spacer"></div>
    <span class="db-count">@View.Count av @_rows.Count</span>
</div>

<div class="db-stats">
    <div class="db-box"><span class="db-box-num">@View.Count</span><span class="db-box-lbl">saker</span></div>
    <div class="db-box"><span class="db-box-num">@($"{View.Sum(k => k.OnsketLaanebelop ?? 0) / 1_000_000:N1}") mill</span><span class="db-box-lbl">samlet</span></div>
    <div class="db-box"><span class="db-box-num">@View.Count(k => k.KundeType == "B2C")</span><span class="db-box-lbl">B2C</span></div>
    <div class="db-box"><span class="db-box-num">@View.Count(k => k.KundeType == "B2B")</span><span class="db-box-lbl">B2B</span></div>
    @foreach (var g in View.GroupBy(k => k.Status).OrderByDescending(g => g.Count()).Take(4))
    {
        <div class="db-box"><span class="db-box-num">@g.Count()</span><span class="db-box-lbl">@g.Key</span></div>
    }
</div>

@if (_loading)
{
    <p class="page-sub">Laster…</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                @Header("id", "Kunde-ID")
                <th>Status</th>
                @Header("navn", "Navn")
                @Header("type", "Type")
                @Header("laanetype", "Lånetype")
                @Header("belop", "Ønsket beløp")
                @Header("opprettet", "Opprettet")
                @Header("eier", "Eier")
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (View.Count == 0)
            {
                <tr><td colspan="9" class="empty-row">Ingen treff.</td></tr>
            }
            @foreach (var k in View)
            {
                <tr>
                    <td class="mono-cell">
                        @k.KundeId
                        @if (CaseCount(k.KundeId) > 1)
                        {
                            <span class="multi-badge" title="@CaseCount(k.KundeId) saker på denne kunden">@CaseCount(k.KundeId) saker</span>
                        }
                    </td>
                    <td>
                        <select class="inline-select" @onchange="e => ChangeStatus(k, e)">
                            @foreach (var s in _statuses) { <option value="@s" selected="@(s == k.Status)">@s</option> }
                        </select>
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(k.FulltNavn) ? "—" : k.FulltNavn)</td>
                    <td><span class="type-tag @(k.KundeType == "B2C" ? "lead" : "bank")">@k.KundeType</span></td>
                    <td>@(string.IsNullOrWhiteSpace(k.Laanetype) ? "—" : k.Laanetype)</td>
                    <td>@(k.OnsketLaanebelop.HasValue ? $"{k.OnsketLaanebelop:N0} kr" : "—")</td>
                    <td>@Dt(k.CreatedAt)</td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(k.Eier))
                        {
                            <button class="btn-sm" @onclick="() => TakeOwnership(k)">Ta eierskap</button>
                        }
                        else
                        {
                            <span>@(k.Eier == Session.Email ? "Deg" : k.EierNavn ?? k.Eier)</span>
                        }
                    </td>
                    <td><button class="btn-sm" @onclick="() => Open(k.Id)">Åpne</button></td>
                </tr>
            }
        </tbody>
    </table>

}

@code {
    private List<Kundekort> _rows = new();
    private bool _loading = true;

    private string _search = "";
    private string _statusFilter = "";
    private string _typeFilter = "";
    private string _sortField = "opprettet";
    private bool _sortAsc = false;

    private readonly string[] _statuses = { "Ny", "Bekreftet", "Sendt bank", "Tilbud", "Fullført", "Avslått" };

    private Dictionary<string, int> _caseCount = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        _rows = await Svc.ListAsync();
        _caseCount = _rows.GroupBy(k => k.KundeId).ToDictionary(g => g.Key, g => g.Count());
        _loading = false;
    }

    private int CaseCount(string kundeId) => _caseCount.GetValueOrDefault(kundeId, 1);

    private List<Kundekort> View
    {
        get
        {
            IEnumerable<Kundekort> q = _rows;

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim().ToLowerInvariant();
                q = q.Where(k =>
                    (k.KundeId?.ToLowerInvariant().Contains(s) ?? false)
                    || (k.FulltNavn?.ToLowerInvariant().Contains(s) ?? false)
                    || (k.Laanetype?.ToLowerInvariant().Contains(s) ?? false));
            }
            if (!string.IsNullOrEmpty(_statusFilter)) q = q.Where(k => k.Status == _statusFilter);
            if (!string.IsNullOrEmpty(_typeFilter)) q = q.Where(k => k.KundeType == _typeFilter);

            Func<Kundekort, object?> key = _sortField switch
            {
                "id" => k => k.KundeId,
                "navn" => k => k.FulltNavn,
                "type" => k => k.KundeType,
                "laanetype" => k => k.Laanetype,
                "belop" => k => k.OnsketLaanebelop ?? 0,
                "status" => k => k.Status,
                "eier" => k => k.EierNavn ?? k.Eier ?? "",
                _ => k => k.CreatedAt,
            };
            q = _sortAsc ? q.OrderBy(key) : q.OrderByDescending(key);
            return q.ToList();
        }
    }

    private RenderFragment Header(string field, string label) => builder =>
    {
        builder.OpenElement(0, "th");
        builder.AddAttribute(1, "class", "sortable");
        builder.AddAttribute(2, "onclick", EventCallback.Factory.Create(this, () => Sort(field)));
        builder.AddContent(3, label);
        if (_sortField == field)
        {
            builder.OpenElement(4, "span");
            builder.AddAttribute(5, "class", "sort-arrow");
            builder.AddContent(6, _sortAsc ? "▲" : "▼");
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private void Sort(string field)
    {
        if (_sortField == field) _sortAsc = !_sortAsc;
        else { _sortField = field; _sortAsc = false; }
    }

    private static string Dt(DateTime d) => d == default ? "—" : d.ToLocalTime().ToString("dd.MM.yyyy HH:mm");

    private async Task ChangeStatus(Kundekort k, ChangeEventArgs e)
    {
        var status = e.Value?.ToString() ?? k.Status;
        k.Status = status;
        await Svc.SetStatusAsync(k.Id, status);
    }

    private async Task TakeOwnership(Kundekort k)
    {
        var eier = Session.Email ?? Session.UserName ?? "ukjent";
        await Svc.SetEierAsync(k.Id, eier, Session.UserName ?? eier);
        k.Eier = eier;
        k.EierNavn = Session.UserName ?? eier;
    }

    private void Open(Guid id) => Nav.NavigateTo($"/crm/ny-kunde?id={id}");
}
