@page "/crm"
@inject RentkuttCRM.Services.SessionState Session
@inject NavigationManager Nav

<PageTitle>Dashbord — Rentekutt</PageTitle>

<h1 class="page-title">Kontrollrommet</h1>
<p class="page-sub">Oversikt over leads, saker og provisjon siste 24 timer.</p>

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-value">0</div>
        <div class="kpi-label">Nye leads (24t)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-value">0 kr</div>
        <div class="kpi-label">Pipeline-verdi</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-value">0</div>
        <div class="kpi-label">Aktive saker</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-value">0 kr</div>
        <div class="kpi-label">Forventet provisjon</div>
    </div>
</div>

<div class="section">
    <h2>Krever oppmerksomhet</h2>
    <div class="priority-grid">
        @foreach (var p in _priorities)
        {
            <div class="priority-card">
                <div class="priority-count">0</div>
                <div class="priority-label">@p</div>
            </div>
        }
    </div>
</div>

<div class="section">
    <h2>Leads uten kontakt</h2>
    <table class="data-table">
        <thead>
            <tr>
                <th>Saksnr</th>
                <th>Kunde</th>
                <th>Lånebeløp</th>
                <th>Siste aktivitet</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <tr><td colspan="5" class="empty-row">Ingen leads ennå.</td></tr>
        </tbody>
    </table>
</div>

<div class="section">
    <h2>Dagens mål</h2>
    <div class="goals-grid">
        @foreach (var g in _goals)
        {
            <div class="goal">
                <div class="goal-head">
                    <span>@g.Label</span>
                    <span>0/@g.Target</span>
                </div>
                <div class="goal-bar"><div class="goal-fill" style="width:0%"></div></div>
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!Session.IsLoggedIn) Nav.NavigateTo("/login");
    }

    private readonly string[] _priorities =
    {
        "Leads uten kontakt",
        "Mangler PSD2-samtykke",
        "Manuell vurdering",
        "Klar for bank",
        "Bank svarer ikke",
        "Uoppfulgte tilbud",
    };

    private record Goal(string Label, int Target);
    private readonly Goal[] _goals =
    {
        new("Leads inn", 25),
        new("Kontaktet", 40),
        new("Kvalifisert", 15),
        new("Sendt bank", 10),
        new("Aksept", 6),
    };
}
