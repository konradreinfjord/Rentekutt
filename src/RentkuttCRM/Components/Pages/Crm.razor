@page "/crm"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.KundekortService Svc
@inject NavigationManager Nav

<PageTitle>Dashbord — Rentekutt</PageTitle>

<div class="dash-head">
    <div>
        <h1 class="page-title">Hei, @Fornavn 👋</h1>
        <p class="page-sub">Her er oversikten din for i dag.</p>
    </div>
    <div class="dash-actions">
        <button class="btn-primary" @onclick='() => Nav.NavigateTo("/crm/ny-kunde")'>+ Opprett kunde</button>
        <button class="btn-logout" @onclick='() => Nav.NavigateTo("/crm/database")'>Database</button>
        <button class="btn-logout" @onclick='() => Nav.NavigateTo("/crm/oppfolging")'>Mine oppfølginger</button>
    </div>
</div>

@if (_loading)
{
    <p class="page-sub">Laster…</p>
}
else
{
    <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-value">@_nye24</div><div class="kpi-label">Nye saker (24t)</div></div>
        <div class="kpi-card"><div class="kpi-value">@_rows.Count</div><div class="kpi-label">Totalt saker</div></div>
        <div class="kpi-card"><div class="kpi-value">@_mine</div><div class="kpi-label">Mine saker</div></div>
        <div class="kpi-card"><div class="kpi-value">@($"{_pipeline / 1_000_000:N1}") mill</div><div class="kpi-label">Pipeline-verdi</div></div>
    </div>

    <div class="section">
        <h2>Saker per status</h2>
        <div class="priority-grid">
            @foreach (var s in _statuser)
            {
                <div class="priority-card" @onclick='() => Nav.NavigateTo("/crm/database")' style="cursor:pointer">
                    <div class="priority-count">@_statusCount.GetValueOrDefault(s, 0)</div>
                    <div class="priority-label">@s</div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Kundekort> _rows = new();
    private Dictionary<string, int> _statusCount = new();
    private int _nye24;
    private int _mine;
    private decimal _pipeline;
    private bool _loading = true;

    private readonly string[] _statuser = KundekortService.Statuser;

    private string Fornavn => (Session.UserName ?? "der").Split(' ')[0];

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        _rows = await Svc.ListAsync();

        var na = DateTime.UtcNow;
        _nye24 = _rows.Count(k => k.CreatedAt > na.AddHours(-24));
        _mine = _rows.Count(k => !string.IsNullOrWhiteSpace(Session.Email) && k.Eier == Session.Email);
        _pipeline = _rows.Where(k => k.Status is not (KundekortService.StatusFullfort or "Avslått")).Sum(k => k.OnsketLaanebelop ?? 0);
        _statusCount = _rows.GroupBy(k => k.Status).ToDictionary(g => g.Key, g => g.Count());

        _loading = false;
    }
}
