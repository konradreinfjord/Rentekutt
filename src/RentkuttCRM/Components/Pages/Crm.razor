@page "/crm"
@inject RentkuttCRM.Services.SessionState Session
@inject NavigationManager Nav

<PageTitle>Dashbord — Rentekutt</PageTitle>

<div class="dash-head">
    <div>
        <h1 class="page-title">Hei, @Fornavn 👋</h1>
        <p class="page-sub">Her er oversikten din for i dag.</p>
    </div>
    <div class="dash-actions">
        <button class="btn-primary" @onclick='() => Nav.NavigateTo("/crm/ny-kunde")'>+ Opprett kunde</button>
        <button class="btn-logout" @onclick='() => Nav.NavigateTo("/crm/database")'>Database</button>
        <button class="btn-logout" @onclick='() => Nav.NavigateTo("/crm/oppfolging")'>Mine oppfølginger</button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card"><div class="kpi-value">0</div><div class="kpi-label">Nye saker (24t)</div></div>
    <div class="kpi-card"><div class="kpi-value">0</div><div class="kpi-label">Mine aktive saker</div></div>
    <div class="kpi-card"><div class="kpi-value">0 kr</div><div class="kpi-label">Pipeline-verdi</div></div>
    <div class="kpi-card"><div class="kpi-value">0 kr</div><div class="kpi-label">Forventet provisjon</div></div>
</div>

<div class="section">
    <h2>Krever oppmerksomhet</h2>
    <div class="priority-grid">
        @foreach (var p in _priorities)
        {
            <div class="priority-card">
                <div class="priority-count">0</div>
                <div class="priority-label">@p</div>
            </div>
        }
    </div>
</div>

<div class="section">
    <h2>Saker uten kontakt</h2>
    <table class="data-table">
        <thead>
            <tr><th>Saksnr</th><th>Kunde</th><th>Lånebeløp</th><th>Siste aktivitet</th><th></th></tr>
        </thead>
        <tbody>
            <tr><td colspan="5" class="empty-row">Ingen saker uten kontakt. 🎉</td></tr>
        </tbody>
    </table>
</div>

<div class="section">
    <h2>Dagens mål</h2>
    <div class="goals-grid">
        @foreach (var g in _goals)
        {
            <div class="goal">
                <div class="goal-head"><span>@g.Label</span><span>0/@g.Target</span></div>
                <div class="goal-bar"><div class="goal-fill" style="width:0%"></div></div>
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!Session.IsLoggedIn) Nav.NavigateTo("/login");
    }

    private string Fornavn => (Session.UserName ?? "der").Split(' ')[0];

    private readonly string[] _priorities =
    {
        "Saker uten kontakt",
        "Mangler PSD2-samtykke",
        "Manuell vurdering",
        "Klar for bank",
        "Bank svarer ikke",
        "Uoppfulgte tilbud",
    };

    private record Goal(string Label, int Target);
    private readonly Goal[] _goals =
    {
        new("Saker inn", 25),
        new("Kontaktet", 40),
        new("Kvalifisert", 15),
        new("Sendt bank", 10),
        new("Aksept", 6),
    };
}
