@page "/crm"
@inject RentkuttCRM.Services.SessionState Session
@inject RentkuttCRM.Services.KundekortService Svc
@inject NavigationManager Nav

<PageTitle>Dashbord — Rentekutt</PageTitle>

<div class="dash-head">
    <div>
        <h1 class="page-title">Hei, @Fornavn 👋</h1>
        <p class="page-sub">Her er oversikten din for i dag.</p>
    </div>
</div>

@if (_loading)
{
    <p class="page-sub">Laster…</p>
}
else
{
    <div class="stat-grid">
        @* Nye søknader (24t) — først *@
        <div class="stat-card accent-blue">
            <div class="stat-top">
                <span class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg></span>
                <span class="stat-lbl">Nye søknader · 24t</span>
            </div>
            <div class="stat-num">@_nye24</div>
            <div class="stat-sub">
                @if (_kilde24.Count > 0)
                {
                    @foreach (var (kilde, antall) in _kilde24)
                    {
                        <span class="kilde-badge @KundekortService.KildeBadgeKlasse(kilde)">@kilde @antall</span>
                    }
                }
                else { <span>Ingen nye siste døgn</span> }
            </div>
        </div>

        @* Utatte saker *@
        <div class="stat-card stat-click accent-amber @(_utatte > 0 ? "warn" : "")" @onclick='() => Nav.NavigateTo("/crm/marked/person")'>
            <div class="stat-top">
                <span class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
                <span class="stat-lbl">Utatte saker</span>
            </div>
            <div class="stat-num @(_utatte > 0 ? "num-warn" : "")">@_utatte</div>
            <div class="stat-sub">@(_utatte == 0 ? "Alt er plukket 🎉" : "venter på å plukkes")</div>
        </div>

        @* Personmarked (B2C) *@
        <div class="stat-card stat-click accent-green" @onclick='() => Nav.NavigateTo("/crm/marked/person")'>
            <div class="stat-top">
                <span class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                <span class="stat-lbl">Personmarked</span>
            </div>
            <div class="stat-num">@_b2c</div>
            <div class="stat-sub">B2C — privatkunder</div>
        </div>

        @* Bedriftsmarked (B2B) *@
        <div class="stat-card stat-click accent-purple" @onclick='() => Nav.NavigateTo("/crm/marked/bedrift")'>
            <div class="stat-top">
                <span class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/></svg></span>
                <span class="stat-lbl">Bedriftsmarked</span>
            </div>
            <div class="stat-num">@_b2b</div>
            <div class="stat-sub">B2B — bedriftskunder</div>
        </div>

        @* Mine søknader *@
        <div class="stat-card stat-click accent-teal" @onclick='() => Nav.NavigateTo("/crm/oppfolging")'>
            <div class="stat-top">
                <span class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></span>
                <span class="stat-lbl">Mine søknader</span>
            </div>
            <div class="stat-num">@_mine</div>
            <div class="stat-sub">dine aktive saker</div>
        </div>

        @* Totalt søknader *@
        <div class="stat-card">
            <div class="stat-top">
                <span class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg></span>
                <span class="stat-lbl">Totalt søknader</span>
            </div>
            <div class="stat-num">@_rows.Count</div>
            <div class="stat-sub">@_b2c privat · @_b2b bedrift</div>
        </div>

        @* Pipeline-verdi *@
        <div class="stat-card">
            <div class="stat-top">
                <span class="stat-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></span>
                <span class="stat-lbl">Pipeline-verdi</span>
            </div>
            <div class="stat-num">@($"{_pipeline / 1_000_000:N1}")<span class="stat-unit">MNOK</span></div>
            <div class="stat-sub">aktiv pipeline</div>
        </div>
    </div>

    <div class="section">
        <h2>Leads siste 30 dager</h2>
        <div class="daybar-wrap">
            <div class="daybar-chart daybar-30">
                @foreach (var dag in _dager)
                {
                    <div class="daybar-col" title="@dag.Label — @dag.Total leads">
                        <div class="daybar-total">@(dag.Total > 0 ? dag.Total.ToString() : "")</div>
                        <div class="daybar-stack">
                            @foreach (var s in _statuser)
                            {
                                var c = dag.PerStatus.GetValueOrDefault(s, 0);
                                @if (c > 0)
                                {
                                    <div class="daybar-seg" style="height:@(((double)c / _maxDag * 100).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%; background:@StatusFarge(s)" title="@s: @c"></div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="daybar-axis"><span>@_dager.FirstOrDefault()?.Label</span><span>I dag</span></div>

            <div class="breakdown-grid">
                <div>
                    <h3 class="stat-subhead">Status</h3>
                    <table class="status-table">
                        <tbody>
                            @foreach (var s in _statuser)
                            {
                                <tr @onclick='() => Nav.NavigateTo("/crm/database")' style="cursor:pointer">
                                    <td class="status-name"><span class="status-dot" style="background:@StatusFarge(s)"></span>@s</td>
                                    <td class="num">@_statusCount30.GetValueOrDefault(s, 0)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div>
                    <h3 class="stat-subhead">Lånetype</h3>
                    <table class="status-table">
                        <tbody>
                            @foreach (var (type, antall) in _laanetype30)
                            {
                                <tr><td class="status-name"><span class="status-dot" style="background:@LaanetypeFarge(type)"></span>@type</td><td class="num">@antall</td></tr>
                            }
                            @if (_laanetype30.Count == 0) { <tr><td colspan="2" class="empty-row">Ingen data.</td></tr> }
                        </tbody>
                    </table>
                </div>
                <div>
                    <h3 class="stat-subhead">Leadskilde</h3>
                    <table class="status-table">
                        <tbody>
                            @foreach (var (kilde, antall) in _kilde30)
                            {
                                <tr><td><span class="kilde-badge @KundekortService.KildeBadgeKlasse(kilde)">@kilde</span></td><td class="num">@antall</td></tr>
                            }
                            @if (_kilde30.Count == 0) { <tr><td colspan="2" class="empty-row">Ingen data.</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Kundekort> _rows = new();
    private Dictionary<string, int> _statusCount30 = new();
    private List<(string Kilde, int Antall)> _kilde24 = new();
    private List<(string Type, int Antall)> _laanetype30 = new();
    private List<(string Kilde, int Antall)> _kilde30 = new();

    private static string LaanetypeFarge(string type) => type switch
    {
        "Forbrukslån" => "#6b3fc4",
        "Refinansiering" => "#1f5fc4",
        "Boliglån" => "#266f32",
        _ => "#9aa0a8",
    };
    private int _nye24;
    private int _mine;
    private decimal _pipeline;
    private bool _loading = true;

    // Utatte saker = ikke plukket (ingen eier) og ikke ferdigbehandlet.
    private int _utatte, _b2c, _b2b;

    private List<DagBar> _dager = new();
    private int _maxDag = 1;
    private record DagBar(string Label, Dictionary<string, int> PerStatus, int Total);

    private readonly string[] _statuser = KundekortService.Statuser;

    private static string StatusFarge(string status) => status switch
    {
        "Åpen" => "#2f8a3e",                // grønn
        "Pågår" => "#1f5fc4",               // blå
        "Manuell behandling" => "#c2740a",  // amber
        "Sendt bank" => "#6b3fc4",          // lilla
        "Tilbud utsendt" => "#0f8a8a",      // teal
        "Fullført og utbetalt" => "#266f32",// mørk grønn
        "Avslått" => "#b42318",             // rød
        _ => "#9aa0a8"
    };

    private string Fornavn => (Session.UserName ?? "der").Split(' ')[0];

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        _rows = await Svc.ListAsync();

        var na = DateTime.UtcNow;
        var siste24 = _rows.Where(k => k.CreatedAt > na.AddHours(-24)).ToList();
        _nye24 = siste24.Count;
        _kilde24 = siste24
            .GroupBy(k => string.IsNullOrWhiteSpace(k.Kilde) ? "Ukjent" : k.Kilde)
            .Select(g => (g.Key, g.Count()))
            .OrderByDescending(x => x.Item2)
            .ToList();
        _mine = _rows.Count(k => !string.IsNullOrWhiteSpace(Session.Email) && k.Eier == Session.Email);
        _pipeline = _rows.Where(k => k.Status is not (KundekortService.StatusFullfort or "Avslått")).Sum(k => k.OnsketLaanebelop ?? 0);

        // Utatte: ingen eier + fortsatt aktiv (ikke fullført/avslått).
        _utatte = _rows.Count(k => string.IsNullOrWhiteSpace(k.Eier)
                                   && k.Status is not (KundekortService.StatusFullfort or "Avslått"));
        _b2c = _rows.Count(k => k.KundeType == "B2C");
        _b2b = _rows.Count(k => k.KundeType == "B2B");
        var idag = DateTime.Now.Date;
        _dager = new();
        for (var i = 29; i >= 0; i--)
        {
            var d = idag.AddDays(-i);
            var dagLeads = _rows.Where(k => k.CreatedAt.ToLocalTime().Date == d).ToList();
            var perStatus = dagLeads.GroupBy(k => k.Status).ToDictionary(g => g.Key, g => g.Count());
            var label = i == 0 ? "I dag" : i == 1 ? "I går" : d.ToString("dd.MM");
            _dager.Add(new DagBar(label, perStatus, dagLeads.Count));
        }
        _maxDag = Math.Max(1, _dager.Max(d => d.Total));

        var fra30 = idag.AddDays(-29);
        var siste30 = _rows.Where(k => k.CreatedAt.ToLocalTime().Date >= fra30).ToList();
        _statusCount30 = siste30.GroupBy(k => k.Status).ToDictionary(g => g.Key, g => g.Count());
        _laanetype30 = siste30
            .GroupBy(k => string.IsNullOrWhiteSpace(k.Laanetype) ? "Ukjent" : k.Laanetype)
            .Select(g => (g.Key, g.Count())).OrderByDescending(x => x.Item2).ToList();
        _kilde30 = siste30
            .GroupBy(k => string.IsNullOrWhiteSpace(k.Kilde) ? "Ukjent" : k.Kilde)
            .Select(g => (g.Key, g.Count())).OrderByDescending(x => x.Item2).ToList();

        _loading = false;
    }
}
